{%- comment -%}
  LE FIGUE — The FIGUE Edit (editorial board + article reader).
  Ported from ~/Downloads/le-figue-the-edit-v2  (1).html; theme header/footer
  wrap it (design's own announce/header/footer removed). Namespaced .lf-edit,
  ids prefixed lfe*. The design's dark "Dispatch" band was dropped — the
  global Dispatch section already renders above the footer on every page.
  The design toggled article view via body.reading — rescoped to a .reading
  class on the .lf-edit section root (same pattern as Agenda's listmode).
  CONTENT: the 10 articles are the ENTRIES array in the JS below ("MD edits
  here" per the design) with a mini image DSL (first| pull| full: duo: trio:
  cap:) documented inline. Manager-friendly editing (Shopify Blog articles)
  is a later editability-pass task.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css">

<div class="lf-edit">

  <!-- ===== BOARD VIEW ===== -->
  <div class="view-board">

    <!-- masthead -->
    <section class="masthead">
      <div class="mast-line"><span>LE FIGUE</span><span>·</span><span>No. 24</span><span>·</span><span>Summer 2026</span></div>
      <h1>The FIGUE Edit</h1>
      <p class="mast-sub">From our table, our travels, and our jewelry trays. What we see, wherever we are, comes back to New York.</p>
      <div class="mast-rule"></div>
    </section>

    <div class="edit-wrap">

      <!-- sommaire -->
      <div class="sommaire" id="lfeSommaire">
        <button class="som" data-cat="The Vault">
          <div class="sc">I</div>
          <div class="sn">The Vault</div>
          <div class="sd">How to look at jewelry. Gold, pearls, settings, and the way we wear them.</div>
        </button>
        <button class="som" data-cat="En Route">
          <div class="sc">II</div>
          <div class="sn">En Route</div>
          <div class="sd">Hotels, tables, and rooms we pass through on the way to the pieces.</div>
        </button>
        <button class="som" data-cat="The Maker">
          <div class="sc">III</div>
          <div class="sn">The Maker</div>
          <div class="sd">The hands, the benches, and the designers we choose to carry.</div>
        </button>
        <button class="som" data-cat="City Edit">
          <div class="sc">IV</div>
          <div class="sn">City Edit</div>
          <div class="sd">New York, from our two doors outward.</div>
        </button>
      </div>

      <!-- feature lead -->
      <a class="feature" id="lfeFeature" data-id="villa-crespi">
        <div class="fimg"><span class="ph">Lead photograph · Villa Crespi</span></div>
        <div class="ftx">
          <div class="fk">The Latest · En Route</div>
          <h2 class="ft">Three sentences from Villa Crespi</h2>
          <p class="fs">We went to Lake Orta for dinner. We came back with notes about jewelry.</p>
          <span class="fr">Read the story <svg viewBox="0 0 20 12"><path d="M1 6h17M13 1l5 5-5 5"/></svg></span>
        </div>
      </a>

      <!-- filter -->
      <div class="filterbar">
        <div class="filterbar-in" id="lfeFilterbar">
          <button class="filt on" data-cat="all">All</button>
          <button class="filt" data-cat="The Vault">The Vault</button>
          <button class="filt" data-cat="En Route">En Route</button>
          <button class="filt" data-cat="The Maker">The Maker</button>
          <button class="filt" data-cat="City Edit">City Edit</button>
        </div>
      </div>

      <!-- mosaic -->
      <div class="board" id="lfeBoard"><!-- cards injected by JS --></div>

    </div>
  </div>

  <!-- ===== ARTICLE VIEW ===== -->
  <div class="view-article">
    <div class="art-wrap">
      <button class="art-back" id="lfeArtBack"><svg viewBox="0 0 24 24"><path d="M15 5l-7 7 7 7"/></svg> Back to the edit</button>
      <div class="art-head">
        <div class="art-tag" id="lfeArtTag">City Edit</div>
        <h1 class="art-title" id="lfeArtTitle">Title</h1>
        <p class="art-stand" id="lfeArtStand">Standfirst</p>
        <div class="art-meta" id="lfeArtMeta">LE FIGUE · The Edit</div>
      </div>
      <div class="art-hero" id="lfeArtHero"><div class="ph">Lead photograph</div></div>
      <div class="art-body" id="lfeArtBody"><!-- filled by JS --></div>
    </div>
    <div class="art-rel">
      <h4>More from the edit</h4>
      <div class="rel-grid" id="lfeRelGrid"><!-- filled by JS --></div>
    </div>
  </div>

</div>

{% stylesheet %}
  .lf-edit{ --ink:#2a2622; --ink-soft:#6b635a; --line:#e3dccf; --line-soft:#efe9dd;
    --cream:#faf7f1; --cream-deep:#f3ede1; --accent:#8a7250; --gold:#b8975f;
    --gold-pale:#d9c49a; --paper:#fdfbf6;
    background:var(--cream); color:var(--ink);
    font-family:'Pretendard Variable','Pretendard',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    font-weight:400; line-height:1.7; -webkit-font-smoothing:antialiased; }
  .lf-edit *{ margin:0; padding:0; box-sizing:border-box; }
  .lf-edit .display{ font-family:'Cormorant Garamond',serif; }
  .lf-edit a{ color:inherit; text-decoration:none; }
  .lf-edit img{ display:block; }

  .lf-edit .edit-wrap{ max-width:1320px; margin:0 auto; padding:0 30px; }

  /* ===== MASTHEAD ===== */
  .lf-edit .masthead{ text-align:center; padding:74px 0 0; }
  .lf-edit .mast-line{ font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:11px; letter-spacing:.32em; text-transform:uppercase; color:var(--ink-soft); display:flex; align-items:center; justify-content:center; gap:22px; }
  .lf-edit .mast-line::before,.lf-edit .mast-line::after{ content:""; height:1px; width:64px; background:var(--line); }
  .lf-edit .masthead h1{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(58px,9vw,124px); line-height:.96; letter-spacing:-.02em; margin:26px 0 20px; }
  .lf-edit .mast-sub{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(16px,2.2vw,20px); color:var(--ink-soft); max-width:560px; margin:0 auto; line-height:1.6; }
  .lf-edit .mast-rule{ max-width:1320px; margin:52px auto 0; border-top:1px solid var(--ink); border-bottom:1px solid var(--line); height:4px; }

  /* ===== SOMMAIRE ===== */
  .lf-edit .sommaire{ display:grid; grid-template-columns:repeat(4,1fr); border-bottom:1px solid var(--line); }
  .lf-edit .som{ padding:30px 26px 34px; text-align:left; background:none; border:none; border-right:1px solid var(--line-soft); cursor:pointer; transition:background .25s; position:relative; font-family:inherit; }
  .lf-edit .som:last-child{ border-right:none; }
  .lf-edit .som:hover,.lf-edit .som.on{ background:var(--paper); }
  .lf-edit .som::after{ content:""; position:absolute; left:26px; right:100%; bottom:0; height:2px; background:var(--accent); transition:right .3s ease; }
  .lf-edit .som:hover::after,.lf-edit .som.on::after{ right:26px; }
  .lf-edit .som .sc{ font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:10px; letter-spacing:.24em; text-transform:uppercase; color:var(--gold); }
  .lf-edit .som .sn{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(21px,2.4vw,27px); line-height:1.1; margin:10px 0 8px; color:var(--ink); }
  .lf-edit .som .sd{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14.5px; line-height:1.55; color:var(--ink-soft); }

  /* ===== FEATURE LEAD ===== */
  .lf-edit .feature{ display:grid; grid-template-columns:7fr 5fr; gap:0; border-bottom:1px solid var(--line); cursor:pointer; }
  .lf-edit .feature .fimg{ aspect-ratio:4/3; overflow:hidden; background:linear-gradient(135deg,#ece4d4,#ddd2c0); position:relative; }
  .lf-edit .feature .fimg img{ width:100%; height:100%; object-fit:cover; transition:transform 1.1s cubic-bezier(.2,.7,.2,1); }
  .lf-edit .feature:hover .fimg img{ transform:scale(1.035); }
  .lf-edit .feature .fimg .ph{ position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:#c4b699; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; }
  .lf-edit .feature .ftx{ padding:clamp(30px,4.5vw,70px) clamp(26px,4vw,64px); display:flex; flex-direction:column; justify-content:center; border-left:1px solid var(--line-soft); }
  .lf-edit .feature .fk{ font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:10.5px; letter-spacing:.26em; text-transform:uppercase; color:var(--gold); margin-bottom:20px; display:flex; align-items:center; gap:14px; }
  .lf-edit .feature .fk::after{ content:""; height:1px; flex:1; max-width:48px; background:var(--line); }
  .lf-edit .feature .ft{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(30px,3.6vw,48px); line-height:1.04; letter-spacing:-.015em; margin-bottom:18px; transition:color .2s; }
  .lf-edit .feature:hover .ft{ color:var(--accent); }
  .lf-edit .feature .fs{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(16px,1.8vw,19px); line-height:1.6; color:var(--ink-soft); margin-bottom:30px; max-width:400px; }
  .lf-edit .feature .fr{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:16px; color:var(--ink); display:inline-flex; align-items:center; gap:10px; }
  .lf-edit .feature .fr svg{ width:17px; height:12px; stroke:var(--accent); stroke-width:1.3; fill:none; transition:transform .25s; }
  .lf-edit .feature:hover .fr svg{ transform:translateX(5px); }

  /* ===== FILTER ===== */
  .lf-edit .filterbar{ position:sticky; top:0; z-index:40; background:rgba(250,247,241,.96); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); border-bottom:1px solid var(--line); }
  .lf-edit .filterbar-in{ display:flex; align-items:center; justify-content:center; gap:8px; flex-wrap:wrap; padding:17px 0; }
  .lf-edit .filt{ font-family:'Cormorant Garamond',serif; font-size:16px; letter-spacing:.04em; color:var(--ink-soft); border:none; background:none; padding:4px 2px; margin:0 16px; cursor:pointer; position:relative; transition:color .18s; }
  .lf-edit .filt::after{ content:""; position:absolute; left:0; right:100%; bottom:-2px; height:1px; background:var(--accent); transition:right .25s ease; }
  .lf-edit .filt:hover{ color:var(--ink); }
  .lf-edit .filt.on{ color:var(--accent); }
  .lf-edit .filt.on::after{ right:0; }
  .lf-edit .filt .ct{ font-size:11px; color:var(--gold); font-style:italic; margin-left:4px; vertical-align:super; }

  /* ===== BOARD ===== */
  .lf-edit .board{ display:grid; grid-template-columns:repeat(3,1fr); gap:48px 24px; padding:56px 0 30px; }
  .lf-edit .card{ cursor:pointer; display:block; }
  .lf-edit .card .cimg{ position:relative; overflow:hidden; background:linear-gradient(135deg,#f3ede1,#e9e1d2); aspect-ratio:4/5; }
  .lf-edit .card .cimg img{ width:100%; height:100%; object-fit:cover; transition:transform .9s cubic-bezier(.2,.7,.2,1); }
  .lf-edit .card:hover .cimg img{ transform:scale(1.045); }
  .lf-edit .card .cimg .ph{ position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:#cbbfa6; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; }
  .lf-edit .card .meta{ padding:16px 2px 0; border-top:1px solid var(--line); margin-top:16px; }
  .lf-edit .card .kc{ font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--gold); display:flex; align-items:baseline; justify-content:space-between; gap:12px; }
  .lf-edit .card .kc .sub{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:12.5px; letter-spacing:.02em; text-transform:none; color:var(--ink-soft); }
  .lf-edit .card .ttl{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:22px; line-height:1.18; color:var(--ink); margin-top:10px; transition:color .15s; }
  .lf-edit .card:hover .ttl{ color:var(--accent); }
  .lf-edit .card.hide{ display:none; }

  /* ===== ARTICLE view (scoped: .reading on section root, not <body>) ===== */
  .lf-edit .view-board{ display:block; }
  .lf-edit .view-article{ display:none; }
  .lf-edit.reading .view-board{ display:none; }
  .lf-edit.reading .view-article{ display:block; }

  .lf-edit .art-wrap{ max-width:1000px; margin:0 auto; padding:0 30px; }
  .lf-edit .art-back{ display:inline-flex; align-items:center; gap:8px; margin:32px 0 0; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; color:var(--ink-soft); background:none; border:none; cursor:pointer; transition:color .18s; }
  .lf-edit .art-back:hover{ color:var(--accent); }
  .lf-edit .art-back svg{ width:16px; height:16px; stroke:currentColor; stroke-width:1.4; fill:none; }

  .lf-edit .art-head{ padding:36px 0 26px; text-align:center; margin-bottom:36px; position:relative; }
  .lf-edit .art-head::after{ content:""; position:absolute; left:50%; bottom:0; transform:translateX(-50%); width:64px; height:1px; background:var(--gold); }
  .lf-edit .art-tag{ font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:11px; letter-spacing:.3em; text-transform:uppercase; color:var(--gold); margin-bottom:18px; }
  .lf-edit .art-title{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(38px,6vw,70px); line-height:1.02; letter-spacing:-.015em; margin-bottom:18px; }
  .lf-edit .art-stand{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(18px,2.4vw,22px); color:var(--ink-soft); max-width:620px; margin:0 auto; line-height:1.5; }
  .lf-edit .art-meta{ margin-top:22px; font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-soft); }

  .lf-edit .art-hero{ aspect-ratio:16/9; overflow:hidden; background:linear-gradient(135deg,#e9e1d2,#ddd2c0); margin-bottom:44px; }
  .lf-edit .art-hero .ph{ height:100%; display:flex; align-items:center; justify-content:center; color:#cbbfa6; font-family:'Cormorant Garamond',serif; font-style:italic; }
  .lf-edit .art-hero img{ width:100%; height:100%; object-fit:cover; }

  .lf-edit .art-body{ max-width:680px; margin:0 auto; }
  .lf-edit .art-body p{ font-size:16px; line-height:1.95; color:var(--ink); margin-bottom:22px; }
  .lf-edit .art-body p.first::first-letter{ font-family:'Cormorant Garamond',serif; font-size:62px; line-height:.8; float:left; margin:6px 12px 0 0; color:var(--accent); font-weight:500; }
  .lf-edit .art-body .pull{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:27px; line-height:1.4; color:var(--accent); text-align:center; margin:44px 0; padding:0 20px; }

  .lf-edit .art-duo{ display:grid; grid-template-columns:1fr 1fr; gap:18px; margin:40px 0; }
  .lf-edit .art-duo .di{ aspect-ratio:4/5; overflow:hidden; background:linear-gradient(135deg,#f3ede1,#e9e1d2); }
  .lf-edit .art-duo .di .ph{ height:100%; display:flex; align-items:center; justify-content:center; color:#cbbfa6; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13px; }

  .lf-edit .art-full{ aspect-ratio:3/2; overflow:hidden; background:linear-gradient(135deg,#e9e1d2,#ddd2c0); margin:40px 0; }
  .lf-edit .art-full .ph{ height:100%; display:flex; align-items:center; justify-content:center; color:#cbbfa6; font-family:'Cormorant Garamond',serif; font-style:italic; }
  .lf-edit .art-full img,.lf-edit .art-duo .di img,.lf-edit .art-trio .ti img{ width:100%; height:100%; object-fit:cover; }

  .lf-edit .art-trio{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; margin:40px 0; }
  .lf-edit .art-trio .ti{ aspect-ratio:3/4; overflow:hidden; background:linear-gradient(135deg,#f3ede1,#e9e1d2); }
  .lf-edit .art-trio .ti .ph{ height:100%; display:flex; align-items:center; justify-content:center; color:#cbbfa6; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:12px; text-align:center; padding:0 8px; }

  .lf-edit .art-cap{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13.5px; color:var(--ink-soft); text-align:center; margin:-28px 0 40px; }

  .lf-edit .art-shop{ border-top:1px solid var(--line); border-bottom:1px solid var(--line); padding:30px 0; margin:48px 0; display:grid; grid-template-columns:90px 1fr auto; gap:20px; align-items:center; }
  .lf-edit .art-shop .si{ width:90px; aspect-ratio:1/1; background:linear-gradient(135deg,#f3ede1,#e9e1d2); overflow:hidden; }
  .lf-edit .art-shop .sk{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13px; color:var(--gold); }
  .lf-edit .art-shop .sn{ font-family:'Cormorant Garamond',serif; font-size:21px; color:var(--ink); margin-top:2px; }
  .lf-edit .art-shop .sp{ font-size:13px; color:var(--ink-soft); margin-top:3px; }
  .lf-edit .art-shop .sbtn{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; color:var(--ink); border:1px solid var(--accent); padding:11px 26px; background:none; cursor:pointer; white-space:nowrap; transition:.2s; }
  .lf-edit .art-shop .sbtn:hover{ background:var(--accent); color:var(--paper); }

  .lf-edit .art-rel{ max-width:1000px; margin:60px auto 0; padding:0 30px; }
  .lf-edit .art-rel h4{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; letter-spacing:.14em; text-transform:uppercase; color:var(--gold); text-align:center; margin-bottom:24px; }
  .lf-edit .rel-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  .lf-edit .rel-card{ cursor:pointer; }
  .lf-edit .rel-card .ri{ aspect-ratio:4/5; overflow:hidden; background:linear-gradient(135deg,#f3ede1,#e9e1d2); margin-bottom:10px; }
  .lf-edit .rel-card .ri img{ width:100%; height:100%; object-fit:cover; transition:transform .9s cubic-bezier(.2,.7,.2,1); }
  .lf-edit .rel-card:hover .ri img{ transform:scale(1.05); }
  .lf-edit .rel-card .ri .ph{ height:100%; display:flex; align-items:center; justify-content:center; color:#cbbfa6; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:12px; }
  .lf-edit .rel-card .rt-tag{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:11.5px; color:var(--gold); }
  .lf-edit .rel-card .rt{ font-family:'Cormorant Garamond',serif; font-size:17px; line-height:1.2; color:var(--ink); margin-top:2px; }

  /* responsive */
  @media(max-width:980px){
    .lf-edit .sommaire{ grid-template-columns:1fr 1fr; }
    .lf-edit .som{ border-bottom:1px solid var(--line-soft); }
    .lf-edit .som:nth-child(2n){ border-right:none; }
    .lf-edit .feature{ grid-template-columns:1fr; }
    .lf-edit .feature .ftx{ border-left:none; border-top:1px solid var(--line-soft); }
    .lf-edit .board{ grid-template-columns:repeat(2,1fr); gap:40px 20px; }
  }
  @media(max-width:620px){
    .lf-edit .edit-wrap,.lf-edit .art-wrap,.lf-edit .art-rel{ padding:0 20px; }
    .lf-edit .masthead{ padding-top:52px; }
    .lf-edit .mast-rule{ margin-top:38px; }
    .lf-edit .sommaire{ grid-template-columns:1fr; }
    .lf-edit .som{ border-right:none; }
    .lf-edit .board{ grid-template-columns:1fr; padding-top:40px; }
    .lf-edit .filt{ margin:0 10px; font-size:15px; }
    .lf-edit .art-duo{ grid-template-columns:1fr; }
    .lf-edit .art-trio{ grid-template-columns:1fr; }
    .lf-edit .art-trio .ti{ aspect-ratio:4/3; }
    .lf-edit .art-shop{ grid-template-columns:1fr; text-align:center; }
    .lf-edit .art-shop .si{ margin:0 auto; }
    .lf-edit .rel-grid{ grid-template-columns:1fr; }
  }
{% endstylesheet %}

{% javascript %}
  (function(){
    var root = document.querySelector('.lf-edit');
    if (!root) return;
    function $(id){ return root.querySelector('#' + id); }

    /* ---------- CONTENT DATA (MD edits here) ----------
       cats: The Vault | En Route | The Maker | City Edit
       The feature lead at top is the first entry (villa-crespi).
       IMAGE SYNTAX inside body (repeat any number of times):
         full:caption            -> one wide image (placeholder)
         full:caption@imageURL   -> one real image
         duo:cap1@URL1,cap2@URL2 -> two side by side (omit URL = placeholder)
         trio:c1@U1,c2@U2,c3@U3  -> three side by side
         cap:caption text        -> italic caption under the image above
       Hero/card images: add hero:'URL', card:'URL' to an entry.            */
    var ENTRIES = [
      { id:'villa-crespi', cat:'En Route',
         title:'Three sentences from Villa Crespi', sub:'Lake Orta',
         stand:'We went to Lake Orta for dinner. We came back with notes about jewelry.',
         meta:'En Route · Piedmont',
         body:'first|We went for the food. We spent half the evening looking at the ceiling.\n|This is the occupational condition we have accepted. Wherever we go, we are thinking about LE FIGUE. A hotel corridor becomes a lesson in lighting. A table setting becomes a case study in spacing. And a nineteenth century villa on Lake Orta becomes, over one long dinner, a building that thinks like a jewel.\npull|A building that thinks like a jewel.\nduo:The ceiling at dinner,The table@\ntrio:The dome,By candlelight,Lake Orta\ncap:Villa Crespi, one long dinner in June\n|Dense where it wants your attention. Quiet where it wants you to rest. Nothing placed without intention. Some of that logic is already in the West Village store, if you look. The rest is coming to Bleecker Street in September.',
         shop:{k:'Visit',n:'West Village',p:'18 Christopher Street'} },

      { id:'summer-light', cat:'The Vault',
         title:'Last summer light, in gold', sub:'In season',
         stand:'The season turns soft and low. We followed the light, and found the pieces that hold it best.',
         meta:'The Vault · No. 24',
         body:'first|The season turns, and the light goes long and low across the city. It is the hour the windows turn amber, when everything looks a little more considered than it did at noon.\n|We followed it for a week. Down Christopher Street at six, through the gallery on Bleecker just before close, and back to the studio where the gold pieces sat catching the last of it.\npull|Warm metals were made for this hour.\n|What to layer it with: a fine chain you forget you are wearing, a single ear cuff, and one piece that does the talking. Nothing more.|duo:A worn detail,The light at six\n|This is the edit for the weeks when the year softens. Slow, warm, and worth pausing for.',
         shop:{k:'In this edit',n:'The Summer Light Stack',p:'Three pieces, layered'} },

      { id:'paris-studio', cat:'En Route',
         title:'A studio above the rooftops', sub:'Paris',
         stand:'Five floors up, a room full of light, and three pieces we could not stop thinking about.',
         meta:'En Route · Paris',
         body:'first|We climbed five floors to a room that smelled of metal and coffee. The maker did not look up at first, bent over a bench by the window, the rooftops of the 3rd arrondissement falling away behind her.\n|We had come for one collection and left thinking about three pieces we had not planned to carry.\npull|We choose the maker first. The pieces follow.\nfull:The studio, in morning light\n|Everything here is finished by hand. You can feel it in the weight, in the way an edge is softened rather than left sharp. That is the difference we look for, and the reason a piece earns a place in the edit.\n|These arrive in the coming weeks. We will tell you first.',
         shop:{k:'From this journey',n:'Atelier Pieces',p:'Arriving soon'} },

      { id:'the-hands', cat:'The Maker',
         title:'Hands at work', sub:'The maker',
         stand:'A portrait of the bench, the tools, and the quiet hours a single piece asks for.',
         meta:'The Maker',
         body:'first|A piece looks effortless when it is finished. The hours before that are anything but.\n|We spent a morning at the bench, watching a single ring come together. Filed, soldered, set, polished, then set down and picked up again until it was right.\npull|Considered is not a style. It is a way of working.\nduo:At the bench,The finished piece\n|This is what we mean when we say made by hand. Not a label, but a person, and the time they were willing to give.',
         shop:{k:'By this maker',n:'The Signet, reimagined',p:'In the edit now'} },

      { id:'everyday-stack', cat:'The Vault',
         title:'The everyday stack', sub:'Styling note',
         stand:'Three pieces, worn together, for the days that do not announce themselves.',
         meta:'The Vault · Styling',
         body:'first|The best jewelry is the kind you stop noticing you have on. Not because it disappears, but because it has become part of how you dress without thinking.\n|This is the stack we reach for most. A fine chain, a slim band, and one ear piece with a little weight to it.\npull|Come for the edit, stay for the stack.\n|Layer by proportion, not by rule. Let one piece lead and the others follow it. That is the whole of it.',
         shop:{k:'Wear it',n:'The Everyday Stack',p:'Three pieces, layered'} },

      { id:'objects-christopher', cat:'City Edit',
         title:'The objects we keep at Christopher Street', sub:'The house',
         stand:'Our West Village store holds more than jewelry. A short inventory of the things that are not for sale.',
         meta:'City Edit · West Village',
         body:'first|People ask about the objects almost as often as they ask about the pieces.\n|Nothing in the store arrived by accident. Every object was found somewhere, carried home, and given a place. Some came from vintage shops in the city. Some flew across an ocean in a carry on, wrapped in a sweater.\npull|Nothing in the store arrived by accident.\nduo:The shelf by the window,Found, then kept\n|We keep them because a jewelry store should feel like a room someone actually lives in. Jewelry is intimate. It should be introduced the way a friend introduces you to something she loves, in a room full of things she loves.\n|If you visit and something catches you, ask us where it came from. We remember all of them.',
         shop:{k:'Visit',n:'West Village',p:'18 Christopher Street'} },

      { id:'west-village-morning', cat:'City Edit',
         title:'West Village, slow morning', sub:'The city',
         stand:'A corner cafe, a quiet street, and the long way back to the shop.',
         meta:'City Edit · West Village',
         body:'first|Start on Christopher Street before the city is fully awake. There is a cafe on the corner that does the coffee properly and lets you sit.\n|From there, the long way. Past the bookshop, the florist, the gallery that changes its window every week.\npull:End the walk at our door.\nfull:The street at nine\n|The city rewards the slow walk. We made this one so you would have an excuse to take it.',
         shop:{k:'Visit',n:'West Village',p:'18 Christopher Street'} },

      { id:'gallery-bleecker', cat:'City Edit',
         title:'The gallery we keep returning to', sub:'NoHo',
         stand:'A small room on Bleecker that always seems to know what we will love next.',
         meta:'City Edit · NoHo',
         body:'first|There is a gallery near the new shop that we cannot stay away from. Small, particular, and always a season ahead of how we are thinking.\n|We go to look, mostly. Sometimes that is the whole point of a place.\npull|Taste is built by looking.\n|If you are near Bleecker, go in. Tell them the edit sent you.',
         shop:{k:'Visit',n:'Bleecker · NoHo',p:'19 Bleecker Street'} },

      { id:'seoul-paris', cat:'The Maker',
         title:'Seoul meets Paris', sub:'Designer pairing',
         stand:'Two makers, two cities, one line that looks like it was always meant to be worn together.',
         meta:'The Maker · Pairing',
         body:'first|One designer works in Seoul, the other in Paris. They have never met. Worn together, you would never know.\n|That is the quiet pleasure of an edit. We get to make introductions the makers never could.\npull|Curation is a kind of conversation.\n|Two pieces, two cities, one neckline. The pairing of the week.',
         shop:{k:'Wear it',n:'Seoul × Paris',p:'Two makers, one line'} },

      { id:'year-of-gold', cat:'The Vault',
         title:'The year of gold', sub:'Letter no. 12',
         stand:'On warmth, and why we keep returning to it. A short letter from the edit.',
         meta:'The Vault · Letter 12',
         body:'first|If there is a thread through this year, it is gold. Warm, soft, lived-in gold. The kind that looks better with wear, not worse.\n|We did not plan it. The pieces we kept choosing simply led us here.\npull|Some years choose their own colour.\n|This is a short note on warmth, and a few of the pieces that carried it. The longer version is in your inbox, if you let it be.',
         shop:{k:'In this letter',n:'Gold, this season',p:'A small edit'} }
    ];

    /* ---------- BOARD RENDER ---------- */
    var board = $('lfeBoard');
    function cardHTML(e){
      var im = e.card || e.hero;
      return '<a class="card" data-id="'+e.id+'" data-cat="'+e.cat+'">'
        + '<div class="cimg">'+(im?'<img src="'+im+'" alt="'+e.title+'" loading="lazy">':'<span class="ph">'+e.cat+'</span>')+'</div>'
        + '<div class="meta"><div class="kc"><span>'+e.cat+'</span><span class="sub">'+(e.sub||'')+'</span></div>'
        + '<div class="ttl">'+e.title+'</div></div></a>';
    }
    /* feature entry is shown at top, board shows the rest */
    board.innerHTML = ENTRIES.slice(1).map(cardHTML).join('');

    /* feature lead image from first entry, if provided */
    (function(){
      var f = ENTRIES[0], box = root.querySelector('#lfeFeature .fimg');
      if(f && box && (f.card||f.hero)) box.innerHTML = '<img src="'+(f.card||f.hero)+'" alt="'+f.title+'">';
    })();

    /* ---------- FILTER (filter bar + sommaire) ---------- */
    function applyFilter(cat){
      root.querySelectorAll('#lfeFilterbar .filt').forEach(function(f){ f.classList.toggle('on', f.dataset.cat===cat); });
      root.querySelectorAll('#lfeSommaire .som').forEach(function(s){ s.classList.toggle('on', s.dataset.cat===cat); });
      root.querySelectorAll('.card').forEach(function(c){
        var show = (cat==='all') || (c.dataset.cat===cat);
        c.classList.toggle('hide', !show);
      });
    }
    function scrollToFilter(){
      var bar = root.querySelector('.filterbar');
      var y = bar.getBoundingClientRect().top + window.pageYOffset - 90;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
    $('lfeFilterbar').addEventListener('click', function(ev){
      var b = ev.target.closest('.filt'); if(!b) return;
      applyFilter(b.dataset.cat);
      scrollToFilter();
    });
    $('lfeSommaire').addEventListener('click', function(ev){
      var s = ev.target.closest('.som'); if(!s) return;
      applyFilter(s.dataset.cat);
      scrollToFilter();
    });

    /* ---------- ARTICLE ROUTING ---------- */
    function cell(cls, item){
      var at = (item||'').split('@');
      var cap = (at[0]||'Image').trim(), url = (at[1]||'').trim();
      return '<div class="'+cls+'">'+(url?'<img src="'+url+'" alt="'+cap+'" loading="lazy">':'<div class="ph">'+cap+'</div>')+'</div>';
    }
    function renderBody(raw){
      return raw.split('\n').map(function(seg){
        if(seg.indexOf('pull:')===0) return '<p class="pull">'+seg.slice(5)+'</p>';
        if(seg.indexOf('pull')===0) return '<p class="pull">'+seg.replace(/^pull\|?/,'')+'</p>';
        if(seg.indexOf('full:')===0){ var at=seg.slice(5).split('@'); var cap=(at[0]||'Image').trim(), url=(at[1]||'').trim();
          return '<div class="art-full">'+(url?'<img src="'+url+'" alt="'+cap+'" loading="lazy">':'<div class="ph">'+cap+'</div>')+'</div>'; }
        if(seg.indexOf('duo:')===0){ var t=seg.slice(4).split(',');
          return '<div class="art-duo">'+cell('di',t[0])+cell('di',t[1])+'</div>'; }
        if(seg.indexOf('trio:')===0){ var t3=seg.slice(5).split(',');
          return '<div class="art-trio">'+cell('ti',t3[0])+cell('ti',t3[1])+cell('ti',t3[2])+'</div>'; }
        if(seg.indexOf('cap:')===0) return '<p class="art-cap">'+seg.slice(4)+'</p>';
        if(seg.indexOf('first|')===0) return '<p class="first">'+seg.slice(6)+'</p>';
        if(seg.trim()==='') return '';
        return '<p>'+seg.replace(/^\|/,'')+'</p>';
      }).join('');
    }
    function openArticle(id){
      var e = null;
      for(var i=0;i<ENTRIES.length;i++){ if(ENTRIES[i].id===id){ e=ENTRIES[i]; break; } }
      if(!e) return;
      $('lfeArtTag').textContent = e.cat;
      $('lfeArtTitle').textContent = e.title;
      $('lfeArtStand').textContent = e.stand;
      $('lfeArtMeta').textContent = e.meta;
      $('lfeArtHero').innerHTML = e.hero
        ? '<img src="'+e.hero+'" alt="'+e.title+'">'
        : '<div class="ph">Lead photograph</div>';
      var bodyHTML = renderBody(e.body);
      if(e.shop){
        bodyHTML += '<div class="art-shop"><div class="si"></div>'
          + '<div><div class="sk">'+e.shop.k+'</div><div class="sn">'+e.shop.n+'</div><div class="sp">'+e.shop.p+'</div></div>'
          + '<button class="sbtn" type="button">Shop the piece</button></div>';
      }
      $('lfeArtBody').innerHTML = bodyHTML;
      var rel = ENTRIES.filter(function(x){ return x.id!==id; })
        .sort(function(a,b){ return (b.cat===e.cat) - (a.cat===e.cat); }).slice(0,3);
      $('lfeRelGrid').innerHTML = rel.map(function(r){
        return '<a class="rel-card" data-id="'+r.id+'"><div class="ri"><div class="ph">'+r.cat+'</div></div>'
          + '<div class="rt-tag">'+r.cat+'</div><div class="rt">'+r.title+'</div></a>';
      }).join('');
      root.classList.add('reading');
      window.scrollTo({ top: 0, behavior: 'auto' });
    }
    function closeArticle(){ root.classList.remove('reading'); }
    root.addEventListener('click', function(ev){
      var card = ev.target.closest('.card,[data-id].rel-card,#lfeFeature');
      if(card && card.dataset.id){ ev.preventDefault(); openArticle(card.dataset.id); return; }
    });
    $('lfeArtBack').addEventListener('click', closeArticle);
  })();
