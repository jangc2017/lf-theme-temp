{% javascript %}
  (function(){
    var root = document.querySelector('.lf-bespoke');
    if (!root) return;
    /* sticky-progress rescue: any ancestor that clips overflow kills position:sticky */
    var an = root.parentElement;
    while (an && an !== document.body){
      var ov = getComputedStyle(an).overflow;
      if (ov && ov !== 'visible') an.style.overflow = 'visible';
      an = an.parentElement;
    }

(function(){
  // view tabs
  var tabBtns=root.querySelectorAll('.ptabs button');
  function showView(id){
    root.querySelectorAll('.view').forEach(function(v){v.classList.toggle('active',v.id===id);});
    tabBtns.forEach(function(b){b.classList.toggle('active',b.dataset.view===id);});
    window.scrollTo({top:0,behavior:'instant'});
  }
  tabBtns.forEach(function(b){ b.addEventListener('click',function(){ showView(b.dataset.view); }); });
  root.querySelectorAll('[data-go]').forEach(function(b){ b.addEventListener('click',function(){ showView(b.dataset.go); }); });

  // ---------- optional deep link ----------
  var Q=new URLSearchParams(location.search);
  if(Q.get('view')==='profile'){ showView('lfb-viewProfile'); }

  // ================= CALENDAR + TIME (inline booking) =================
  var MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
  var DOWLONG=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  var bkState={ mode:'atelier', date:null, time:null };
  var bkToday=new Date(); bkToday.setHours(0,0,0,0);
  var bkVY=bkToday.getFullYear(), bkVM=bkToday.getMonth();
  var HOURS_ATELIER=['11:00','12:30','2:00','3:30','5:00','6:30'];
  var HOURS_VIRTUAL=['10:00','11:30','1:00','2:30','4:00','5:30'];

  function bkSeeded(n){ var x=Math.sin(n)*10000; return x-Math.floor(x); }
  function bkFullyBooked(d){ return bkSeeded(d.getFullYear()*372+(d.getMonth()+1)*31+d.getDate())>0.86; }
  function bkClosed(d){ return d.getDay()===0; }
  function bkPast(d){ return d<bkToday; }
  function bkSameDay(a,b){ return a&&b&&a.getFullYear()===b.getFullYear()&&a.getMonth()===b.getMonth()&&a.getDate()===b.getDate(); }
  function bkTaken(d){
    var base=(bkState.mode==='atelier')?HOURS_ATELIER:HOURS_VIRTUAL, gone={};
    base.forEach(function(t,i){ if(bkSeeded(d.getDate()*53+i*17+d.getMonth()*7)>0.62) gone[t]=true; });
    return gone;
  }
  function fmtTime(t){ var h=parseInt(t.split(':')[0],10); return t+' '+(h<=11?'AM':'PM'); }

  var bkGrid=document.getElementById('lfb-bkCalGrid');
  var bkCalMonth=document.getElementById('lfb-bkCalMonth');
  var bkCalYear=document.getElementById('lfb-bkCalYear');
  var bkPrev=document.getElementById('lfb-bkPrevM');
  var bkNext=document.getElementById('lfb-bkNextM');

  function bkRenderCal(){
    bkCalMonth.firstChild.nodeValue=MONTHS[bkVM]+' ';
    bkCalYear.textContent=bkVY;
    bkGrid.innerHTML='';
    var startDow=new Date(bkVY,bkVM,1).getDay();
    var dim=new Date(bkVY,bkVM+1,0).getDate();
    for(var i=0;i<startDow;i++){ var e=document.createElement('div'); e.className='bk-day empty'; bkGrid.appendChild(e); }
    for(var dd=1;dd<=dim;dd++){
      var cur=new Date(bkVY,bkVM,dd); cur.setHours(0,0,0,0);
      var btn=document.createElement('button'); btn.type='button'; btn.className='bk-day'; btn.textContent=dd;
      var off=bkPast(cur)||bkClosed(cur)||bkFullyBooked(cur);
      if(bkSameDay(cur,bkToday)) btn.classList.add('today');
      if(off){ btn.classList.add('off'); btn.disabled=true; }
      if(bkSameDay(cur,bkState.date)) btn.classList.add('sel');
      (function(cur,off){ btn.addEventListener('click',function(){ if(off) return; bkSelectDate(cur); }); })(cur,off);
      bkGrid.appendChild(btn);
    }
    bkPrev.disabled=(bkVY===bkToday.getFullYear()&&bkVM===bkToday.getMonth());
  }
  bkPrev.addEventListener('click',function(){ if(bkPrev.disabled) return; bkVM--; if(bkVM<0){bkVM=11;bkVY--;} bkRenderCal(); });
  bkNext.addEventListener('click',function(){ bkVM++; if(bkVM>11){bkVM=0;bkVY++;} bkRenderCal(); });

  var bkTimeEmpty=document.getElementById('lfb-bkTimeEmpty');
  var bkTimeBody=document.getElementById('lfb-bkTimeBody');
  var bkSlotsEl=document.getElementById('lfb-bkSlots');
  var bkTimeHead=document.getElementById('lfb-bkTimeHead');
  var bkTzNote=document.getElementById('lfb-bkTzNote');

  function bkRenderTimes(){
    if(!bkState.date){ bkTimeEmpty.style.display='block'; bkTimeBody.style.display='none'; return; }
    bkTimeEmpty.style.display='none'; bkTimeBody.style.display='block';
    bkTimeHead.textContent=DOWLONG[bkState.date.getDay()]+', '+MONTHS[bkState.date.getMonth()]+' '+bkState.date.getDate();
    bkTzNote.textContent=(bkState.mode==='atelier')?'Times shown in New York (ET) · 19 Bleecker Street':'Times shown in New York (ET) · link sent on confirmation';
    var base=(bkState.mode==='atelier')?HOURS_ATELIER:HOURS_VIRTUAL, gone=bkTaken(bkState.date);
    bkSlotsEl.innerHTML='';
    base.forEach(function(t){
      var b=document.createElement('button'); b.type='button'; b.className='bk-slot'; b.textContent=fmtTime(t);
      if(gone[t]){ b.classList.add('gone'); b.disabled=true; }
      if(bkState.time===t) b.classList.add('sel');
      b.addEventListener('click',function(){ if(gone[t]) return; bkState.time=t; bkRenderTimes(); bkUpdateSummary(); });
      bkSlotsEl.appendChild(b);
    });
  }
  function bkSelectDate(d){ bkState.date=d; bkState.time=null; bkRenderCal(); bkRenderTimes(); bkUpdateSummary(); }

  document.getElementById('lfb-bkModes').addEventListener('click',function(e){
    var b=e.target.closest('.bk-mode'); if(!b) return;
    root.querySelectorAll('.bk-mode').forEach(function(m){ m.classList.remove('on'); });
    b.classList.add('on'); bkState.mode=b.dataset.mode; bkState.time=null;
    bkRenderTimes(); bkUpdateSummary();
  });

  var bkSumLine=document.getElementById('lfb-bkSumLine');
  var bkSumMeta=document.getElementById('lfb-bkSumMeta');
  function bkWhere(){ return (bkState.mode==='atelier')?'The Bleecker Atelier · 19 Bleecker Street, NoHo':'Virtual Atelier · private video call'; }
  function bkUpdateSummary(){
    bkSumMeta.textContent=bkWhere();
    var held=document.getElementById('lfb-heldReadout');
    held.style.borderLeftColor='';
    if(bkState.date&&bkState.time){
      var d=bkState.date, line=DOWLONG[d.getDay()]+', '+MONTHS[d.getMonth()]+' '+d.getDate()+' · '+fmtTime(bkState.time);
      bkSumLine.innerHTML=line;
      held.classList.remove('empty');
      held.innerHTML='<b>Reserving</b> '+line+' · '+(bkState.mode==='atelier'?'Bleecker atelier':'Virtual');
    } else if(bkState.date){
      bkSumLine.innerHTML=DOWLONG[bkState.date.getDay()]+', '+MONTHS[bkState.date.getMonth()]+' '+bkState.date.getDate()+' <span class="muted">· choose a time</span>';
      held.classList.add('empty'); held.textContent='Choose a time above to reserve your consultation.';
    } else {
      bkSumLine.innerHTML='<span class="muted">Choose a date and time above</span>';
      held.classList.add('empty'); held.textContent='Choose your hour above to reserve your consultation.';
    }
  }

  bkRenderCal(); bkRenderTimes(); bkUpdateSummary();


  // chips
  root.querySelectorAll('.chips').forEach(function(group){
    var single=group.hasAttribute('data-single');
    group.addEventListener('click',function(e){
      var b=e.target.closest('.chip'); if(!b||!group.contains(b)) return;
      if(single){ var was=b.classList.contains('on'); group.querySelectorAll('.chip').forEach(function(c){c.classList.remove('on');}); if(!was)b.classList.add('on'); }
      else { b.classList.toggle('on'); }
    });
  });

  // progress scroll-spy (all sections visible)
  var nodes=Array.prototype.slice.call(root.querySelectorAll('#lfb-progress .pnode'));
  var bars=Array.prototype.slice.call(root.querySelectorAll('#lfb-progress .pbar'));
  var sections=nodes.map(function(n){ return document.getElementById(n.dataset.goStep); });
  function setActive(idx){
    nodes.forEach(function(n,i){
      n.classList.toggle('current',i===idx);
      n.classList.toggle('done',i<idx);
    });
    bars.forEach(function(bar,i){ bar.classList.toggle('filled', i<idx); });
  }
  // click node -> scroll to section
  nodes.forEach(function(n){ n.addEventListener('click',function(){
    var el=document.getElementById(n.dataset.goStep);
    if(el) window.scrollTo({top:el.offsetTop-110,behavior:'smooth'});
  }); });
  // observe sections
  var spy=function(){
    var y=window.scrollY+300, idx=0;
    sections.forEach(function(s,i){ if(s && s.offsetTop<=y) idx=i; });
    setActive(idx);
  };
  window.addEventListener('scroll',spy,{passive:true});
  // run spy only when profile view active
  var origShow=showView;

  // file upload — inspiration images
  (function(){
    var drop=document.getElementById('lfb-drop');
    var input=document.getElementById('lfb-fileInput');
    var thumbs=document.getElementById('lfb-thumbs');
    if(!drop||!input||!thumbs) return;
    var files=[];
    var MAX=8;
    function render(){
      thumbs.innerHTML='';
      files.forEach(function(f,i){
        var cell=document.createElement('div'); cell.className='thumb';
        if(f.type && f.type.indexOf('image/')===0){
          var img=document.createElement('img'); img.src=URL.createObjectURL(f); cell.appendChild(img);
        } else {
          var doc=document.createElement('div'); doc.className='doc';
          doc.innerHTML='<svg viewBox="0 0 24 24"><path d="M6 2h9l5 5v15a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/><path d="M14 2v6h6"/></svg><span>'+f.name.slice(0,18)+'</span>';
          cell.appendChild(doc);
        }
        var rm=document.createElement('button'); rm.type='button'; rm.className='rm'; rm.innerHTML='&times;';
        rm.addEventListener('click',function(){ files.splice(i,1); render(); });
        cell.appendChild(rm);
        thumbs.appendChild(cell);
      });
    }
    function add(list){
      for(var i=0;i<list.length && files.length<MAX;i++){ files.push(list[i]); }
      render();
    }
    drop.addEventListener('click',function(){ input.click(); });
    input.addEventListener('change',function(){ add(input.files); input.value=''; });
    ['dragenter','dragover'].forEach(function(ev){ drop.addEventListener(ev,function(e){ e.preventDefault(); drop.classList.add('drag'); }); });
    ['dragleave','drop'].forEach(function(ev){ drop.addEventListener(ev,function(e){ e.preventDefault(); drop.classList.remove('drag'); }); });
    drop.addEventListener('drop',function(e){ if(e.dataTransfer && e.dataTransfer.files) add(e.dataTransfer.files); });
  })();

  // ---------- combined submit: hour + story together ----------
  var scrim=document.getElementById('lfb-scrim');
  document.getElementById('lfb-customForm').addEventListener('submit',function(e){
    e.preventDefault();
    // 1) an hour must be held
    if(!bkState.date || !bkState.time){
      var s0=document.getElementById('lfb-s0');
      if(s0) window.scrollTo({top:s0.offsetTop-110,behavior:'smooth'});
      var held=document.getElementById('lfb-heldReadout');
      held.classList.add('empty');
      held.style.borderLeftColor='var(--accent)';
      held.textContent=bkState.date?'Please choose a time for your consultation.':'Please choose a date and time for your consultation.';
      return;
    }
    // 2) contact details
    var nm=document.getElementById('lfb-fName'), em=document.getElementById('lfb-fEmail');
    if(!nm.value.trim()){ nm.scrollIntoView({behavior:'smooth',block:'center'}); nm.focus(); nm.style.borderColor='var(--accent)'; return; }
    if(!em.value.trim()||em.value.indexOf('@')<1){ em.scrollIntoView({behavior:'smooth',block:'center'}); em.focus(); em.style.borderColor='var(--accent)'; return; }
    // 3) fill the combined confirmation
    var d=bkState.date, first=nm.value.trim().split(/\s+/)[0];
    document.getElementById('lfb-confirmTitle').textContent='Thank you, '+first+'. Your hour is held and your story is with June.';
    document.getElementById('lfb-rNameRow').style.display='flex';
    document.getElementById('lfb-rName').textContent=nm.value.trim();
    document.getElementById('lfb-rWhen').textContent=DOWLONG[d.getDay()]+', '+MONTHS[d.getMonth()]+' '+d.getDate()+', '+d.getFullYear();
    document.getElementById('lfb-rTime').textContent=fmtTime(bkState.time)+' ET';
    document.getElementById('lfb-rWhere').textContent=(bkState.mode==='atelier')?'19 Bleecker Street, NoHo':'Virtual · video call';
    scrim.classList.add('open'); window.scrollTo({top:0});
  });
  document.getElementById('lfb-closeConfirm').addEventListener('click',function(){ scrim.classList.remove('open'); showView('lfb-viewAtelier'); });
  scrim.addEventListener('click',function(e){ if(e.target===scrim) scrim.classList.remove('open'); });
  spy();
})();

  })();
{% endjavascript %}

