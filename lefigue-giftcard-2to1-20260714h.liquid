{%- comment -%}
  LE FIGUE — Gift Card landing page. Ported from the provided design; theme
  header/footer wrap it (design's own nav/footer removed). CSS+ids namespaced
  .lf-giftcard / #lfg-*. Amount picker uses the REAL gift-card product variants
  ($50/$100/$150/$250/$500); selecting one points the CTA at that variant.
  CTA → product /products/le-figue-gift-card ; "Gift Consultation" → /pages/book-appointment.
  NOTE: the gift card product is currently DRAFT — it must be Active + published
  to the Online Store sales channel for the product link to work on the storefront.
  Card visual = the gift-card product's featured image (CDN fallback), so
  updating the product image updates this page too. Amount overlay stays on top.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Cormorant+SC:wght@300;400&display=swap" rel="stylesheet">
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css">

<div class="lf-giftcard">
  <!-- HERO -->
  <section class="gc-hero">
    <p class="hero-eyebrow">LE FIGUE Gift Card</p>
    <h1 class="hero-title">Something They Would Have<br>Chosen Themselves.</h1>
    <p class="hero-subtitle">Let them find the piece that feels like theirs.</p>
    <p class="hero-desc">For birthdays, milestones, thank-yous, and the moments you want to mark with care. LE FIGUE Gift Cards are delivered by email and can be used online or in-store.</p>
    <div class="hero-scroll">
      <span>Select Amount</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- PICKER -->
  <section class="section-picker">
    <div class="picker-inner">
      <div class="card-visual">
        {%- assign lfg_product = all_products['le-figue-gift-card'] -%}
        {%- if lfg_product.featured_image -%}
          <img class="card-image" src="{{ lfg_product.featured_image | image_url: width: 1206 }}" alt="LE FIGUE Gift Card" loading="lazy" width="1206" height="753" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        {%- else -%}
          <img class="card-image" src="https://cdn.shopify.com/s/files/1/0809/2729/3738/files/lefigue-gift-card.jpg?v=1783906554" alt="LE FIGUE Gift Card" loading="lazy" width="1206" height="753" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        {%- endif -%}
        <div class="card-amount-display" id="lfg-amountDisplay">—</div>
      </div>

      <div class="picker-right">
        <span class="picker-label">Choose an Amount</span>
        <div class="amount-grid" id="lfg-amounts">
          <button class="amount-btn" type="button" data-amount="$50" data-variant="51888251896106">$50</button>
          <button class="amount-btn" type="button" data-amount="$100" data-variant="51888251928874">$100</button>
          <button class="amount-btn" type="button" data-amount="$150" data-variant="51888251961642">$150</button>
          <button class="amount-btn" type="button" data-amount="$250" data-variant="51888251994410">$250</button>
          <button class="amount-btn" type="button" data-amount="$500" data-variant="51888252027178">$500</button>
          <button class="amount-btn custom" type="button" disabled>Custom amounts available in-store</button>
        </div>

        <p class="picker-note">Delivered by email with a unique code. Redeemable online or during an in-store visit.<br>No fees. No expiration.</p>

        <a class="btn-primary" id="lfg-cta" href="/products/le-figue-gift-card">Send a Gift Card</a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section-how">
    <span class="section-eyebrow">How It Works</span>
    <h2 class="section-title">Choose an amount,<br>send it with care.</h2>
    <p class="section-prose">Let them discover their own piece, at their own pace. Gift cards are delivered by email with a unique code and can be redeemed online or during an in-store visit to either LE FIGUE location.</p>
    <div class="how-steps">
      <div class="how-step"><div class="step-num">i.</div><p class="step-text">Select an amount and add to cart.</p></div>
      <div class="how-step"><div class="step-num">ii.</div><p class="step-text">A gift card is delivered by email with a unique code.</p></div>
      <div class="how-step"><div class="step-num">iii.</div><p class="step-text">Use it online or in-store at LE FIGUE.</p></div>
      <div class="how-step"><div class="step-num">iv.</div><p class="step-text">Any remaining balance carries forward to a future visit.</p></div>
    </div>
  </section>

  <!-- PERFECT FOR -->
  <section class="section-perfect">
    <div class="perfect-inner">
      <div class="perfect-header">
        <span class="section-eyebrow">Perfect For</span>
        <h2 class="section-title">The person who knows<br>their own taste.</h2>
      </div>
      <div class="perfect-grid">
        <div class="perfect-card"><span class="perfect-occasion">Birthdays</span><p class="perfect-desc">A piece they choose for themselves.</p></div>
        <div class="perfect-card"><span class="perfect-occasion">Thank You Gifts</span><p class="perfect-desc">A small gesture, made lasting.</p></div>
        <div class="perfect-card"><span class="perfect-occasion">Milestones</span><p class="perfect-desc">For the moments worth marking.</p></div>
        <div class="perfect-card"><span class="perfect-occasion">Last-Minute Gifts</span><p class="perfect-desc">Delivered by email, beautifully simple.</p></div>
      </div>
    </div>
  </section>

  <!-- APPOINTMENT BAND -->
  <section class="section-appointment">
    <span class="appt-eyebrow">Not Sure What to Choose?</span>
    <h2 class="appt-title">Gift cards are even better<br>with a little guidance.</h2>
    <p class="appt-desc">Gift cards can be used during an in-store styling appointment. Our team can help them discover pieces that feel personal, wearable, and entirely their own.</p>
    <a href="/pages/book-appointment" class="btn-ghost">Book a Gift Consultation</a>
  </section>

  <!-- PHYSICAL GIFT -->
  <section class="section-physical">
    <div class="physical-inner">
      <span class="physical-icon">✉</span>
      <span class="physical-title">Prefer Something to Hold?</span>
      <p class="physical-desc">In-store purchases may be wrapped with a LE FIGUE gift note and envelope upon request. A quiet detail that makes it feel complete.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-faq">
    <div class="faq-inner">
      <div class="faq-header">
        <span class="section-eyebrow">Frequently Asked</span>
        <h2 class="section-title">Questions</h2>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">Where can I use it?<span class="faq-icon"></span></button>
        <div class="faq-a"><p>Gift cards can be used online or in-store at LE FIGUE — at our Bleecker location or our West Village shop on Christopher Street.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">How is it delivered?<span class="faq-icon"></span></button>
        <div class="faq-a"><p>Gift cards are delivered by email with a unique code, typically within a few minutes of purchase.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">Can I use part of the balance?<span class="faq-icon"></span></button>
        <div class="faq-a"><p>Yes. Any remaining balance can be used toward a future purchase — online or in-store, whenever they are ready.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">Can I choose a custom amount?<span class="faq-icon"></span></button>
        <div class="faq-a"><p>Custom amounts are available in-store. Our team is happy to help you choose an amount that feels right for the occasion.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">Can I return a gift card?<span class="faq-icon"></span></button>
        <div class="faq-a"><p>Gift cards are final sale and cannot be returned, except where required by law.</p></div>
      </div>
    </div>
  </section>

  <!-- POLICY -->
  <section class="section-policy">
    <p class="policy-text">LE FIGUE Gift Cards are redeemable online and in-store. Gift cards are not reloadable, cannot be used to purchase another gift card, and are final sale except where required by law. No fees apply.</p>
  </section>
</div>

{% stylesheet %}
  .lf-giftcard{ --cream:#F8F5F0; --warm-white:#FDFCF9; --ink:#1C1C1A; --ink-soft:#3A3935; --gold:#B8A882; --gold-light:#D6C9A8; --divider:#D8D3C8; --muted:#8A8680;
    --font-display:'Cormorant Garamond',Georgia,serif; --font-sc:'Cormorant SC',Georgia,serif; --font-body:'Pretendard Variable','Pretendard',-apple-system,'Helvetica Neue',Arial,sans-serif;
    background:var(--cream); color:var(--ink); font-family:var(--font-body); font-size:15px; line-height:1.7; -webkit-font-smoothing:antialiased; }
  .lf-giftcard *, .lf-giftcard *::before, .lf-giftcard *::after{ box-sizing:border-box; }
  .lf-giftcard a{ text-decoration:none; color:inherit; }

  .lf-giftcard .gc-hero{ min-height:80vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:80px 24px 80px; background:var(--warm-white); position:relative; overflow:hidden; }
  .lf-giftcard .hero-eyebrow{ font-family:var(--font-sc); font-size:11px; letter-spacing:.28em; color:var(--gold); margin-bottom:36px; opacity:0; animation:lfg-fadeUp .9s .2s ease forwards; }
  .lf-giftcard .hero-title{ font-family:var(--font-display); font-style:italic; font-weight:300; font-size:clamp(52px,8vw,96px); line-height:1.05; letter-spacing:-.01em; color:var(--ink); margin-bottom:28px; opacity:0; animation:lfg-fadeUp 1s .4s ease forwards; }
  .lf-giftcard .hero-subtitle{ font-family:var(--font-display); font-weight:300; font-size:clamp(16px,2.2vw,20px); color:var(--ink-soft); letter-spacing:.01em; margin-bottom:20px; opacity:0; animation:lfg-fadeUp 1s .6s ease forwards; }
  .lf-giftcard .hero-desc{ max-width:480px; font-size:13.5px; color:var(--muted); line-height:1.9; letter-spacing:.02em; margin-bottom:56px; opacity:0; animation:lfg-fadeUp 1s .8s ease forwards; }
  .lf-giftcard .hero-scroll{ position:absolute; bottom:40px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:10px; opacity:0; animation:lfg-fadeUp 1s 1.2s ease forwards; }
  .lf-giftcard .hero-scroll span{ font-family:var(--font-sc); font-size:9px; letter-spacing:.25em; color:var(--muted); }
  .lf-giftcard .scroll-line{ width:1px; height:36px; background:var(--gold); animation:lfg-lineGrow 1.5s 1.8s ease-out forwards; transform-origin:top; transform:scaleY(0); }

  .lf-giftcard .section-picker{ background:var(--cream); padding:100px 48px; }
  .lf-giftcard .picker-inner{ max-width:1100px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
  .lf-giftcard .card-visual{ position:relative; aspect-ratio:2/1; background:var(--ink); border-radius:2px; display:flex; flex-direction:column; justify-content:flex-end; padding:36px 40px; overflow:hidden; }
  .lf-giftcard .card-visual::before{ content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 20% 80%, rgba(184,168,130,.18) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(184,168,130,.10) 0%, transparent 50%); }
  .lf-giftcard .card-monogram{ font-family:var(--font-sc); font-size:11px; letter-spacing:.3em; color:var(--gold); margin-bottom:28px; position:relative; }
  .lf-giftcard .card-name{ font-family:var(--font-display); font-style:italic; font-weight:300; font-size:28px; color:var(--warm-white); line-height:1.1; position:relative; }
  .lf-giftcard .card-amount-display{ position:absolute; top:36px; right:40px; font-family:var(--font-display); font-size:15px; letter-spacing:.1em; color:var(--gold-light); font-weight:300; transition:opacity .3s; }
  .lf-giftcard .card-bottom-line{ position:absolute; bottom:0; left:0; right:0; height:3px; background:linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 50%, transparent 100%); opacity:.6; }
  .lf-giftcard .picker-label{ font-family:var(--font-sc); font-size:10px; letter-spacing:.28em; color:var(--muted); margin-bottom:24px; display:block; }
  .lf-giftcard .amount-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:36px; }
  .lf-giftcard .amount-btn{ background:transparent; border:1px solid var(--divider); color:var(--ink); font-family:var(--font-display); font-size:20px; font-weight:300; letter-spacing:.03em; padding:18px 12px; cursor:pointer; transition:all .25s ease; text-align:center; outline:none; }
  .lf-giftcard .amount-btn:hover{ border-color:var(--gold); color:var(--ink); }
  .lf-giftcard .amount-btn.active{ background:var(--ink); border-color:var(--ink); color:var(--warm-white); }
  .lf-giftcard .amount-btn.custom{ grid-column:span 3; font-size:12px; font-family:var(--font-sc); letter-spacing:.2em; padding:14px; color:var(--muted); border-style:dashed; font-weight:300; cursor:default; }
  .lf-giftcard .picker-note{ font-size:12px; color:var(--muted); letter-spacing:.02em; margin-bottom:28px; line-height:1.7; }
  .lf-giftcard .btn-primary{ display:block; width:100%; background:var(--ink); color:var(--warm-white); font-family:var(--font-sc); font-size:12px; letter-spacing:.22em; padding:18px 32px; border:none; cursor:pointer; text-align:center; transition:background .25s, color .25s; }
  .lf-giftcard .btn-primary:hover{ background:var(--ink-soft); }

  .lf-giftcard .section-how{ background:var(--warm-white); border-top:1px solid var(--divider); border-bottom:1px solid var(--divider); padding:100px 48px; text-align:center; }
  .lf-giftcard .section-eyebrow{ font-family:var(--font-sc); font-size:10px; letter-spacing:.3em; color:var(--gold); margin-bottom:20px; display:block; }
  .lf-giftcard .section-title{ font-family:var(--font-display); font-weight:300; font-size:clamp(28px,3.5vw,40px); line-height:1.25; color:var(--ink); margin-bottom:24px; }
  .lf-giftcard .section-prose{ max-width:560px; margin:0 auto 56px; font-size:14px; color:var(--ink-soft); line-height:1.9; letter-spacing:.015em; }
  .lf-giftcard .how-steps{ max-width:900px; margin:0 auto; display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--divider); border:1px solid var(--divider); }
  .lf-giftcard .how-step{ background:var(--warm-white); padding:40px 28px; text-align:left; }
  .lf-giftcard .step-num{ font-family:var(--font-display); font-style:italic; font-size:36px; color:var(--gold-light); font-weight:300; margin-bottom:16px; line-height:1; }
  .lf-giftcard .step-text{ font-size:13px; color:var(--ink-soft); line-height:1.8; letter-spacing:.01em; }

  .lf-giftcard .section-perfect{ background:var(--cream); padding:100px 48px; }
  .lf-giftcard .perfect-inner{ max-width:1000px; margin:0 auto; }
  .lf-giftcard .perfect-header{ text-align:center; margin-bottom:60px; }
  .lf-giftcard .perfect-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:1px; background:var(--divider); border:1px solid var(--divider); }
  .lf-giftcard .perfect-card{ background:var(--cream); padding:48px 44px; transition:background .3s; }
  .lf-giftcard .perfect-card:hover{ background:var(--warm-white); }
  .lf-giftcard .perfect-occasion{ font-family:var(--font-sc); font-size:11px; letter-spacing:.25em; color:var(--gold); margin-bottom:14px; display:block; }
  .lf-giftcard .perfect-desc{ font-family:var(--font-display); font-weight:300; font-size:20px; color:var(--ink-soft); line-height:1.5; letter-spacing:.01em; }

  .lf-giftcard .section-appointment{ background:var(--ink); padding:100px 48px; text-align:center; }
  .lf-giftcard .appt-eyebrow{ font-family:var(--font-sc); font-size:10px; letter-spacing:.3em; color:var(--gold); margin-bottom:20px; display:block; }
  .lf-giftcard .appt-title{ font-family:var(--font-display); font-style:italic; font-weight:300; font-size:clamp(32px,4vw,52px); color:var(--warm-white); line-height:1.2; margin-bottom:24px; }
  .lf-giftcard .appt-desc{ max-width:500px; margin:0 auto 44px; font-size:13.5px; color:rgba(253,252,249,.6); line-height:1.9; letter-spacing:.02em; }
  .lf-giftcard .btn-ghost{ display:inline-block; border:1px solid rgba(184,168,130,.5); color:var(--gold-light); font-family:var(--font-sc); font-size:11px; letter-spacing:.22em; padding:16px 40px; transition:all .25s; }
  .lf-giftcard .btn-ghost:hover{ border-color:var(--gold-light); color:var(--warm-white); background:rgba(184,168,130,.08); }

  .lf-giftcard .section-physical{ background:var(--warm-white); border-top:1px solid var(--divider); border-bottom:1px solid var(--divider); padding:72px 48px; text-align:center; }
  .lf-giftcard .physical-inner{ max-width:560px; margin:0 auto; }
  .lf-giftcard .physical-icon{ font-size:28px; margin-bottom:20px; display:block; opacity:.5; }
  .lf-giftcard .physical-title{ font-family:var(--font-sc); font-size:12px; letter-spacing:.22em; color:var(--ink); margin-bottom:16px; display:block; }
  .lf-giftcard .physical-desc{ font-size:13.5px; color:var(--muted); line-height:1.85; letter-spacing:.015em; }

  .lf-giftcard .section-faq{ background:var(--cream); padding:100px 48px; }
  .lf-giftcard .faq-inner{ max-width:720px; margin:0 auto; }
  .lf-giftcard .faq-header{ margin-bottom:48px; text-align:center; }
  .lf-giftcard .faq-item{ border-bottom:1px solid var(--divider); }
  .lf-giftcard .faq-q{ width:100%; background:none; border:none; text-align:left; padding:24px 0; font-family:var(--font-display); font-size:17px; font-weight:400; color:var(--ink); cursor:pointer; display:flex; justify-content:space-between; align-items:center; letter-spacing:.01em; outline:none; gap:16px; }
  .lf-giftcard .faq-q:hover{ color:var(--ink-soft); }
  .lf-giftcard .faq-icon{ flex-shrink:0; width:18px; height:18px; position:relative; opacity:.4; transition:opacity .2s, transform .3s; }
  .lf-giftcard .faq-icon::before, .lf-giftcard .faq-icon::after{ content:''; position:absolute; background:var(--ink); border-radius:1px; }
  .lf-giftcard .faq-icon::before{ width:12px; height:1px; top:50%; left:50%; transform:translate(-50%,-50%); }
  .lf-giftcard .faq-icon::after{ width:1px; height:12px; top:50%; left:50%; transform:translate(-50%,-50%); transition:transform .3s, opacity .3s; }
  .lf-giftcard .faq-item.open .faq-icon::after{ transform:translate(-50%,-50%) rotate(90deg); opacity:0; }
  .lf-giftcard .faq-item.open .faq-icon{ opacity:.7; }
  .lf-giftcard .faq-a{ max-height:0; overflow:hidden; transition:max-height .35s ease, padding .35s ease; }
  .lf-giftcard .faq-item.open .faq-a{ max-height:200px; padding-bottom:24px; }
  .lf-giftcard .faq-a p{ font-size:13.5px; color:var(--muted); line-height:1.85; letter-spacing:.015em; }

  .lf-giftcard .section-policy{ background:var(--warm-white); border-top:1px solid var(--divider); padding:48px; text-align:center; }
  .lf-giftcard .policy-text{ font-family:var(--font-sc); font-size:10px; letter-spacing:.18em; color:var(--muted); max-width:600px; margin:0 auto; line-height:2; }

  @keyframes lfg-fadeUp{ from{opacity:0; transform:translateY(16px);} to{opacity:1; transform:translateY(0);} }
  @keyframes lfg-lineGrow{ to{transform:scaleY(1);} }

  @media (max-width:768px){
    .lf-giftcard .section-picker{ padding:72px 24px; }
    .lf-giftcard .picker-inner{ grid-template-columns:1fr; gap:48px; }
    .lf-giftcard .amount-grid{ grid-template-columns:repeat(2,1fr); }
    .lf-giftcard .amount-btn.custom{ grid-column:span 2; }
    .lf-giftcard .how-steps{ grid-template-columns:1fr 1fr; }
    .lf-giftcard .section-how, .lf-giftcard .section-perfect, .lf-giftcard .section-appointment, .lf-giftcard .section-faq{ padding:72px 24px; }
    .lf-giftcard .section-policy{ padding:40px 24px; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var root = document.querySelector('.lf-giftcard');
    if (!root) return;

    var PRODUCT_URL = '/products/le-figue-gift-card';
    var amounts = root.querySelector('#lfg-amounts');
    var display = root.querySelector('#lfg-amountDisplay');
    var cta = root.querySelector('#lfg-cta');

    if (amounts) {
      amounts.addEventListener('click', function (e) {
        var b = e.target.closest('.amount-btn'); if (!b || b.classList.contains('custom') || !amounts.contains(b)) return;
        amounts.querySelectorAll('.amount-btn').forEach(function (x) { x.classList.remove('active'); });
        b.classList.add('active');
        if (display) display.textContent = b.dataset.amount || '—';
        if (cta && b.dataset.variant) cta.setAttribute('href', PRODUCT_URL + '?variant=' + b.dataset.variant);
      });
    }

    root.querySelectorAll('.faq-q').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('.faq-item');
        var isOpen = item.classList.contains('open');
        root.querySelectorAll('.faq-item').forEach(function (i) { i.classList.remove('open'); });
        if (!isOpen) item.classList.add('open');
      });
    });

    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { en.target.style.opacity = '1'; en.target.style.transform = 'translateY(0)'; }
      });
    }, { threshold: 0.15 });
    root.querySelectorAll('.how-step, .perfect-card').forEach(function (el) {
      el.style.opacity = '0'; el.style.transform = 'translateY(20px)'; el.style.transition = 'opacity .6s ease, transform .6s ease';
      obs.observe(el);
    });
  })();
{% endjavascript %}

