{%- comment -%}
  LE FIGUE — Partnerships page (for makers/ateliers to introduce their work).
  Ported from the provided design. Submits via Shopify's native contact form
  (Option A) → emails the store's registered contact email, then a confirmation
  modal shows. CSS + ids namespaced .lf-partners / #lfp-* to avoid theme clashes.
  NOTE: native contact form can't email file attachments, so the design's
  drag-drop catalogue uploader is replaced with a "paste a link" field.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css">

<div class="lf-partners">
  <section class="pt-hero">
    <div class="eyebrow">Partnerships · For makers &amp; ateliers</div>
    <h1 class="display">Introduce your work.</h1>
    <p>We're always looking for the next name to keep company with — independent makers, wherever they are, whose pieces are made by hand and built to be lived in. If that sounds like you, tell us a little below. We read every introduction ourselves.</p>
  </section>

  <div class="pt-wrap">
    <aside class="pt-rail">
      <div class="rail-block">
        <h3>What we look for</h3>
        <p style="margin-bottom:10px;">We look for jewelry with a clear point of view — pieces that feel considered, personal, and quietly distinctive.</p>
        <p style="margin-bottom:10px;">We are drawn to work that is made by hand or finished with exceptional care, with materials, proportions, and details we would be proud to place our name beside.</p>
        <p>Many of the designers we carry are local to places we love, visit, or feel connected to. Above all, we look for pieces that bring something meaningful to the LE FIGUE edit.</p>
      </div>
      <div class="rail-block">
        <h3>How it works</h3>
        <p style="margin-bottom:10px;">Every submission is reviewed thoughtfully by our team.</p>
        <p style="margin-bottom:10px;">When we feel there may be a fit, we will reach out to request a line sheet, wholesale terms, and one or two samples for review.</p>
        <p>Our curation changes seasonally, and timing can vary depending on the current direction of the edit. A "no for now" is not always a "no forever" — we keep thoughtful submissions in mind as our collections evolve.</p>
      </div>
      <div class="rail-block">
        <h3>Prefer to email?</h3>
        <p style="margin-bottom:10px;">Write to our buying team directly.</p>
        <a class="rail-mail" href="mailto:partnerships@lefigue.com">partnerships@lefigue.com</a>
      </div>
    </aside>

    {%- form 'contact', id: 'lfp-form', class: 'pt-form' -%}
      {%- if form.errors -%}
        <div class="lfp-error">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <div class="fsec">
        <div class="fsec-h"><span class="n">01</span>The atelier</div>
        <div class="field"><label>Brand name <span class="req">*</span></label><input type="text" name="contact[Brand]" required placeholder="The name your work goes by"></div>
        <div class="two">
          <div class="field"><label>Based in <span class="opt">· country / city</span></label><input type="text" name="contact[Based in]" placeholder="e.g. Seoul, South Korea"></div>
          <div class="field"><label>Founded <span class="opt">· optional</span></label><input type="text" name="contact[Founded]" placeholder="Year"></div>
        </div>
        <div class="two">
          <div class="field"><label>Website <span class="opt">· optional</span></label><input type="text" name="contact[Website]" placeholder="https://"></div>
          <div class="field"><label>Instagram <span class="opt">· optional</span></label><input type="text" name="contact[Instagram]" placeholder="@yourbrand"></div>
        </div>
      </div>

      <div class="fsec">
        <div class="fsec-h"><span class="n">02</span>The work</div>
        <div class="field">
          <span class="qlabel">Main materials <span class="opt">· choose any</span></span>
          <div class="chips" data-group="materials" data-mode="multi">
            <button type="button" class="chip">Recycled silver</button>
            <button type="button" class="chip">Sterling silver</button>
            <button type="button" class="chip">Gold vermeil</button>
            <button type="button" class="chip">Gold-filled</button>
            <button type="button" class="chip">Solid gold</button>
            <button type="button" class="chip">Brass</button>
            <button type="button" class="chip">Pearls</button>
            <button type="button" class="chip">Natural stones</button>
            <button type="button" class="chip">Enamel</button>
            <button type="button" class="chip">Ceramic</button>
            <button type="button" class="chip">Beadwork</button>
            <button type="button" class="chip">Other</button>
          </div>
        </div>
        <div class="field">
          <span class="qlabel">Typical retail range <span class="opt">· optional</span></span>
          <div class="chips" data-group="range" data-mode="single">
            <button type="button" class="chip">Under $100</button>
            <button type="button" class="chip">$100–300</button>
            <button type="button" class="chip">$300–1,000</button>
            <button type="button" class="chip">$1,000+</button>
            <button type="button" class="chip">Mixed</button>
          </div>
        </div>
        <div class="field"><label>Catalogue / line sheet link <span class="opt">· Drive, Dropbox, or website</span></label><input type="text" name="contact[Catalogue link]" placeholder="https://"></div>
        <div class="field"><label>A short introduction <span class="req">*</span></label><textarea name="contact[body]" rows="4" required placeholder="Tell us about the atelier and the maker — what the work is, how it's made, and what makes it yours."></textarea></div>
      </div>

      <div class="fsec">
        <div class="fsec-h"><span class="n">03</span>The maker</div>
        <div class="two">
          <div class="field"><label>Your name <span class="req">*</span></label><input type="text" name="contact[Name]" required placeholder="First and last name"></div>
          <div class="field"><label>Role <span class="opt">· optional</span></label><input type="text" name="contact[Role]" placeholder="e.g. Founder"></div>
        </div>
        <div class="field"><label>Email <span class="req">*</span></label><input type="email" name="contact[email]" required placeholder="you@email.com"></div>
        <label class="consent"><input type="checkbox" data-lfp-consent><span>You may keep my details on file for future seasons, even if there isn't a fit right now.</span></label>
      </div>

      <input type="hidden" name="contact[Main materials]" data-lfp-h="materials">
      <input type="hidden" name="contact[Retail range]" data-lfp-h="range">
      <input type="hidden" name="contact[Keep on file]" value="No" data-lfp-h="consent">

      <div class="submitrow">
        <button type="submit" class="submit">Send introduction</button>
        <div class="submitnote">Your submission goes only to our buying team. We reply to every maker.</div>
      </div>

      <!-- CONFIRMATION (inside the form so form.posted_successfully? is in scope) -->
      <div class="scrim{% if form.posted_successfully? %} open{% endif %}" id="lfp-scrim"><div class="confirm">
        <div class="seal">✓</div>
        <h3 class="display">Thank you — this is with our buying team.</h3>
        <p class="sub">We've received your introduction.</p>
        <div class="expect"><b>What happens next.</b> We read every submission ourselves. When there's a fit, we'll be in touch for a line sheet, wholesale terms, and a sample or two. Because the curation rotates by season, timing varies — but we keep makers we love on file, and reach out when the moment is right.</div>
        <button type="button" class="cbtn" id="lfp-closeConfirm">Done</button>
      </div></div>
    {%- endform -%}
  </div>
</div>

{% stylesheet %}
  .lf-partners{ --ink:#2a2622; --ink-soft:#6b635a; --line:#e3dccf; --line-soft:#efe9dd; --cream:#faf7f1; --cream-deep:#f3ede1; --accent:#8a7250; --gold:#b8975f; --paper:#fdfbf6;
    background:var(--cream); color:var(--ink); font-family:'Pretendard Variable','Pretendard',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-weight:400; line-height:1.7; -webkit-font-smoothing:antialiased; }
  .lf-partners *{ box-sizing:border-box; }
  .lf-partners a{ color:inherit; text-decoration:none; }
  .lf-partners .display{ font-family:'Cormorant Garamond',serif; }

  .lf-partners .pt-hero{ max-width:1280px; margin:0 auto; padding:64px 30px 30px; }
  .lf-partners .pt-hero .eyebrow{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--accent); font-size:17px; }
  .lf-partners .pt-hero h1{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(42px,7vw,84px); line-height:1.0; letter-spacing:-.01em; margin:10px 0 16px; }
  .lf-partners .pt-hero p{ font-size:15.5px; color:var(--ink-soft); max-width:580px; }

  .lf-partners .pt-wrap{ max-width:1280px; margin:0 auto; padding:26px 30px 72px; display:grid; grid-template-columns:360px 1fr; gap:64px; align-items:start; }
  .lf-partners .pt-rail{ position:sticky; top:108px; }
  .lf-partners .rail-block{ padding:22px 0; border-top:1px solid var(--line); }
  .lf-partners .rail-block:first-child{ border-top:none; padding-top:0; }
  .lf-partners .rail-block h3{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:18px; color:var(--gold); margin-bottom:12px; }
  .lf-partners .rail-block p{ font-size:13.5px; color:var(--ink-soft); }
  .lf-partners .rail-mail{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:16px; color:var(--ink); border-bottom:1px solid var(--accent); padding-bottom:2px; }

  .lf-partners .pt-form{ background:var(--paper); border:1px solid var(--line); padding:40px 42px 36px; box-shadow:0 30px 60px -42px rgba(42,38,34,.4); }
  .lf-partners .fsec{ border-top:1px solid var(--line-soft); padding-top:24px; margin-top:26px; }
  .lf-partners .fsec:first-child{ border-top:none; margin-top:0; padding-top:0; }
  .lf-partners .fsec-h{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:22px; margin-bottom:18px; }
  .lf-partners .fsec-h .n{ font-style:italic; color:var(--gold); font-size:15px; margin-right:8px; }
  .lf-partners .field{ margin-bottom:18px; }
  .lf-partners .field>label,.lf-partners .qlabel{ display:block; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:8px; }
  .lf-partners .req{ color:var(--accent); }
  .lf-partners .opt{ text-transform:none; letter-spacing:0; color:#bcae93; font-style:italic; }
  .lf-partners .field input,.lf-partners .field textarea{ width:100%; border:1px solid var(--line); background:var(--cream); padding:12px 14px; font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:14px; color:var(--ink); outline:none; transition:border-color .18s; }
  .lf-partners .field input:focus,.lf-partners .field textarea:focus{ border-color:var(--accent); }
  .lf-partners .field input::placeholder,.lf-partners .field textarea::placeholder{ color:#bcb09a; }
  .lf-partners .two{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .lf-partners .chips{ display:flex; gap:8px; flex-wrap:wrap; }
  .lf-partners .chip{ font-family:'Cormorant Garamond',serif; font-size:14px; padding:8px 15px; border:1px solid var(--line); background:var(--cream); color:var(--ink-soft); cursor:pointer; border-radius:30px; transition:.16s; }
  .lf-partners .chip:hover{ border-color:var(--accent); color:var(--ink); }
  .lf-partners .chip.on{ background:var(--accent); color:#f7f1e6; border-color:var(--accent); }

  .lf-partners .consent{ display:flex; gap:10px; align-items:flex-start; margin-top:8px; font-size:12.5px; color:var(--ink-soft); }
  .lf-partners .consent input{ appearance:none; -webkit-appearance:none; margin:2px 0 0; flex-shrink:0; width:20px; height:20px; border-radius:50%; border:1px solid var(--line); background:var(--paper); cursor:pointer; position:relative; transition:.18s; }
  .lf-partners .consent input:checked{ background:var(--accent); border-color:var(--accent); }
  .lf-partners .consent input:checked::after{ content:""; position:absolute; left:50%; top:50%; width:5px; height:9px; border:2px solid #fff; border-top:none; border-left:none; transform:translate(-50%,-60%) rotate(45deg); }

  .lf-partners .submitrow{ margin-top:30px; display:flex; align-items:center; gap:20px; flex-wrap:wrap; }
  .lf-partners .submit{ background:var(--ink); color:#f4eee2; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:17px; padding:15px 38px; border:none; cursor:pointer; transition:.2s; }
  .lf-partners .submit:hover{ background:var(--accent); }
  .lf-partners .submitnote{ font-size:12px; color:var(--ink-soft); max-width:320px; line-height:1.5; }
  .lf-partners .lfp-error{ border:1px solid #c0392b; color:#c0392b; background:#fbeeec; padding:12px 14px; margin-bottom:18px; font-size:13px; }

  .lf-partners .scrim{ position:fixed; inset:0; background:rgba(33,29,25,.5); z-index:90; display:none; align-items:flex-start; justify-content:center; padding:48px 20px; overflow-y:auto; }
  .lf-partners .scrim.open{ display:flex; }
  .lf-partners .confirm{ background:var(--paper); max-width:520px; width:100%; border:1px solid var(--line); box-shadow:0 40px 80px -30px rgba(0,0,0,.5); padding:40px 38px 32px; }
  .lf-partners .confirm .seal{ width:48px; height:48px; border:1px solid var(--accent); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--accent); font-size:22px; margin-bottom:20px; }
  .lf-partners .confirm h3{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:28px; margin-bottom:8px; }
  .lf-partners .confirm .sub{ font-size:14px; color:var(--ink-soft); margin-bottom:22px; }
  .lf-partners .confirm .expect{ font-size:13px; color:var(--ink-soft); line-height:1.7; border:1px solid var(--line); background:var(--cream); padding:16px 18px; margin-bottom:22px; }
  .lf-partners .confirm .expect b{ color:var(--ink); font-weight:500; }
  .lf-partners .cbtn{ width:100%; text-align:center; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; padding:13px; border:1px solid var(--accent); color:#f7f1e6; background:var(--accent); cursor:pointer; transition:.18s; }
  .lf-partners .cbtn:hover{ background:var(--ink); border-color:var(--ink); }

  @media(max-width:980px){
    .lf-partners .pt-wrap{ grid-template-columns:1fr; gap:30px; }
    .lf-partners .pt-rail{ position:static; order:2; }
    .lf-partners .pt-form{ order:1; padding:30px 24px 28px; }
  }
  @media(max-width:560px){ .lf-partners .two{ grid-template-columns:1fr; } }
{% endstylesheet %}

{% javascript %}
  (function () {
    var root = document.querySelector('.lf-partners');
    if (!root) return;

    // chip groups -> hidden inputs
    root.querySelectorAll('.chips[data-mode]').forEach(function (group) {
      var mode = group.dataset.mode;
      var hidden = root.querySelector('[data-lfp-h="' + group.dataset.group + '"]');
      function sync() {
        if (!hidden) return;
        var on = [].map.call(group.querySelectorAll('.chip.on'), function (c) { return c.textContent.trim(); });
        hidden.value = on.join(', ');
      }
      group.addEventListener('click', function (e) {
        var b = e.target.closest('.chip'); if (!b || !group.contains(b)) return;
        if (mode === 'single') {
          var was = b.classList.contains('on');
          group.querySelectorAll('.chip').forEach(function (c) { c.classList.remove('on'); });
          if (!was) b.classList.add('on');
        } else {
          b.classList.toggle('on');
        }
        sync();
      });
    });

    // consent -> hidden value
    var consent = root.querySelector('[data-lfp-consent]');
    var consentH = root.querySelector('[data-lfp-h="consent"]');
    if (consent && consentH) consent.addEventListener('change', function () { consentH.value = this.checked ? 'Yes' : 'No'; });

    // confirmation modal
    var scrim = root.querySelector('#lfp-scrim');
    var closeBtn = root.querySelector('#lfp-closeConfirm');
    function close() { if (scrim) scrim.classList.remove('open'); }
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (scrim) scrim.addEventListener('click', function (e) { if (e.target === scrim) close(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "LE FIGUE Partnerships",
  "settings": [],
  "presets": [{ "name": "LE FIGUE Partnerships" }]
}
{% endschema %}
