{%- comment -%}
  LE FIGUE — Designers (Discover → "All Designers A-Z").
  Ported from the provided design; theme header/footer wrap it (the design's own
  announce bar / header / footer were removed). CSS + behavior namespaced under
  .lf-designers so generic class names don't collide with the theme.
  NOTE: this is a front-end prototype — the designer NAMES are a real list, but
  each designer's DETAIL view (bio, specs, "selected pieces" + prices) is
  deterministically generated placeholder data, not real Shopify products.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css">

<div class="lf-designers">
  <!-- ===================== INDEX VIEW ===================== -->
  <main class="view active" id="indexView">
    <section class="dz-hero">
      <div class="eyebrow">The House of Makers</div>
      <h1 class="display">Design<span class="amp">e</span>rs</h1>
    </section>

    <div class="dz-intro">
      <p><span class="lead">We don't carry brands. We keep makers.</span>Most we found in person: a quiet atelier in Seoul, a market table in Lisbon, a studio above a shop in Paris. We look for work that is genuinely well made and hard to find anywhere else, finished by hand and meant to be lived in. Because we choose this way, the curation never sits still; makers and pieces change with the season. Some names you'll know. Most you won't yet.</p>
    </div>

    <!-- featured -->
    <div class="dz-featured" id="featured"></div>

    <!-- A-Z + search -->
    <div class="az-bar"><div class="az-inner">
      <div class="az-letters" id="azLetters"></div>
      <label class="az-search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
        <input type="text" id="filterInput" placeholder="Find a maker">
      </label>
    </div></div>

    <!-- index list -->
    <div class="dz-index" id="dzIndex"></div>
    <div class="dz-empty" id="dzEmpty">No maker by that name — yet. Tell us who we're missing.</div>

    <div class="dz-foot"><div class="dz-foot-in">
      <p>A local maker, in a city we haven't reached yet?<br>We welcome introductions from independent ateliers, wherever you are. If you'd like to be considered for the LE FIGUE curation, tell us about your work.</p>
      <a href="/pages/partnerships" id="partnerLink">Apply for partnership →</a>
    </div></div>
  </main>

  <!-- ===================== DETAIL VIEW ===================== -->
  <main class="view" id="detailView">
    <div class="det-top">
      <div class="crumb"><a id="crumbHome">Designers</a><span class="sep">/</span><span id="crumbName">—</span></div>
      <div class="det-nav">
        <button id="prevBtn">← <span id="prevName">Previous</span></button>
        <button id="nextBtn"><span id="nextName">Next</span> →</button>
      </div>
    </div>

    <div class="det-wrap">
      <aside class="det-rail">
        <div class="det-eye">In the curation</div>
        <h1 class="det-name" id="dName">—</h1>
        <div class="det-tagline" id="dTagline">—</div>
        <div class="det-bio" id="dBio"></div>
        <span class="readmore" id="readMore">Read more →</span>

        <div class="spec" id="dSpec"></div>

        <div class="values">
          <div class="vlab">Values</div>
          <div class="pills" id="dValues"></div>
        </div>

        <div class="det-portrait"><div class="viz" id="dPortrait"><span class="cap">In the studio</span></div></div>
      </aside>

      <section class="det-main">
        <div class="det-prodhead">
          <h2 class="display" id="dPiecesTitle">Selected pieces</h2>
        </div>
        <div class="det-products" id="dProducts"></div>
      </section>
    </div>

    <div class="det-allnote"><div class="in">
      <p id="dCloser">A small, rotating selection. Pieces arrive in ones and twos, and rarely return the same.</p>
      <span class="bk" id="backToAll">← Back to all designers</span>
    </div></div>
  </main>
</div>

{% stylesheet %}
  .lf-designers{ --ink:#2a2622; --ink-soft:#6b635a; --line:#e3dccf; --line-soft:#efe9dd; --cream:#faf7f1; --cream-deep:#f3ede1; --accent:#8a7250; --gold:#b8975f; --paper:#fdfbf6;
    background:var(--cream); color:var(--ink); font-family:'Pretendard Variable','Pretendard',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-weight:400; line-height:1.7; -webkit-font-smoothing:antialiased; }
  .lf-designers *{ box-sizing:border-box; }
  .lf-designers a{ color:inherit; text-decoration:none; }
  .lf-designers img{ display:block; max-width:100%; }
  .lf-designers .display{ font-family:'Cormorant Garamond',serif; }
  .lf-designers .view{ display:none; }
  .lf-designers .view.active{ display:block; }

  /* INDEX */
  .lf-designers .dz-hero{ max-width:1280px; margin:0 auto; padding:70px 30px 30px; }
  .lf-designers .dz-hero .eyebrow{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--accent); font-size:17px; }
  .lf-designers .dz-hero h1{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(54px,11vw,150px); line-height:.92; letter-spacing:-.015em; margin:10px 0 0; }
  .lf-designers .dz-hero h1 .amp{ font-style:italic; color:var(--gold); }
  .lf-designers .dz-intro{ max-width:1280px; margin:0 auto; padding:0 30px; display:grid; grid-template-columns:1fr 1fr; gap:54px; align-items:start; }
  .lf-designers .dz-intro p{ font-size:15.5px; color:var(--ink-soft); max-width:540px; }
  .lf-designers .dz-intro p .lead{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:20px; color:var(--ink); display:block; margin-bottom:12px; line-height:1.4; }

  .lf-designers .dz-featured{ max-width:1280px; margin:46px auto 0; padding:0 30px; display:grid; grid-template-columns:repeat(4,1fr); gap:20px; }
  .lf-designers .feat{ position:relative; cursor:pointer; }
  .lf-designers .feat .viz{ position:relative; width:100%; min-height:330px; border:1px solid var(--line); display:flex; align-items:flex-end; padding:20px; overflow:hidden; transition:.3s; }
  .lf-designers .feat:hover .viz{ border-color:var(--accent); }
  .lf-designers .feat .viz::before{ content:""; position:absolute; inset:0; background:repeating-linear-gradient(135deg,rgba(255,255,255,.16) 0 1px,transparent 1px 10px); opacity:.5; }
  .lf-designers .feat .viz::after{ content:""; position:absolute; left:0; right:0; bottom:0; height:46%; background:linear-gradient(to top,rgba(40,35,30,.42),transparent); }
  .lf-designers .feat .mono{ position:absolute; top:50%; left:50%; transform:translate(-50%,-58%); font-family:'Cormorant Garamond',serif; font-size:120px; color:rgba(255,255,255,.34); line-height:1; pointer-events:none; }
  .lf-designers .feat .fname{ position:relative; color:#fff; font-size:13px; letter-spacing:.22em; text-transform:uppercase; z-index:2; }
  .lf-designers .feat .feye{ position:relative; z-index:2; color:#f0e7d6; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13px; text-transform:none; letter-spacing:0; display:block; margin-bottom:3px; }

  .lf-designers .az-bar{ position:sticky; top:0; z-index:40; background:rgba(250,247,241,.96); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); border-top:1px solid var(--line); border-bottom:1px solid var(--line); margin-top:56px; }
  .lf-designers .az-inner{ max-width:1280px; margin:0 auto; padding:0 30px; display:flex; align-items:center; gap:20px; height:58px; }
  .lf-designers .az-letters{ display:flex; flex-wrap:wrap; gap:2px; flex:1; }
  .lf-designers .az-letters a{ font-family:'Cormorant Garamond',serif; font-size:15px; color:var(--ink-soft); width:25px; height:25px; display:flex; align-items:center; justify-content:center; border-radius:50%; transition:.16s; }
  .lf-designers .az-letters a:hover{ color:var(--accent); }
  .lf-designers .az-letters a.disabled{ color:#d4c9b4; pointer-events:none; }
  .lf-designers .az-search{ display:flex; align-items:center; gap:8px; border-bottom:1px solid var(--line); min-width:190px; }
  .lf-designers .az-search svg{ width:15px; height:15px; stroke:var(--ink-soft); stroke-width:1.4; fill:none; }
  .lf-designers .az-search input{ border:none; background:none; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:16px; color:var(--ink); padding:8px 0; outline:none; width:100%; }
  .lf-designers .az-search input::placeholder{ color:#c2b69e; }

  .lf-designers .dz-index{ max-width:1280px; margin:0 auto; padding:24px 30px 70px; }
  .lf-designers .dz-group{ padding:26px 0; border-top:1px solid var(--line-soft); display:grid; grid-template-columns:90px 1fr; gap:20px; }
  .lf-designers .dz-group:first-child{ border-top:none; }
  .lf-designers .dz-group .gl{ font-family:'Cormorant Garamond',serif; font-size:40px; color:var(--gold); line-height:1; position:sticky; top:72px; align-self:start; }
  .lf-designers .dz-names{ display:grid; grid-template-columns:repeat(4,1fr); gap:11px 26px; }
  .lf-designers .dz-names a{ font-size:15px; color:var(--ink-soft); transition:.16s; display:inline-block; padding:3px 0; border-bottom:1px solid transparent; width:fit-content; cursor:pointer; }
  .lf-designers .dz-names a:hover{ color:var(--ink); border-bottom-color:var(--accent); }
  .lf-designers .dz-empty{ display:none; text-align:center; color:var(--ink-soft); font-family:'Cormorant Garamond',serif; font-style:italic; font-size:18px; padding:60px 0; }
  .lf-designers .dz-foot{ max-width:1280px; margin:0 auto; padding:0 30px 70px; border-top:1px solid var(--line); }
  .lf-designers .dz-foot-in{ padding-top:36px; display:flex; justify-content:space-between; align-items:center; gap:24px; flex-wrap:wrap; }
  .lf-designers .dz-foot-in p{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:19px; color:var(--ink); max-width:520px; }
  .lf-designers .dz-foot-in a{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; color:var(--accent); border-bottom:1px solid var(--accent); padding-bottom:3px; white-space:nowrap; }

  /* DETAIL */
  .lf-designers .det-top{ max-width:1280px; margin:0 auto; padding:26px 30px 0; display:flex; justify-content:space-between; align-items:center; gap:16px; }
  .lf-designers .crumb{ font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-soft); }
  .lf-designers .crumb a{ cursor:pointer; }
  .lf-designers .crumb a:hover{ color:var(--accent); }
  .lf-designers .crumb .sep{ color:var(--gold); margin:0 8px; }
  .lf-designers .det-nav{ display:flex; gap:18px; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--ink-soft); }
  .lf-designers .det-nav button{ background:none; border:none; cursor:pointer; font:inherit; color:inherit; transition:.16s; }
  .lf-designers .det-nav button:hover{ color:var(--accent); }

  .lf-designers .det-wrap{ max-width:1280px; margin:0 auto; padding:22px 30px 70px; display:grid; grid-template-columns:384px 1fr; gap:56px; align-items:start; }
  .lf-designers .det-rail{ position:sticky; top:24px; }
  .lf-designers .det-eye{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--gold); font-size:15px; }
  .lf-designers .det-name{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(38px,4.4vw,54px); line-height:1.02; margin:4px 0 8px; }
  .lf-designers .det-tagline{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:17px; color:var(--ink-soft); margin-bottom:22px; }
  .lf-designers .det-bio{ font-size:14.5px; color:var(--ink-soft); }
  .lf-designers .det-bio .more{ display:none; }
  .lf-designers .det-bio.open .more{ display:inline; }
  .lf-designers .readmore{ margin-top:8px; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--accent); border-bottom:1px solid var(--accent); padding-bottom:2px; cursor:pointer; display:inline-block; }

  .lf-designers .spec{ margin-top:28px; border-top:1px solid var(--line); }
  .lf-designers .spec .row{ display:flex; justify-content:space-between; gap:16px; padding:11px 0; border-bottom:1px solid var(--line-soft); font-size:12.5px; }
  .lf-designers .spec .k{ letter-spacing:.12em; text-transform:uppercase; color:var(--ink-soft); }
  .lf-designers .spec .v{ text-align:right; color:var(--ink); font-family:'Cormorant Garamond',serif; font-size:15px; font-style:italic; }
  .lf-designers .values{ margin-top:20px; }
  .lf-designers .values .vlab{ font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:10px; }
  .lf-designers .pills{ display:flex; flex-wrap:wrap; gap:8px; }
  .lf-designers .pill{ font-family:'Cormorant Garamond',serif; font-size:13.5px; color:var(--ink-soft); border:1px solid var(--line); border-radius:30px; padding:6px 15px; }
  .lf-designers .det-portrait{ margin-top:26px; }
  .lf-designers .det-portrait .viz{ position:relative; width:100%; min-height:300px; border:1px solid var(--line); overflow:hidden; display:flex; align-items:flex-end; padding:18px; }
  .lf-designers .det-portrait .viz::before{ content:""; position:absolute; inset:0; background:repeating-linear-gradient(135deg,rgba(255,255,255,.16) 0 1px,transparent 1px 10px); opacity:.5; }
  .lf-designers .det-portrait .cap{ position:relative; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13px; color:var(--ink-soft); }

  .lf-designers .det-prodhead{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:20px; }
  .lf-designers .det-prodhead h2{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:26px; }
  .lf-designers .det-products{ display:grid; grid-template-columns:repeat(2,1fr); gap:26px 24px; }
  .lf-designers .prod{ cursor:pointer; }
  .lf-designers .prod .viz{ position:relative; width:100%; min-height:300px; border:1px solid var(--line); overflow:hidden; transition:.3s; display:flex; align-items:center; justify-content:center; }
  .lf-designers .prod:hover .viz{ border-color:var(--accent); }
  .lf-designers .prod .viz::before{ content:""; position:absolute; inset:0; background:repeating-linear-gradient(135deg,rgba(255,255,255,.14) 0 1px,transparent 1px 11px); opacity:.5; }
  .lf-designers .prod .mono{ font-family:'Cormorant Garamond',serif; font-size:88px; color:rgba(138,114,80,.16); line-height:1; }
  .lf-designers .prod .tag{ position:absolute; top:12px; left:12px; z-index:2; background:rgba(253,251,246,.92); border:1px solid var(--line); font-family:'Cormorant Garamond',serif; font-style:italic; font-size:12px; color:var(--accent); padding:3px 11px; border-radius:20px; }
  .lf-designers .prod .wish{ position:absolute; top:12px; right:12px; z-index:2; width:24px; height:24px; }
  .lf-designers .prod .wish svg{ width:18px; height:18px; stroke:var(--ink-soft); stroke-width:1.3; fill:none; }
  .lf-designers .prod .meta{ margin-top:13px; }
  .lf-designers .prod .pb{ font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--gold); }
  .lf-designers .prod .pn{ font-family:'Cormorant Garamond',serif; font-size:19px; line-height:1.2; margin-top:3px; }
  .lf-designers .prod .pm{ font-size:12px; color:var(--ink-soft); margin-top:3px; }
  .lf-designers .prod .pp{ font-size:13.5px; color:var(--ink); margin-top:6px; }
  .lf-designers .det-allnote{ max-width:1280px; margin:0 auto; padding:0 30px 64px; }
  .lf-designers .det-allnote .in{ border-top:1px solid var(--line); padding-top:30px; text-align:center; }
  .lf-designers .det-allnote p{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:18px; color:var(--ink); }
  .lf-designers .det-allnote .bk{ margin-top:14px; display:inline-block; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; color:var(--accent); border-bottom:1px solid var(--accent); padding-bottom:3px; cursor:pointer; }

  @media(max-width:980px){
    .lf-designers .dz-intro{ grid-template-columns:1fr; gap:20px; }
    .lf-designers .dz-featured{ grid-template-columns:1fr 1fr; }
    .lf-designers .dz-names{ grid-template-columns:repeat(2,1fr); }
    .lf-designers .dz-group{ grid-template-columns:54px 1fr; gap:12px; }
    .lf-designers .dz-group .gl{ font-size:30px; }
    .lf-designers .det-wrap{ grid-template-columns:1fr; gap:30px; }
    .lf-designers .det-rail{ position:static; }
    .lf-designers .det-products{ gap:22px 18px; }
  }
  @media(max-width:560px){
    .lf-designers .dz-featured{ grid-template-columns:1fr; }
    .lf-designers .dz-names{ grid-template-columns:1fr; }
    .lf-designers .det-products{ grid-template-columns:1fr; }
    .lf-designers .az-letters{ display:none; }
    .lf-designers .az-search{ flex:1; }
  }
{% endstylesheet %}

{% javascript %}
  (function(){
    var root = document.querySelector('.lf-designers');
    if (!root) return;
    function $(id){ return root.querySelector('#' + id); }

    /* ---------- data ---------- */
    var DESIGNERS = [
      "Alex Monroe","Alhaja","April Please","Atelier 82","Atelier Stone","Au Fil de Lo",
      "Bangle Up","Club Five","Diaperis","Emilieanne","Erminia Sinapi",
      "Fascinato","Felt & Son","Flit 101","Goyate","Hustda","Irene D’Arloz","Kudos",
      "La2L","Leju Leeda","Les Félicités","Louis Hendricks","Lsonge",
      "Mayrena","Mela Bianca","Melissa de la Fuente","Miliemoon","Mon Rêve","Muja Juma","Myabay",
      "Nouvel Amour","Revgrit","Romilt","Sing a Song","Upcycling Phenomenon","Yay","Ylume"
    ].sort(function(a,b){return a.localeCompare(b);});

    var TAGLINES = {
      "Alex Monroe":"Nature, cast in gold · England",
      "Romilt":"Quiet metalwork · the everyday object",
      "Miliemoon":"The house hand · made close to home",
      "Atelier Stone":"Stones first · one of a kind",
      "Mon Rêve":"Soft romance, in gold vermeil",
      "Muja Juma":"Colour & stone · Amsterdam",
      "Au Fil de Lo":"Thread of gold · Paris",
      "Sing a Song":"Playful, daily, collectible"
    };
    var CITIES = ["Paris, France","Seoul, South Korea","Tokyo, Japan","Copenhagen, Denmark","New York, USA","Amsterdam, Netherlands","London, England","Lisbon, Portugal"];
    var MATERIALS = ["Recycled silver","14k gold vermeil","Gold-filled","Solid 9k gold","Freshwater pearl","Sterling silver","Brass · gold plate","Hand-set stones"];
    var VALUE_POOL = ["Recycled metals","Hand-finished","Made to order","Small-batch","Local production","One of a kind","Hypoallergenic","Lifetime repair"];
    var PIECE_DESC = ["Petite","Fil d’Or","Keshi","Coma","Atelier","Vermeil","Hammered","Solitaire","Seed","Mirror","Demi","Première"];
    var PIECE_TYPE = ["Signet","Hoop","Pendant","Band","Cuff","Drop","Chain","Stud","Charm","Ring"];
    var PROD_TAGS = ["New","Best Seller","Exclusive","Pre-order","",""];

    function seed(str){var h=2166136261;for(var i=0;i<str.length;i++){h^=str.charCodeAt(i);h=Math.imul(h,16777619);}return (h>>>0);}
    function pick(arr,n){return arr[Math.abs(n)%arr.length];}

    function detailFor(name){
      var s=seed(name);
      var tagline=TAGLINES[name] || "Independent atelier · in the LE FIGUE curation";
      var origin=pick(CITIES,s);
      var m1=pick(MATERIALS,s), m2=pick(MATERIALS,s>>3), m3=pick(MATERIALS,s>>6);
      var mats=[m1,m2,m3].filter(function(v,i,a){return a.indexOf(v)===i;}).slice(0,3).join(" · ");
      var vals=[]; for(var i=0;i<4;i++){var v=pick(VALUE_POOL,(s>>(i*2))+i);if(vals.indexOf(v)<0)vals.push(v);}
      var since = 1990 + (s % 33);
      var nprod = 4 + (s%3);
      var prods=[];
      for(var p=0;p<nprod;p++){
        var ps=seed(name+"#"+p);
        var nm=pick(PIECE_DESC,ps)+" "+pick(PIECE_TYPE,ps>>4);
        var price = 48 + (ps % 26)*24;
        var tg = pick(PROD_TAGS, ps>>2);
        var pm = pick(MATERIALS, ps>>5);
        prods.push({name:nm, price:price, tag:tg, mat:pm});
      }
      return {
        name:name, tagline:tagline,
        bioShort:"Some makers we find. Some find us. "+name+" sits in the curation for the way the work holds the hand — considered, quiet, made to be worn every day rather than kept for occasions.",
        bioMore:" We keep a small, rotating selection and let the pieces lead. They pair easily, layer without competing, and tend to become the thing you reach for first. New arrivals come in ones and twos; when something is gone, it's often gone.",
        specs:[
          {k:"Origin", v:origin},
          {k:"House since", v:String(since)},
          {k:"Atelier", v:"Made in small batches"},
          {k:"Materials", v:mats}
        ],
        values:vals,
        products:prods
      };
    }

    function grad(n){
      var s=seed(n); var a=20+(s%40); var x=60+(s%30);
      var c1=["#efe8db","#f0e7d6","#f1e9dc","#ece4d4","#efe6d6"][s%5];
      var c2=["#e6dac6","#e4d8c2","#e7dcc8","#e3d6bf","#e8ddc9"][(s>>>3)%5];
      var c3=["#dccdb4","#d6c7ac","#ddd0b8","#d8c9ae","#dccdb2"][(s>>>6)%5];
      return "radial-gradient("+(100+a)+"% "+(100+a)+"% at "+x+"% 12%, "+c1+" 0%, "+c2+" 50%, "+c3+" 100%)";
    }
    function mono(n){var c=n.replace(/[^A-Za-z]/g,'');return (c[0]||'L').toUpperCase();}

    /* ---------- build index ---------- */
    var GROUPS={};
    DESIGNERS.forEach(function(n){ var L=mono(n); (GROUPS[L]=GROUPS[L]||[]).push(n); });
    var ALPHA="ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");

    var featNames=["Alex Monroe","Romilt","Atelier Stone","Miliemoon"].filter(function(n){return DESIGNERS.indexOf(n)>=0;});
    var featEl=$('featured');
    featNames.forEach(function(n){
      var el=document.createElement('div'); el.className='feat'; el.dataset.name=n;
      el.innerHTML='<div class="viz" style="background:'+grad(n)+'"><span class="mono">'+mono(n)+'</span>'+
        '<div><span class="feye">'+(TAGLINES[n]? TAGLINES[n].split(' · ')[0] : 'In the curation')+'</span>'+
        '<span class="fname">'+n+'</span></div></div>';
      el.addEventListener('click',function(){openDetail(n);});
      featEl.appendChild(el);
    });

    var azEl=$('azLetters');
    ALPHA.forEach(function(L){
      var a=document.createElement('a'); a.textContent=L;
      if(GROUPS[L]){ a.href='#grp-'+L; } else { a.className='disabled'; }
      azEl.appendChild(a);
    });

    var idxEl=$('dzIndex');
    Object.keys(GROUPS).sort().forEach(function(L){
      var g=document.createElement('div'); g.className='dz-group'; g.id='grp-'+L; g.dataset.letter=L;
      var names=GROUPS[L].sort(function(a,b){return a.localeCompare(b);});
      var namesHtml=names.map(function(n){return '<a data-name="'+n.replace(/"/g,'&quot;')+'">'+n+'</a>';}).join('');
      g.innerHTML='<div class="gl display">'+L+'</div><div class="dz-names">'+namesHtml+'</div>';
      idxEl.appendChild(g);
    });

    idxEl.addEventListener('click',function(e){
      var a=e.target.closest('a[data-name]'); if(!a) return;
      e.preventDefault(); openDetail(a.dataset.name);
    });

    /* ---------- filter ---------- */
    var fInput=$('filterInput'), emptyEl=$('dzEmpty');
    fInput.addEventListener('input',function(){
      var q=this.value.trim().toLowerCase(); var anyShown=false;
      root.querySelectorAll('.dz-group').forEach(function(g){
        var shown=0;
        g.querySelectorAll('a[data-name]').forEach(function(a){
          var hit=a.dataset.name.toLowerCase().indexOf(q)>=0;
          a.style.display=hit?'':'none'; if(hit)shown++;
        });
        g.style.display=shown?'':'none'; if(shown)anyShown=true;
      });
      emptyEl.style.display=anyShown?'none':'block';
    });

    /* ---------- detail ---------- */
    var indexView=$('indexView'), detailView=$('detailView');
    function openDetail(name){
      var d=detailFor(name);
      $('crumbName').textContent=name;
      $('dName').textContent=name;
      $('dTagline').textContent=d.tagline;
      var bio=$('dBio');
      bio.classList.remove('open');
      bio.innerHTML=d.bioShort+'<span class="more">'+d.bioMore+'</span>';
      $('readMore').textContent='Read more →';
      $('readMore').style.display='inline-block';

      $('dSpec').innerHTML=d.specs.map(function(r){return '<div class="row"><span class="k">'+r.k+'</span><span class="v">'+r.v+'</span></div>';}).join('');
      $('dValues').innerHTML=d.values.map(function(v){return '<span class="pill">'+v+'</span>';}).join('');
      $('dPortrait').style.background=grad(name);

      $('dProducts').innerHTML=d.products.map(function(p){
        var tag=p.tag?'<span class="tag">'+p.tag+'</span>':'';
        return '<div class="prod"><div class="viz" style="background:'+grad(name+p.name)+'">'+tag+
          '<span class="wish"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.5-9.5-9C1 8 2.5 4.5 6 4.5c2 0 3.2 1.2 4 2.3.8-1.1 2-2.3 4-2.3 3.5 0 5 3.5 3.5 6.5C19 15.5 12 20 12 20z"/></svg></span>'+
          '<span class="mono">'+mono(name)+'</span></div>'+
          '<div class="meta"><div class="pb">'+name+'</div><div class="pn">'+p.name+'</div>'+
          '<div class="pm">'+p.mat+'</div><div class="pp">$'+p.price+'</div></div></div>';
      }).join('');

      var i=DESIGNERS.indexOf(name);
      var prev=DESIGNERS[(i-1+DESIGNERS.length)%DESIGNERS.length];
      var next=DESIGNERS[(i+1)%DESIGNERS.length];
      $('prevName').textContent=prev;
      $('nextName').textContent=next;
      $('prevBtn').onclick=function(){openDetail(prev);};
      $('nextBtn').onclick=function(){openDetail(next);};

      indexView.classList.remove('active'); detailView.classList.add('active');
      window.scrollTo({top:0,behavior:'auto'});
    }
    function showIndex(){ detailView.classList.remove('active'); indexView.classList.add('active'); }

    $('readMore').addEventListener('click',function(){
      var bio=$('dBio'); var open=bio.classList.toggle('open');
      this.textContent=open?'Read less ←':'Read more →';
    });
    $('crumbHome').addEventListener('click',showIndex);
    $('backToAll').addEventListener('click',showIndex);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "LE FIGUE Designers",
  "settings": [],
  "presets": [{ "name": "LE FIGUE Designers" }]
}
{% endschema %}
