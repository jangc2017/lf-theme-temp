        "item-1": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "Do you ship internationally?",
            "text": "<p>At this time, LE FIGUE ships within the United States only. International shipping is not currently available.</p>"
          }
        },
        "item-2": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "When will my order be shipped?",
            "text": "<p>Shipping timing may vary depending on the item.</p><p>Most ready-to-ship items are processed within 1–2 business days. Some pieces, including made-to-order, special order, or designer-dependent items, may require approximately 7–14 business days before shipment.</p><p>If there is any expected delay or special production timeline, our team will contact you by email.</p>"
          }
        },
        "item-3": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "How long will it take until I receive my order?",
            "text": "<p>Many domestic orders arrive within approximately 12–24 hours after shipment, depending on the destination and carrier service. Delivery timing may vary due to carrier conditions, holidays, weather, or other circumstances outside of our control.</p>"
          }
        },
        "item-4": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "What is your return policy?",
            "text": "<p>We are happy to accept eligible returns within the following return windows:</p><p>Earrings may be returned within 14 days of delivery.</p><p>All other eligible items may be returned within 21 days of delivery.</p><p>Returned items must be unworn, unused, in their original condition, and returned with original packaging and proof of purchase. Items that show signs of wear, damage, alteration, or missing packaging may not be accepted.</p><p>For hygiene reasons, earrings must be completely unworn and in original condition to be eligible for return.</p><p>Made-to-order, custom, special order, final sale items, and gift cards may not be eligible for return unless otherwise required by law or approved by LE FIGUE.</p><p>To request a return, please email <a href=\"mailto:care@lefigue.com\" target=\"_blank\">care@lefigue.com</a> with your order number and return request details.</p>"
          }
        },
        "item_yXUNhD": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "What should I do if my item arrives damaged?",
            "text": "<p>Please contact us at<a href=\"mailto:care@lefigue.com\" target=\"_blank\">care@lefigue.com</a>within 48 hours of delivery with your order number and clear photos of the item, packaging, and shipping box. Our team will review the issue and assist you as quickly as possible.</p>"
          }
        }
