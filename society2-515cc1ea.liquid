;margin:0 auto;border-top:1px solid var(--hair)}.lf-society .faq-item{border-bottom:1px solid var(--hair)}.lf-society .faq-q{width:100%;display:flex;justify-content:space-between;align-items:center;gap:20px;background:none;border:none;text-align:left;padding:22px 4px;font-family:var(--d);font-size:21px;color:var(--ink);transition:color .3s}.lf-society .faq-q:hover{color:var(--accent)}.lf-society .faq-ic{flex:0 0 auto;font-family:var(--b);font-size:20px;color:var(--accent);transition:transform .3s;line-height:1}.lf-society .faq-item.open .faq-ic{transform:rotate(45deg)}.lf-society .faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease}.lf-society .faq-a p{font-size:13.5px;line-height:1.8;color:var(--ink-soft);padding:0 4px 24px;max-width:66ch}.lf-society .refer{margin:74px 0 0}.lf-society .refer-card{max-width:620px;margin:0 auto;border:1px solid var(--gold);background:rgba(184,151,95,.06);padding:48px 44px;text-align:center}.lf-society .refer-card .ov{font-size:11px;letter-spacing:.36em;text-transform:uppercase;color:var(--accent);font-weight:600}.lf-society .refer-card h2{font-family:var(--d);font-weight:500;font-size:clamp(30px,4.2vw,44px);line-height:1.04;margin-top:12px}.lf-society .refer-card>p{font-size:14px;color:var(--ink-soft);line-height:1.7;margin-top:14px;max-width:42ch;margin-left:auto;margin-right:auto}.lf-society .refer-card>p b{color:var(--accent);font-weight:500}.lf-society .refer-link{margin-top:28px;text-align:left}.lf-society .rl-label{font-size:9.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-soft)}.lf-society .rl-row{display:flex;gap:10px;margin-top:9px}.lf-society .rl-row input{flex:1;font-family:var(--b);font-size:13px;color:var(--ink);background:var(--cream);border:1px solid var(--hair);padding:13px 14px;border-radius:0;min-width:0}.lf-society .rl-row button, .lf-society .refer-send button{background:var(--ink);color:var(--cream);border:1px solid var(--ink);font-size:11px;letter-spacing:.18em;text-transform:uppercase;padding:13px 22px;white-space:nowrap;transition:background .3s,color .3s}.lf-society .rl-row button:hover, .lf-society .refer-send button:hover{background:transparent;color:var(--ink)}.lf-society .refer-or{font-family:var(--d);font-style:italic;color:var(--ink-soft);font-size:14px;margin:22px 0 14px}.lf-society .refer-send{display:flex;gap:10px}.lf-society .refer-send input{flex:1;font-family:var(--b);font-size:14px;color:var(--ink);background:transparent;border:none;border-bottom:1px solid var(--line);padding:11px 2px;border-radius:0;transition:border-color .3s;min-width:0}.lf-society .refer-send input:focus{outline:none;border-color:var(--gold)}.lf-society .refer-done{font-family:var(--d);font-style:italic;font-size:15px;color:var(--accent);margin-top:18px}.lf-society .refer-fine{font-size:11px;color:var(--ink-soft);margin-top:18px;line-height:1.6}@media(max-width:560px){.lf-society .rl-row, .lf-society .refer-send{flex-direction:column}.lf-society .refer-card{padding:32px 24px}}.lf-society .rl-row button, .lf-society .refer-send button{background:var(--gold);color:#1b1714;border-color:var(--gold)}.lf-society .rl-row button:hover, .lf-society .refer-send button:hover{background:transparent;color:var(--gold)}.lf-society .rl-row input{background:var(--cream-2)}.lf-society .refer-card{background:rgba(214,178,125,.08)}.lf-society .refer-min{text-align:center;padding:20px 0 0}.lf-society .rm-inner{max-width:460px;margin:0 auto}.lf-society .rm-mark{width:26px;height:1px;background:var(--gold);margin:0 auto 22px}.lf-society .rm-ov{font-size:10.5px;letter-spacing:.34em;text-transform:uppercase;color:var(--accent);font-weight:600}.lf-society .rm-line{font-family:var(--d);font-style:italic;font-size:19px;line-height:1.5;color:var(--ink-soft);margin-top:12px}.lf-society .rm-line .amt{color:var(--accent);font-style:normal}.lf-society .rm-link{display:flex;align-items:center;gap:10px;max-width:360px;margin:24px auto 0;border-bottom:1px solid var(--line);padding-bottom:9px}.lf-society .rm-link input{flex:1;border:none;background:transparent;font-family:var(--b);font-size:13px;color:var(--ink);padding:2px 0;border-radius:0;min-width:0}.lf-society .rm-link input:focus{outline:none}.lf-society .rm-link button{background:none;border:none;font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);white-space:nowrap;transition:opacity .3s;cursor:pointer}.lf-society .rm-link button:hover{opacity:.55}.lf-society .rm-fine{font-size:11px;color:var(--ink-soft);margin-top:16px}
