x;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-soft)}.lf-society .stat .v{display:block;font-family:var(--d);font-size:23px;line-height:28px;margin-top:6px;color:var(--ink)}.lf-society .td-benefits{list-style:none;margin-top:24px}.lf-society .td-benefits li{display:flex;gap:13px;align-items:baseline;padding:9px 0;font-size:13.5px;color:var(--ink);line-height:1.55}.lf-society .td-benefits li::before{content:"";flex:0 0 5px;height:5px;border-radius:50%;background:var(--gold);transform:translateY(7px)}.lf-society .td-note{font-family:var(--d);font-style:italic;font-size:14px;color:var(--ink-soft);line-height:1.6;margin-top:auto;padding-top:22px;border-top:1px solid var(--hair)}.lf-society .tier-toggle{display:inline-flex;border:1px solid var(--hair);border-radius:40px;padding:4px;margin-top:18px}.lf-society .tier-toggle button{border:none;background:none;color:var(--ink-soft);font-size:11px;letter-spacing:.18em;text-transform:uppercase;padding:9px 22px;border-radius:30px;transition:all .3s}.lf-society .tier-toggle button.on{background:var(--ink);color:var(--cream)}.lf-society #compare-view{display:none}.lf-society .cmp-scroll{overflow-x:auto;border:1px solid var(--hair);scrollbar-width:thin}.lf-society .cmp{border-collapse:collapse;width:100%;min-width:880px}.lf-society .cmp th, .lf-society .cmp td{padding:14px 16px;text-align:center;border-bottom:1px solid var(--hair);font-size:12.5px;white-space:nowrap}.lf-society .cmp thead th{position:sticky;top:0;background:var(--cream);z-index:2;border-bottom:1px solid var(--line)}.lf-society .cmp thead th .tn{font-family:var(--d);font-size:18px;color:var(--ink);display:block}.lf-society .cmp thead th .te{font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);margin-top:3px;display:block;font-weight:400}.lf-society .cmp thead th.inv .tn{color:var(--accent)}.lf-society .cmp tbody th{position:sticky;left:0;background:var(--cream);text-align:left;font-weight:500;font-size:10px;letter-spacin