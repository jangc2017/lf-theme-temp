{% javascript %}
/* ── seal motif ── */
  const SEAL = `<svg viewBox="0 0 200 200" fill="none">
    <circle cx="100" cy="100" r="82" stroke="currentColor" stroke-width="1"/>
    <circle cx="100" cy="100" r="73" stroke="currentColor" stroke-width="0.6"/>
    <defs><path id="arc" d="M46 100 A54 54 0 0 0 154 100"/></defs>
    <text font-family="'Pretendard Variable',sans-serif" font-size="10.5" letter-spacing="3.4" fill="currentColor"><textPath href="#arc" startOffset="50%" text-anchor="middle">LE FIGUE SOCIETY</textPath></text>
    <text x="100" y="118" text-anchor="middle" font-family="'Cormorant Garamond',serif" font-weight="500" font-size="50" fill="currentColor">LF</text>
    <circle cx="78" cy="150" r="1.5" fill="currentColor"/><circle cx="100" cy="153" r="1.5" fill="currentColor"/><circle cx="122" cy="150" r="1.5" fill="currentColor"/>
  </svg>`;
  ['seal-bg','join-seal','done-seal'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML=SEAL;});

  /* ── tiers ── */
  const TIERS=[
    {name:'The Guest', who:'For the one who has just arrived.', entry:'Sign up', credit:'1%', pricing:'—',
     benefits:['Welcome 250 House Credits','Member account access']},
    {name:'The Explorer', who:'For the one who discovers first.', entry:'$350, or 3 orders', credit:'1%', pricing:'3%',
     benefits:['250 House Credits on entry','Complimentary standard shipping','Birthday month House Credit bonus']},
    {name:'The Connoisseur', who:'For the one who knows how to choose.', entry:'$700, or 5 orders', credit:'1.25%', pricing:'5%',
     benefits:['500 House Credits on entry','Complimentary standard shipping','Birthday House Credits, doubled','Anniversary House Credit bonus']},
    {name:'The Resident', who:'For the one who has become part of the society.', entry:'$1,300, or 9 orders', credit:'1.5%', pricing:'7%',
     benefits:['500 House Credits on entry','Complimentary standard and express shipping','Anniversary House Credit bonus','Early access, twelve hours, to selected previews and restocks']},
    {name:'The Keeper', who:'For the one who has found their own language.', entry:'$2,000, or 15 orders', credit:'1.75%', pricing:'10%',
     benefits:['750 House Credits on entry','Complimentary standard and express shipping','Birthday House Credits, doubled','Early access, twenty four hours, to selected releases and restocks','Private shopping appointment']},
    {name:'The Confidant', who:'For the one others look to.', entry:'$3,500, or 20 orders', credit:'2%', pricing:'12%',
     benefits:['1,000 House Credits on entry','International shipping courtesy on eligible orders','A seasonal gift from the society','Private shopping appointment','Personal styling suggestions','Designer preview access']},
    {name:'The Figure', who:'For the one who becomes part of the LE FIGUE story.', entry:'By invitation', credit:'2.5%', pricing:'Private', invitation:true,
     benefits:['1,500 House Credits on entry','Priority access to selected designer previews','Private appointment priority','Personal styling and edit suggestions','A seasonal gift from the society','An annual private LE FIGUE gift','Dedicated client support for special requests'],
     note:'The Figure is our private invitation tier, reserved for clients with an ongoing relationship with the society. It remains selective, personal, and quietly extended.'}
  ];

  const rail=document.getElementById('rail');
  rail.innerHTML=TIERS.map((t,i)=>`<button class="tier-item ${i===0?'on':''}" data-i="${i}">
    <span class="node"></span>
    <span class="ti-main"><span class="ti-name">${t.name}</span><span class="ti-entry">${t.entry}</span></span>
    ${t.invitation?'<span class="ti-inv">Invitation</span>':''}
  </button>`).join('');

  function renderTier(i){
    const t=TIERS[i];
    const pricing = t.pricing==='—' ? '<span style="color:var(--line)">&mdash;</span>' : t.pricing;
    document.getElementById('tier-detail').innerHTML=`
      <div class="td-kick">Tier</div>
      <div class="td-name">${t.name}</div>
      <div class="td-who">${t.who}</div>
      <div class="td-stats">
        <div class="stat"><span class="k">Credit rate</span><span class="v">${t.credit}</span></div>
        <div class="stat"><span class="k">Member Pricing</span><span class="v">${pricing}</span></div>
        <div class="stat"><span class="k">How to enter</span><span class="v" style="font-size:17px;line-height:28px">${t.entry}</span></div>
      </div>
      <ul class="td-benefits">${t.benefits.map(b=>`<li>${b}</li>`).join('')}</ul>
      ${t.note?`<p class="td-note">${t.note}</p>`:''}`;
  }
  rail.addEventListener('click',e=>{const b=e.target.closest('.tier-item');if(!b)return;
    [...rail.children].forEach(x=>x.classList.remove('on'));b.classList.add('on');renderTier(+b.dataset.i);});
  renderTier(0);

  /* ── compare matrix (cumulative: higher tiers keep lower benefits) ── */
  const ROWS=[
    {k:'How to enter', v:['Sign up','$350 or 3 orders','$700 or 5 orders','$1,300 or 9 orders','$2,000 or 15 orders','$3,500 or 20 orders','By invitation']},
    {k:'House Credits earned', v:['1%','1%','1.25%','1.5%','1.75%','2%','2.5%']},
    {k:'Member Pricing', v:['—','3%','5%','7%','10%','12%','Private']},
    {k:'Welcome credits', v:['250','250','500','500','750','1,000','1,500']},
    {k:'Complimentary shipping', v:['—','Standard','Standard','Standard, Express','Standard, Express','International courtesy','International courtesy']},
    {k:'Birthday House Credits', v:['—','Bonus','Doubled','Doubled','Doubled','Doubled','Doubled']},
    {k:'Anniversary credits', v:['—','—','Yes','Yes','Yes','Yes','Yes']},
    {k:'Early access', v:['—','—','—','12 hours','24 hours','24 hours','Priority']},
    {k:'Private appointment', v:['—','—','—','—','Yes','Yes','Priority']},
    {k:'Personal styling', v:['—','—','—','—','—','Yes','Yes']},
    {k:'Designer previews', v:['—','—','—','—','—','Access','Priority']},
    {k:'Seasonal gift', v:['—','—','—','—','—','Yes','Yes']},
    {k:'Annual private gift', v:['—','—','—','—','—','—','Yes']},
    {k:'Dedicated support', v:['—','—','—','—','—','—','Yes']}
  ];
  let compareBuilt=false;
  function buildCompare(){
    const head='<tr><th></th>'+TIERS.map(t=>`<th class="${t.invitation?'inv':''}"><span class="tn">${t.name}</span><span class="te">${t.entry}</span></th>`).join('')+'</tr>';
    const body=ROWS.map(r=>'<tr><th>'+r.k+'</th>'+r.v.map(v=>{
      if(v==='Yes')return '<td class="yes">&#10003;</td>';
      if(v==='—')return '<td><span class="dash">&mdash;</span></td>';
      return '<td>'+v+'</td>';
    }).join('')+'</tr>').join('');
    document.getElementById('compare-view').innerHTML=`<div class="cmp-scroll"><table class="cmp"><thead>${head}</thead><tbody>${body}</tbody></table></div><p class="cmp-note">Higher tiers keep the benefits of every tier below, and House Credits are worth two dollars for every hundred. The Figure is extended by invitation.</p>`;
  }
  document.querySelectorAll('.tier-toggle button').forEach(b=>b.addEventListener('click',()=>{
    document.querySelectorAll('.tier-toggle button').forEach(x=>x.classList.remove('on'));b.classList.add('on');
    const v=b.dataset.v;
    document.getElementById('explore-view').style.display=v==='explore'?'block':'none';
    document.getElementById('compare-view').style.display=v==='compare'?'block':'none';
    if(v==='compare'&&!compareBuilt){buildCompare();compareBuilt=true;}
  }));

  /* ── join ── */
  const cta=document.getElementById('join-cta');
  cta.addEventListener('click',()=>{
    const fn=document.getElementById('fn'), em=document.getElementById('em');
    const pw=document.getElementById('pw'), pw2=document.getElementById('pw2');
    const err=document.getElementById('err');
    document.querySelectorAll('.field').forEach(f=>f.classList.remove('err'));
    let ok=true, msg='Please complete the fields to create your account.';
    if(!fn.value.trim()){fn.closest('.field').classList.add('err');ok=false;}
    const emv=em.value.trim();
    if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(emv)){em.closest('.field').classList.add('err');ok=false;}
    if(pw.value.length<8){pw.closest('.field').classList.add('err');ok=false;msg='Please choose a password of at least 8 characters.';}
    if(pw.value && pw.value!==pw2.value){pw2.closest('.field').classList.add('err');ok=false;msg='Your passwords do not match.';}
    if(!ok){err.textContent=msg;return;}
    err.textContent='';
    const name=fn.value.trim();
    const member={name, lastName:document.getElementById('ln').value.trim(), email:emv,
      birthday:document.getElementById('bm').value, tierIndex:0, joined:'2026'};
    try{localStorage.setItem('lf_member',JSON.stringify(member));}catch(e){}
    document.getElementById('done-msg').textContent=`${name}, your account is open. The Guest is where the society begins, and every purchase moves you quietly toward the next tier.`;
    document.getElementById('join-card').hidden=true;
    document.getElementById('join-done').hidden=false;
    document.getElementById('join-done').scrollIntoView({block:'center'});
  });

  /* FAQ accordion */
  document.querySelectorAll('.faq-q').forEach(q=>q.addEventListener('click',()=>{
    const it=q.closest('.faq-item'), a=it.querySelector('.faq-a');
    const open=it.classList.toggle('open');
    a.style.maxHeight=open?a.scrollHeight+'px':'0';
  }));
  /* referral */
  (function(){
    const link=document.getElementById('ref-link'); if(!link)return;
    try{const m=JSON.parse(localStorage.getItem('lf_member')||'null');
      if(m&&m.name){link.value='lefigue.com/society?ref='+m.name.toUpperCase().replace(/[^A-Z0-9]/g,'')+'50';}}catch(e){}
    const cp=document.getElementById('ref-copy');
    cp&&cp.addEventListener('click',()=>{
      if(navigator.clipboard){navigator.clipboard.writeText(link.value).catch(()=>{});}
      else{link.select();try{document.execCommand('copy');}catch(e){}}
      cp.textContent='Copied'; setTimeout(()=>cp.textContent='Copy',1600);});
    const rs=document.getElementById('ref-send');
    rs&&rs.addEventListener('click',()=>{const e=document.getElementById('ref-email'),v=e.value.trim();
      if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(v)){e.style.borderColor='#b4554d';return;}
      document.querySelector('.refer-send').style.display='none';
      document.getElementById('ref-done').hidden=false;});
  })();
{% endjavascript %}

