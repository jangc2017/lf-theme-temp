{%- comment -%}
  LE FIGUE — shared Pre-Order payload. Source of truth = manual collection "pre-order";
  product metafields custom.preorder_* drive state/dates/edition/labels. Rendered by
  sections/lefigue-preorder.liquid and lefigue-preorder-detail.liquid.
  Dates emit as ISO-8601 (offset without colon, e.g. -0400) — page JS normalizes.
  edition = raw label ("Limited Edition" | "LE FIGUE Exclusive" | "Maison Objet" | null).
  variants = every variant (id/title/available) — >1 variant drives the size selector.
{%- endcomment -%}
{%- assign lf_po = collections['pre-order'] -%}
<script type="application/json" data-lf-preorder>
[
{%- assign lf_emitted = 0 -%}
{%- for p in lf_po.products -%}
  {%- if lf_emitted > 0 -%},{%- endif -%}
  {"handle": {{ p.handle | json }},
   "title": {{ p.title | json }},
   "brand": {{ p.vendor | json }},
   "price": {{ p.price | divided_by: 100.0 | json }},
   "disc": {{ p.metafields.custom.preorder_discount.value | json }},
   "img": {% if p.featured_image %}{{ p.featured_image | image_url: width: 900 | json }}{% else %}null{% endif %},
   "variant": {{ p.selected_or_first_available_variant.id | json }},
   "imgs": [{% assign lf_in = 0 %}{% for im in p.images limit: 8 %}{% if lf_in > 0 %},{% endif %}{{ im | image_url: width: 1200 | json }}{% assign lf_in = lf_in | plus: 1 %}{% endfor %}],
   "url": {{ p.url | json }},
   "open_at": {% assign lf_oa = p.metafields.custom.preorder_open_at.value | date: '%Y-%m-%dT%H:%M:%S%z' %}{% if lf_oa != blank %}{{ lf_oa | json }}{% else %}null{% endif %},
   "close_at": {% assign lf_ca = p.metafields.custom.preorder_close_at.value | date: '%Y-%m-%dT%H:%M:%S%z' %}{% if lf_ca != blank %}{{ lf_ca | json }}{% else %}null{% endif %},
   "edition": {{ p.metafields.custom.preorder_edition.value | json }},
   "run_total": {{ p.metafields.custom.preorder_run_total.value | json }},
   "run_left": {{ p.metafields.custom.preorder_run_left.value | json }},
   "ships": {{ p.metafields.custom.preorder_ships.value | json }},
   "note": {{ p.metafields.custom.preorder_note.value | json }},
   "size_note": {{ p.metafields.custom.preorder_size_note.value | json }},
   "material": {{ p.metafields.custom.material.value | json }},
   "form": {{ p.metafields.custom.form.value | json }},
   "desc": {{ p.description | strip_html | truncate: 600 | json }},
   "desc_html": {{ p.description | json }},
   "variants": [{% assign lf_vn = 0 %}{% for v in p.variants %}{% if lf_vn > 0 %},{% endif %}{"id": {{ v.id | json }}, "t": {{ v.title | json }}, "a": {% if v.available %}true{% else %}false{% endif %}}{% assign lf_vn = lf_vn | plus: 1 %}{% endfor %}],
   "maker_handle": {% assign lf_mh = '' %}{% assign lf_mi = '' %}{% for c in p.collections %}{% if c.title == p.vendor and c.metafields.custom.designer_page.value %}{% assign lf_mh = c.handle %}{% if c.image %}{% assign lf_mi = c.image | image_url: width: 900 %}{% endif %}{% endif %}{% endfor %}{% if lf_mh != '' %}{{ lf_mh | json }}{% else %}null{% endif %},
   "maker_img": {% if lf_mi != '' %}{{ lf_mi | json }}{% else %}null{% endif %}}
  {%- assign lf_emitted = lf_emitted | plus: 1 -%}
{%- endfor -%}
]
</script>
