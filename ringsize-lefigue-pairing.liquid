    { "type": "text", "id": "hero_sub", "label": "Subline", "default": "Some pieces are stronger in dialogue." },
    { "type": "textarea", "id": "hero_lede", "label": "Intro line", "default": "Discover the pairing that feels like yours, composed to be worn together." }
  ],
  "presets": [{ "name": "LE FIGUE Pairing" }]
}
