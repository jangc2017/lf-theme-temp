{% comment %} LE FIGUE Pairing — data from collections flagged custom.pairing_page; discount from custom.pairing_discount. {% endcomment %}
<script type="application/json" data-lf-pairings>
[
{%- assign lf_first = true -%}
{%- paginate collections by 250 -%}
{%- for collection in collections -%}
  {%- if collection.metafields.custom.pairing_page.value -%}
    {%- unless lf_first %},{% endunless -%}{%- assign lf_first = false -%}
    {%- assign disc = collection.metafields.custom.pairing_discount.value | default: 15 -%}
    {%- assign makers = '' -%}
    {%- for p in collection.products -%}{%- unless makers contains p.vendor -%}{%- assign makers = makers | append: p.vendor | append: ' · ' -%}{%- endunless -%}{%- endfor -%}
    {%- assign makers = makers | remove_last: ' · ' -%}
    {
      "type": "figue",
      "feat": {% if collection.metafields.custom.pairing_featured.value %}true{% else %}false{% endif %},
      "id": {{ collection.handle | json }},
      "name": {{ collection.title | json }},
      "ar": "4/5",
      "makers": {{ makers | json }},
      "note": {{ collection.description | strip_html | json }},
      "img": {% if collection.image %}{{ collection.image | image_url: width: 1200 | json }}{% else %}null{% endif %},
      "disc": {{ disc | json }},
      "pieces": [
        {%- for p in collection.products -%}{%- unless forloop.first %},{% endunless -%}
        {
          "nm": {{ p.title | json }},
          "url": {{ p.url | json }},
          "vid": {{ p.first_available_variant.id | default: p.variants.first.id | json }},
          {%- assign szopt = '' -%}{%- unless p.has_only_default_variant -%}{%- for o in p.options_with_values -%}{%- assign od = o.name | downcase -%}{%- if od == 'size' -%}{%- assign szopt = o.name -%}{%- endif -%}{%- endfor -%}{%- endunless -%}
          "sopt": {% if szopt == '' %}null{% else %}{{ szopt | json }}{% endif %},
          "vars": [{%- if szopt != '' -%}{%- for v in p.variants -%}{%- unless forloop.first -%},{%- endunless -%}{"id":{{ v.id | json }},"t":{{ v.title | json }},"av":{% if v.available %}true{% else %}false{% endif %}}{%- endfor -%}{%- endif -%}],
          "mk": {{ p.vendor | json }},
          "price": {{ p.price | divided_by: 100.0 | json }},
          "cat": {{ p.category.name | default: p.type | json }},
          "m": {{ p.metafields.custom.material.value | default: '' | json }},
          "sz": {{ p.metafields.custom.form.value | default: '' | json }},
          "d": {{ p.description | strip_html | json }},
          "img": {% if p.featured_image %}{{ p.featured_image | image_url: width: 1000 | json }}{% else %}null{% endif %},
          "ar": "4/5"
        }
        {%- endfor -%}
      ]
    }
  {%- endif -%}
{%- endfor -%}
{%- endpaginate -%}
]
</script>
<div class="lf-pairing">
<main id="view-board">
  <div class="wrap"><div class="phead"><div class="ov">{{ section.settings.hero_eyebrow | default: "Le Figue Pairing" }}</div><h1>{{ section.settings.hero_title | default: "Worn as one thought" }}</h1><p class="sub">{{ section.settings.hero_sub | default: "Some pieces are stronger in dialogue." }}</p><p class="lede">{{ section.settings.hero_lede | default: "Discover the pairing that feels like yours, composed to be worn together." }}</p></div></div>
  <div class="filterbar"><div class="inner">
    <div class="filtersets"><div class="filterrow"><span class="flbl">Type</span><div class="chips"><button class="chip on" data-cat="All">All</button><button class="chip " data-cat="Necklaces">Necklaces</button><button class="chip " data-cat="Earrings">Earrings</button><button class="chip " data-cat="Bracelets">Bracelets</button><button class="chip " data-cat="Rings">Rings</button></div></div></div>
    <button class="saved-btn" id="saved-btn" aria-label="Kept"><svg viewBox="0 0 24 24"><path d="M6 4h12v16l-6-4-6 4z"/></svg><span class="lbl">Kept</span><span class="cnt" id="saved-cnt">0</span></button>
  </div></div>
  <div class="wrap"><div id="board-body"></div></div>
  
  
</main>

<main id="view-saved">
  <div class="detailbar"><div class="inner"><button class="back2" id="saved-back">&larr; All pairings</button><span class="all" style="pointer-events:none">Kept</span></div></div>
  <div class="wrap"><div class="phead small"><div class="ov">Kept</div><h1>The pieces you keep</h1></div><div id="saved-body"></div></div>
</main>

<main id="view-pairing">
  <div class="detailbar"><div class="inner"><button class="back2" id="pairing-back">&larr; All pairings</button>
    <button class="keepbar" id="pairing-keep" data-keep><svg viewBox="0 0 24 24"><path d="M6 4h12v16l-6-4-6 4z"/></svg>Keep</button></div></div>
  <div class="wrap"><div id="pairing-body"></div></div>
</main>

<main id="view-product">
  <div class="detailbar"><div class="inner"><button class="back2" id="product-back">&larr; Back</button><button class="all" id="all-pairings">All pairings</button></div></div>
  <div class="wrap"><div id="product-body"></div></div>
</main>
</div>
