  return `<div class="${cls} lf-car" style="aspect-ratio:${asp}">${imgs.map((u,i)=>`<div class="sl${i?'':' on'}" style="background-image:url('${u}')"></div>`).join('')}<span class="cnav cprev" role="button" aria-label="Previous photo">&lsaquo;</span><span class="cnav cnext" role="button" aria-label="Next photo">&rsaquo;</span><div class="cdots">${imgs.map((_,i)=>`<span${i?'':' class="on"'}></span>`).join('')}</div></div>`;};
const RM=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
function stepCar(el,dir){const sl=el.querySelectorAll('.sl');if(sl.length<2)return;let c=0;sl.forEach((s,j)=>{if(s.classList.contains('on'))c=j;});const n=(c+dir+sl.length)%sl.length;sl[c].classList.remove('on');sl[n].classList.add('on');const d=el.querySelectorAll('.cdots span');if(d.length){d[c].classList.remove('on');d[n].classList.add('on');}}
function wireCars(){document.querySelectorAll('.lf-car:not([data-live])').forEach((el,i)=>{el.dataset.live='1';
  el.querySelectorAll('.cnav').forEach(b=>b.addEventListener('click',e=>{e.stopPropagation();e.preventDefault();el.dataset.hold='1';stepCar(el,b.classList.contains('cnext')?1:-1);}));
  if(RM)return;
  setTimeout(()=>{const iv=setInterval(()=>{if(!el.isConnected){clearInterval(iv);return;}if(el.dataset.hold)return;stepCar(el,1);},3500);},(i%5)*700);});}
const lfRate=n=>n>=5?20:(n===4?18:(n===3?15:(n===2?7:0)));

/* ---------- favorites (Kept) ---------- */
const KEY='lf_kept_'+PAGE;
function loadKept(){try{const r=localStorage.getItem(KEY);return new Set(r?JSON.parse(r):[]);}catch(e){return new Set();}}
function saveKept(){try{localStorage.setItem(KEY,JSON.stringify([...kept]));}catch(e){}}
let kept=loadKept();
function updateBadge(){const el=$('#saved-cnt');if(!el)return;el.textContent=kept.size;el.style.display=kept.size?'inline-flex':'none';}
function syncKeep(){document.querySelectorAll('[data-keep]').forEach(b=>{const host=b.closest('[data-id]');if(host)b.classList.toggle('on',kept.has(host.dataset.id));});}
function toggleKeep(id){if(kept.has(id))kept.delete(id);else kept.add(id);saveKept();updateBadge();syncKeep();if(curView==='saved')renderSaved();}

/* ---------- state + filters ---------- */
let view='list', catF='All', brandF='All', curView='board', passes=0, maxPasses=1, io=null, boardGridList=[];
function pcats(p){const s=new Set(p.pieces.map(x=>x.cat));if(p.icon)s.add(p.icon.cat);return [...s];}
function filtered(){let l=DATA.slice();if(PAGE==='icon'&&brandF!=='All')l=l.filter(p=>p.house===brandF);if(catF!=='All')l=l.filter(p=>pcats(p).includes(catF));return l;}

function tileHTML(p){const ov=PAGE==='icon'?p.house:'Le Figue';
  return `<button class="tile" data-id="${p.id}">${slot(p.ar,p.img)}<span class="keep ${kept.has(p.id)?'on':''}" data-keep title="Keep">${BM}</span>
    <div class="hov"><div class="hl"><div class="ho">${ov}</div><div class="hn">${p.name}</div>
    <div class="hp"><span class="was">${fmt(sum(p))}</span><span>${fmt(setp(p))}</span><span class="set">Set ${lfRate(p.pieces.length)}%</span></div></div></div></button>`;}
function cardHTML(p){const ov=PAGE==='icon'?p.house:'Le Figue Pairing';const cnt=PAGE==='icon'?p.pieces.length+' piece edit':p.pieces.length+' pieces';
  return `<button class="card" data-id="${p.id}">${carSlot(p,false)}<div class="cap"><div class="ov">${ov}</div><div class="nm">${p.name}</div>
    <div class="mt"><span class="l">${cnt}</span><span class="p"><span class="was">${fmt(sum(p))}</span>${fmt(setp(p))}<span class="set">Set ${lfRate(p.pieces.length)}%</span></span></div></div></button>`;}
function heroHTML(p){const isIcon=PAGE==='icon';
  const ov=isIcon?p.house+' · Icon Pairing':'Le Figue Pairing';
  const copy=isIcon?p.hn:p.note;
  const listLabel=isIcon?'The edit':'The pairing';
  const items=p.pieces.map(x=>`<li><span>${x.nm}</span><span class="hp-pr">${fmt(x.price)}</span></li>`).join('');
  return `<div class="hero2" data-id="${p.id}">
    <div class="hmedia">${carSlot(p,true)}</div>
    <div class="hinfo">
      <div class="ov">${ov}</div>
      <h2>${p.name}</h2>
      <p class="hsub">${copy}</p>
      <ul class="hlist"><li class="hl-h">${listLabel}</li>${items}</ul>
      <div class="hprice"><span class="was">${fmt(sum(p))}</span><span class="now">${fmt(setp(p))}</span><span class="set">Set ${lfRate(p.pieces.length)}%</span></div>
      <button class="hcta">See the pairing</button>
    </div></div>`;}
function itemHTML(p){return view==='gallery'?tileHTML(p):cardHTML(p);}

/* ---------- board with infinite scroll ---------- */
function renderBoard(){
  passes=0; if(io){io.disconnect();io=null;}
  const list=filtered();
  let h='';
  const showHero=catF==='All'&&brandF==='All'&&list.length>0;
  if(showHero) h+=heroHTML(list[0]);
  boardGridList=showHero?list.slice(1):list;
  h+=`<div class="count">${list.length} ${list.length===1?'pairing':'pairings'}</div>`;
  if(!list.length){h+=`<div class="empty">No pairings in this view yet.<button class="reset">Show all</button></div>`;$('#board-body').innerHTML=h;return;}
  h+=`<div class="grid ${view}" id="grid"></div><div id="sentinel"></div><p class="foot-note" id="foot" style="display:none">New pairings are added each season.</p>`;
  $('#board-body').innerHTML=h;
  appendPass();
  io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)appendPass();});},{rootMargin:'500px'});
  io.observe($('#sentinel'));
}
function appendPass(){
  const grid=$('#grid');if(!grid)return;
  if(passes>=maxPasses){const f=$('#foot');if(f)f.style.display='block';if(io){io.disconnect();io=null;}return;}
  grid.insertAdjacentHTML('beforeend',boardGridList.map(itemHTML).join(''));
  passes++; syncKeep(); wireCars();
}

/* ---------- saved (Kept) view ---------- */
function renderSaved(){
  const list=DATA.filter(p=>kept.has(p.id));
  let h;
  if(!list.length){
    h=`<div class="empty">Nothing kept yet.<br><span style="font-size:14px">Tap the bookmark on any pairing to keep it here.</span><button class="browsebtn">Browse pairings</button></div>`;
  }else{
    h=`<div class="count">${list.length} kept</div><div class="grid list">${list.map(cardHTML).join('')}</div>`;
  }
  $('#saved-body').innerHTML=h; syncKeep(); wireCars();
}

/* ---------- pairing + product (unchanged logic) ---------- */
function sizeSel(x,i){var eh=function(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');};return `<select class="lf-sizesel" data-size="${i}" aria-label="Select size"><option value="">Size</option>${x.vars.map(v=>`<option value="${v.id}"${v.av?'':' disabled'}>${eh(v.t)}${v.av?'':' \u2014 sold out'}</option>`).join('')}</select>`;}
function pieceRow(x,i,fixed){
  if(fixed) return `<div class="piece fixed"><div class="nav"><div class="meta"><div class="nm">${x.nm}</div><div class="mk">${x.mk}</div></div></div><div class="pr">Yours, or one day</div></div>`;
  return `<div class="piece" data-price="${x.price}"><button class="nav" data-piece="${i}"><div class="meta"><div class="nm">${x.nm}<span class="arrow">view &rarr;</span></div><div class="mk">${x.mk}</div></div></button>${x.sopt&&x.vars&&x.vars.length?sizeSel(x,i):''}<div class="pr">${fmt(x.price)}</div><button class="tog" data-tog="${i}" aria-label="Include"></button></div>`;}
function summaryHTML(p,complete,whole,cta,micro){
  return `<div class="summary"><div class="ledger"><span class="count2">${complete}</span><span class="set-flag">Set ${lfRate(p.pieces.length)}%</span></div><div class="total"><span class="lab">${whole}</span><span><span class="amt">${fmt(setp(p))}</span><span class="was" hidden>${fmt(sum(p))}</span></span></div><button class="cta">${cta}</button><p class="micro">${micro}</p></div>`;}
function renderPairing(p){
  lastPairing=p.id;let h;
  if(p.type==='figue'){
    h=`<div class="spread"><div class="imgcol">${carSlot(p,false)}</div><div class="info"><div class="kicker">Le Figue Pairing · ${p.name}</div><h2>${p.name}</h2><div class="origin">${p.makers}</div><p class="note">${p.note}</p><div class="pieces">${p.pieces.map((x,i)=>pieceRow(x,i,false)).join('')}</div>${summaryHTML(p,p.pieces.length+' pieces, complete','The pairing','Take the pairing','A pairing deepens as it grows — <em>7% for two pieces, 15% for three, 18% for four, 20% for five.</em>')}</div></div>`;
  }else{
    const dots=[0,1,2].map(i=>`<span class="dot ${i<p.affinity?'f':''}"></span>`).join('');
    const ev=p.affinity===3?'Pairs naturally':p.affinity===2?'Pairs well':'Pairs softly';
    h=`<div class="show-hero">${slot(p.ar,p.img)}<div class="veil"></div><div class="htxt"><div class="hov2">${p.house} · Icon Pairing</div><h2>${p.name}</h2></div></div><div class="show-lower"><div class="left"><div class="kicker">The Icon</div><div class="housenote"><div class="icon-name">${p.icon.nm}</div><div class="icon-house">${p.icon.house}</div><div class="hn">${p.hn}</div><div class="affinity"><span class="lab">House Note</span><span class="dots">${dots}</span><span class="ev">${ev}</span></div></div></div><div class="right"><div class="kicker">The Edit · by Le Figue</div><p class="note">${p.note}</p><div class="band-lbl"><span class="l">Yours already</span><span class="ln"></span></div><div class="pieces">${pieceRow(p.icon,-1,true)}</div><div class="band-lbl"><span class="l">The Edit</span><span class="ln"></span></div><div class="pieces">${p.pieces.map((x,i)=>pieceRow(x,i,false)).join('')}</div>${summaryHTML(p,'The edit, complete','The edit','Take the edit','The icon stays with you. We add only <em>the edit.</em>')}</div></div>`;
  }
  $('#pairing-body').innerHTML=h;
  const pk=$('#pairing-keep');pk.dataset.id=p.id;pk.classList.toggle('on',kept.has(p.id));
  wire(p);wireCars();go('pairing');
}
function wire(p){
  const scope=$('#pairing-body');const rows=[...scope.querySelectorAll('.piece:not(.fixed)')];
  const s=scope.querySelector('.summary');
  const amt=s.querySelector('.amt'),was=s.querySelector('.was'),flag=s.querySelector('.set-flag'),cnt=s.querySelector('.count2'),lab=s.querySelector('.total .lab'),cta=s.querySelector('.cta');
  const wC=cnt.textContent,wL=lab.textContent,wT=cta.textContent;
  function rc(){const on=rows.filter(r=>!r.classList.contains('off'));const t=on.reduce((a,r)=>a+(+r.dataset.price),0);const all=on.length===rows.length&&on.length>0;
    if(all){var fr=lfRate(on.length);amt.textContent=fmt(Math.round(t*(1-(fr/100))));if(fr>0){was.textContent=fmt(t);was.hidden=false;flag.textContent='Set '+fr+'%';flag.classList.add('show');}else{was.hidden=true;flag.classList.remove('show');}cnt.textContent=wC;lab.textContent=wL;cta.textContent=wT;}
    else if(on.length===0){amt.textContent=fmt(0);was.hidden=true;flag.classList.remove('show');cnt.textContent='Choose a piece to begin';lab.textContent='Nothing selected';cta.textContent='Select a piece';}
    else{var pr=lfRate(on.length);if(pr>0){amt.textContent=fmt(Math.round(t*(1-(pr/100))));was.textContent=fmt(t);was.hidden=false;flag.textContent='Set '+pr+'%';flag.classList.add('show');cnt.textContent=on.length+' of '+rows.length+' pieces';}else{amt.textContent=fmt(t);was.hidden=true;flag.classList.remove('show');cnt.textContent='One piece, no set';}lab.textContent=(on.length===1?'One piece':on.length+' pieces');cta.textContent=(on.length===1?'Add the piece':'Add selected');}}
  scope.querySelectorAll('.tog').forEach(b=>b.addEventListener('click',()=>{b.closest('.piece').classList.toggle('off');rc();}));
  scope.querySelectorAll('select[data-size]').forEach(function(s){s.addEventListener('change',function(){s.classList.remove('err');});});
  scope.querySelectorAll('.nav[data-piece]').forEach(b=>b.addEventListener('click',()=>{const x=p.pieces[+b.dataset.piece];if(x&&x.url){window.location.href=x.url;}else{renderProduct(p,+b.dataset.piece);}}));
  cta.addEventListener('click',function(){var on=rows.filter(function(r){return !r.classList.contains('off');});if(!on.length)return;var items=[];var missing=[];on.forEach(function(r){var b=r.querySelector('[data-piece]');var x=b?p.pieces[+b.dataset.piece]:null;if(!x)return;var vid=x.vid;if(x.sopt&&x.vars&&x.vars.length){var sel=r.querySelector('select[data-size]');if(sel&&sel.value){vid=sel.value;}else{missing.push(x.nm);if(sel)sel.classList.add('err');return;}}if(vid){items.push({id:vid,quantity:1});}});if(missing.length){alert('Please select a size for: '+missing.join(', '));return;}if(!items.length){alert('These pieces are not available to order online yet.');return;}var keep=cta.textContent;cta.disabled=true;cta.textContent='Adding\u2026';fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:items})}).then(function(r){if(!r.ok){return r.json().then(function(j){throw new Error(j&&j.description?j.description:'add failed');});}window.location.href='/cart';}).catch(function(e){cta.disabled=false;cta.textContent=keep;alert('Could not add to bag \u2014 '+(e&&e.message?e.message:'a piece may be sold out.'));});});
  rc();
}
let lastPairing=null;
function renderProduct(p,i){
  const x=p.pieces[i];const ar=x.ar||'4/5';
  const h=`<div class="product"><div class="imgcol">${slot(ar,x.img)}</div><div class="info"><div class="kicker">${x.mk}</div><h2>${x.nm}</h2><div class="price">${fmt(x.price)}</div><p class="desc">${x.d}</p><div class="spec"><div class="r"><span class="k">Category</span><span class="v">${x.cat}</span></div><div class="r"><span class="k">Material</span><span class="v">${x.m}</span></div><div class="r"><span class="k">Form</span><span class="v">${x.sz}</span></div><div class="r"><span class="k">Made</span><span class="v">By hand, in limited number</span></div></div><button class="addbag">Add to bag</button><button class="complete" data-back="${p.id}"><div class="c-ov">${PAGE==='icon'?'Part of the edit':'Part of a pairing'}</div><div class="c-row"><span class="c-nm">${p.name}</span><span class="c-pr">${fmt(setp(p))}<span class="set">Set ${lfRate(p.pieces.length)}%</span></span></div><div class="c-go">${PAGE==='icon'?'Take the whole edit':'Take the whole pairing'}<span class="arrow">&rarr;</span></div></button></div></div>`;
  $('#product-body').innerHTML=h;
  $('#product-back').textContent='\u2190  '+p.name;
  $('#product-body').querySelector('.complete').addEventListener('click',()=>{renderPairing(DATA.find(d=>d.id===lastPairing));});
  go('product');
}

/* ---------- nav ---------- */
function go(v){curView=v;['board','pairing','product','saved'].forEach(x=>$('#view-'+x).style.display=(x===v?'block':'none'));window.scrollTo({top:0});}

document.addEventListener('click',e=>{
  const keep=e.target.closest('[data-keep]');
  if(keep){e.preventDefault();e.stopPropagation();const host=keep.closest('[data-id]');if(host)toggleKeep(host.dataset.id);return;}
  const opener=e.target.closest('.tile,.card,.hero2');
  if(opener&&opener.dataset.id){renderPairing(DATA.find(d=>d.id===opener.dataset.id));return;}
  if(e.target.classList.contains('reset')){catF='All';brandF='All';syncChips();renderBoard();return;}
  if(e.target.classList.contains('browsebtn')){go('board');return;}
});
function syncChips(){
  document.querySelectorAll('[data-cat]').forEach(c=>c.classList.toggle('on',c.dataset.cat===catF));
  document.querySelectorAll('[data-brand]').forEach(c=>c.classList.toggle('on',c.dataset.brand===brandF));
}
$('.filterbar')&&$('.filterbar').addEventListener('click',e=>{
  const chip=e.target.closest('.chip');if(!chip)return;
  if('cat' in chip.dataset)catF=chip.dataset.cat;
  if('brand' in chip.dataset)brandF=chip.dataset.brand;
  syncChips();renderBoard();
});


$('#saved-btn').addEventListener('click',()=>{renderSaved();go('saved');});
$('#saved-back').addEventListener('click',()=>go('board'));
$('#pairing-back').addEventListener('click',()=>go('board'));
$('#all-pairings').addEventListener('click',()=>go('board'));
$('#product-back').addEventListener('click',()=>{const pp=DATA.find(d=>d.id===lastPairing);pp?renderPairing(pp):go('board');});
$('#pairing-back').textContent='\u2190  '+(PAGE==='icon'?'All icon pairings':'All Le Figue pairings');
$('#saved-back').textContent='\u2190  '+(PAGE==='icon'?'All icon pairings':'All Le Figue pairings');

updateBadge();
renderBoard();

/* dispatch subscribe */
const dc=$('#d-cta');
if(dc){dc.addEventListener('click',()=>{
  const inp=$('#d-email'); const v=inp.value.trim();
  if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(v)){inp.style.borderColor='#b4554d';return;}
  document.querySelector('.d-form').style.display='none'; $('#d-done').hidden=false;
});}
})();
{% endjavascript %}

