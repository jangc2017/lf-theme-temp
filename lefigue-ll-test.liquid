{%- comment -%}
  TEMP SPIKE — tests whether LoyaltyLion's custom SDK components (data-lion-points)
  render the logged-in customer's real data on a normal storefront page. If they
  show your real balance -> custom dashboard is feasible. If they show 0 / blank ->
  the custom components are plan-gated (Advanced) or the customer isn't authed on
  storefront pages. DELETE this section + /pages/ll-test after testing.
{%- endcomment -%}
<div class="lf-lltest" style="max-width:680px;margin:0 auto;padding:70px 30px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#2a2622;line-height:1.7">
  <h2 style="font-size:24px;margin-bottom:8px">LoyaltyLion SDK spike</h2>
  <p style="color:#6b635a;margin-bottom:24px">View this page <b>while logged in</b>. Below are LoyaltyLion's custom data mounts + a probe of the SDK state.</p>

  <div style="border:1px solid #e3dccd;padding:20px 22px;margin-bottom:18px">
    <p>Total points (<code>data-lion-points</code>): <b style="font-size:20px"><span data-lion-points></span></b></p>
    <p>Redeemable (<code>approved</code>): <b><span data-lion-points="approved"></span></b></p>
    <p>Lifetime: <b><span data-lion-points="lifetime"></span></b></p>
  </div>

  <div id="lltest-probe" style="border:1px solid #e3dccd;background:#f3eee4;padding:18px 22px;font-family:ui-monospace,Menlo,monospace;font-size:13px;white-space:pre-wrap">Probing SDK…</div>
</div>

<script>
  (function(){
    var out = document.getElementById('lltest-probe');
    function report(){
      var ll = window.loyaltylion;
      var lines = [];
      lines.push('window.loyaltylion present: ' + (!!ll));
      try {
        var cfg = ll && (ll._config || ll.config || {});
        lines.push('SDK configured: ' + (!!(ll && (ll._initialised || ll._loaded || cfg))));
        lines.push('customer in config: ' + (cfg && cfg.customer ? ('yes (id ' + (cfg.customer.id||'?') + ')') : 'no / not exposed'));
      } catch(e){ lines.push('probe error: ' + e.message); }
      var p = document.querySelector('[data-lion-points]');
      lines.push('data-lion-points rendered text: "' + (p ? p.textContent : 'element missing') + '"');
      lines.push('(empty or 0 = component not available on this plan OR not authed)');
      out.textContent = lines.join('\n');
    }
    // give the SDK time to load + hydrate the mounts
    setTimeout(report, 3500);
    if (window.loyaltylion && window.loyaltylion.on) {
      try { window.loyaltylion.on('load', function(){ setTimeout(report, 800); }); } catch(e){}
    }
  })();
</script>

{% schema %}
{ "name": "LL Test", "settings": [], "presets": [{ "name": "LL Test" }] }
{% endschema %}
