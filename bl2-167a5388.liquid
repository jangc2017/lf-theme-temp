{% comment %}
  LE FIGUE — Bleecker · NoHo location page (19 Bleecker Street)
  From le-figue-visit-bleecker.html. Theme header/footer wrap the page,
  so the design's own topbar/footer are stripped. GALLERY + West Village
  cross-promo photos are THEME-EDITOR image_picker settings (2026-07-07);
  placeholder art shows until a mod sets them.

  "Pre-opening mode" (theme-editor checkbox, default ON) shows the
  opening poster + opening-list signup and "From September" pickup
  tags. Untick it on opening day for the normal hero + live wording.
  The opening-list form is a REAL Shopify customer form — signups
  land in Customers tagged newsletter + bleecker-opening-list.
{% endcomment %}

{%- assign opening = section.settings.opening_mode -%}

<section class="lf-bl">

  {%- if opening -%}
  <div class="lf-bl-poster-wrap">
    <div class="poster"><div class="poster-in">
      <span class="corner tl">Le Figue</span><span class="corner tr">New York</span>
      <span class="corner bl">NoHo</span><span class="corner br">MMXXVI</span>
      <div class="ov">LE FIGUE · The House, Expanded</div>
      <div class="no">No. II</div>
      <h1>BLEECKER</h1>
      <div class="addr">19 Bleecker Street · New York</div>
      <div class="prule"></div>
      <div class="when">{{ section.settings.opening_when }}</div>
      <p class="line">The tray comes to a table.</p>
      <p class="sub">Private edits, custom pieces, and the long look.</p>
      {% form 'customer', class: 'p-form-outer' %}
        {%- if form.posted_successfully? -%}
          <p class="p-thanks">Thank you. You will hear from us first.</p>
        {%- else -%}
          <div class="p-form">
            <input type="hidden" name="contact[tags]" value="newsletter,bleecker-opening-list">
            <input type="email" name="contact[email]" placeholder="Your email" aria-label="Email" autocomplete="email" required>
            <button type="submit">Join the Opening List</button>
          </div>
          {%- if form.errors -%}<p class="p-err">Please enter a valid email address.</p>{%- endif -%}
        {%- endif -%}
      {% endform %}
      <p class="fine">The opening date, the first appointments, the opening evening. Nothing else.</p>
    </div></div>
  </div>
  {%- else -%}
  <div class="hero">
    <div class="crumbs"><a href="/pages/locations">Visit NYC</a> · Bleecker · NoHo</div>
    <span class="eyebrow">LE FIGUE · The House, Expanded</span>
    <h1>Bleecker · NoHo</h1>
    <div class="addr">19 Bleecker Street, New York</div>
    <p class="lead">The tray comes to a table. A room built for the long look, the private edit, and the pieces that deserve a chair.</p>
    <div class="rule"></div>
  </div>
  {%- endif -%}

  <div class="wrap">

    <div class="duo-cta">
      <div class="dc">
        <span class="rn">i</span>
        <h3>The Private Edit</h3>
        <p>A tray built around your note before you arrive. A chair, a drink, and enough quiet to try the third option you would not have asked for at a counter.</p>
        <p class="note">First appointments open with the door · Complimentary</p>
        <a class="btn" href="/pages/book-appointment">Book an Appointment</a>
      </div>
      <div class="dc">
        <span class="rn">ii</span>
        <h3>A Piece of Your Own</h3>
        <p>Custom and bespoke work with our designer June. From a first sketch over the table to a piece that exists nowhere else, in gold, silver, and stone.</p>
        <p class="note">By consultation · Begins with a conversation</p>
        <a class="btn gold" href="/pages/custom-bespoke">Begin a Custom Piece</a>
      </div>
    </div>

    <div class="gallery">
      <div class="g main">{% if section.settings.img_main %}<img src="{{ section.settings.img_main | image_url: width: 2000 }}" alt="The Bleecker room" loading="lazy">{% else %}<div class="ph"><span>The Bleecker room, morning light on a set table</span></div>{% endif %}</div>
      <div class="g sub">{% if section.settings.img_sub_1 %}<img src="{{ section.settings.img_sub_1 | image_url: width: 900 }}" alt="The appointment table" loading="lazy">{% else %}<div class="ph"><span>The appointment table, laid for two</span></div>{% endif %}</div>
      <div class="g sub">{% if section.settings.img_sub_2 %}<img src="{{ section.settings.img_sub_2 | image_url: width: 900 }}" alt="The gift room" loading="lazy">{% else %}<div class="ph"><span>The gift room, shelves in shadow</span></div>{% endif %}</div>
      <div class="g sub">{% if section.settings.img_sub_3 %}<img src="{{ section.settings.img_sub_3 | image_url: width: 900 }}" alt="The custom bench" loading="lazy">{% else %}<div class="ph"><span>The bench where custom pieces begin</span></div>{% endif %}</div>
    </div>
    <div class="g-cap">{% if opening %}The room, as it will be{% else %}The room{% endif %}</div>

    <div class="band">
      <div class="cell">
        <span class="eyebrow">Open Hours</span>
        <h3>When to Come</h3>
        <div class="hours">
          <div class="r today"><span class="d">Daily</span><span class="t">11 – 7</span></div>
        </div>
        {%- if opening -%}
        <p class="hours-note">Hours begin with the September opening and may settle in the first weeks.</p>
        {%- endif -%}
      </div>
      <div class="cell">
        <span class="eyebrow">Visit</span>
        <h3>Finding the Door</h3>
        <p><b>19 Bleecker Street</b><br>New York, NY 10012</p>
        <p class="mt12">Between Bowery and Lafayette, a short walk from the 6 at Bleecker Street and the B, D, F, M at Broadway–Lafayette.</p>
        <p class="mt12"><b>{{ section.settings.contact_email }}</b></p>
        <a class="linkline" href="https://maps.google.com/?q=19+Bleecker+Street+New+York+NY" target="_blank" rel="noopener">Get Directions</a>
      </div>
      <div class="cell">
        <span class="eyebrow">In This Room</span>
        <h3>What Changes Here</h3>
        <ul class="svc">
          <li>The private edit, a tray built before you arrive</li>
          <li>Custom and bespoke pieces with June</li>
          <li>The gift room, for presents that cannot be guessed</li>
          <li>Fine and demi fine, the long look at a table</li>
          <li>Boutique pickup, from opening week</li>
        </ul>
      </div>
    </div>

    <div class="mapsec">
      <div class="sec-head"><h2>On the Map</h2><span class="k">NoHo</span></div>
      <div class="map-grid">
        <div class="map-frame">
          <iframe title="LE FIGUE Bleecker map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps?q=19+Bleecker+Street,+New+York,+NY+10012&output=embed"></iframe>
        </div>
        <div class="map-note">
          <span class="eyebrow">The Neighborhood</span>
          <h4>NoHo, at a walk</h4>
          <p>Galleries a block in either direction, the gallery we keep returning to among them, and some of the best tables downtown within five minutes. The Bleecker edit of the neighborhood arrives with the opening.</p>
          <a class="btn ghost mt22" href="/pages/the-figue-edit">Read the Bleecker Edit</a>
        </div>
      </div>
    </div>

    <div class="pickup">
      <div class="sec-head"><h2>Ready at This Boutique</h2><span class="k">{% if opening %}Pickup Begins With the Door{% else %}Pickup · Usually Within 2 Hours{% endif %}</span></div>
      {%- assign pick_tag = 'Pickup Today' -%}
      {%- if opening -%}{%- assign pick_tag = 'From September' -%}{%- endif -%}
      <div class="pick-grid">
        <div class="pc">
          <div class="fr"><div class="ph"><span>F</span></div><span class="tag">{{ pick_tag }}</span></div>
          <div class="bc">LE FIGUE · Fine</div><div class="nm">Fine Diamond Line Band</div><div class="pr">$780</div>
        </div>
        <div class="pc">
          <div class="fr"><div class="ph"><span>B</span></div><span class="tag">{{ pick_tag }}</span></div>
          <div class="bc">Miliemoon · New York</div><div class="nm">The Bleecker Signet</div><div class="pr">$420</div>
        </div>
        <div class="pc">
          <div class="fr"><div class="ph"><span>S</span></div><span class="tag">{{ pick_tag }}</span></div>
          <div class="bc">Stilla · Milan</div><div class="nm">Sculptural Statement Cuff</div><div class="pr">$980</div>
        </div>
        <div class="pc">
          <div class="fr"><div class="ph"><span>O</span></div><span class="tag">{{ pick_tag }}</span></div>
          <div class="bc">LE FIGUE · Opening</div><div class="nm">Opening Pearl Drop</div><div class="pr">$430</div>
        </div>
      </div>
      <div class="pick-cta">
        <a class="btn" href="/collections/all">{% if opening %}Preview the Bleecker Pickup Edit{% else %}Shop Everything Ready at Bleecker{% endif %}</a>
        <p class="pick-line">{% if opening %}From opening week: order online, choose Bleecker at checkout, and it is wrapped when you arrive.{% else %}Order online, choose pickup at checkout, and we will have it wrapped when you arrive.{% endif %}</p>
      </div>
    </div>

    <div class="other">
      <div class="fr">{% if section.settings.img_westvillage %}<img src="{{ section.settings.img_westvillage | image_url: width: 1200 }}" alt="18 Christopher Street" loading="lazy">{% else %}<div class="ph"><span>18 Christopher Street, the quiet window</span></div>{% endif %}</div>
      <div>
        <span class="eyebrow">The First Door</span>
        <h3>West Village</h3>
        <p>Where LE FIGUE began, and open today. The full tray, same day pickup, and walk ins welcome every open hour at 18 Christopher Street.</p>
        <a class="btn ghost" href="/pages/west-village">Visit the West Village Page</a>
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
.lf-bl{--cream:#fdfbf6;--cream-deep:#f3eee4;--paper:#fffdf9;--ink:#2a2622;--ink-soft:#5b554d;--gold:#b8975f;--accent:#8a7250;--line:#e3dccd;--bl-sans:'Pretendard Variable',Pretendard,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--cream);color:var(--ink);font-family:var(--bl-sans);font-size:15px;line-height:1.75;padding-bottom:20px;}
.lf-bl a{color:inherit;text-decoration:none;}
.lf-bl .eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent);}
.lf-bl .wrap{max-width:1240px;margin:0 auto;padding:0 32px;}
.lf-bl .mt12{margin-top:12px;}
.lf-bl .mt22{margin-top:22px;}
.lf-bl-poster-wrap{padding:56px 32px 10px;max-width:1240px;margin:0 auto;}
.lf-bl .poster{border:1px solid var(--ink);padding:8px;}
.lf-bl .poster-in{border:1px solid var(--ink);text-align:center;padding:76px 28px 70px;position:relative;background:radial-gradient(130% 100% at 50% 0%, #fffdf8 0%, #faf6ec 60%, #f3ecdc 100%);}
.lf-bl .poster .ov{font-size:11px;letter-spacing:.5em;text-transform:uppercase;color:var(--accent);padding-left:.5em;}
.lf-bl .poster .no{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:19px;color:var(--gold);margin-top:22px;}
.lf-bl .poster h1{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:clamp(56px,9vw,110px);line-height:.98;letter-spacing:.04em;margin:8px 0 0;}
.lf-bl .poster .addr{font-size:12px;letter-spacing:.32em;text-transform:uppercase;color:var(--ink-soft);margin-top:22px;}
.lf-bl .poster .prule{width:56px;height:1px;background:var(--gold);margin:30px auto;}
.lf-bl .poster .when{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:clamp(22px,3vw,32px);letter-spacing:.14em;text-transform:uppercase;}
.lf-bl .poster .line{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:19px;color:var(--ink-soft);margin-top:16px;}
.lf-bl .poster .sub{font-size:12.5px;color:var(--ink-soft);margin-top:26px;}
.lf-bl .p-form{display:flex;max-width:400px;margin:22px auto 0;border-bottom:1px solid var(--ink);}
.lf-bl .p-form input[type="email"]{flex:1;border:none;background:none;font-size:14px;padding:12px 4px;outline:none;color:var(--ink);font-family:inherit;}
.lf-bl .p-form input::placeholder{color:#a89e90;}
.lf-bl .p-form button{border:none;background:none;font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;cursor:pointer;color:inherit;font-family:inherit;}
.lf-bl .p-form button:hover{color:var(--accent);}
.lf-bl .p-thanks{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:18px;color:var(--accent);margin-top:26px;}
.lf-bl .p-err{font-size:12px;color:#a05252;margin-top:10px;}
.lf-bl .poster .fine{font-size:11px;color:#a89e90;margin-top:14px;}
.lf-bl .corner{position:absolute;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13px;color:var(--gold);letter-spacing:.08em;}
.lf-bl .corner.tl{top:18px;left:24px;}.lf-bl .corner.tr{top:18px;right:24px;}
.lf-bl .corner.bl{bottom:16px;left:24px;}.lf-bl .corner.br{bottom:16px;right:24px;}
.lf-bl .hero{text-align:center;padding:78px 24px 50px;}
.lf-bl .hero .crumbs{font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:20px;}
.lf-bl .hero .crumbs a{color:var(--accent);}
.lf-bl .hero h1{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:clamp(42px,6vw,68px);line-height:1.04;margin:0;}
.lf-bl .hero .addr{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:20px;color:var(--gold);margin-top:14px;}
.lf-bl .hero .lead{max-width:520px;margin:18px auto 0;font-size:14.5px;color:var(--ink-soft);line-height:1.85;}
.lf-bl .hero .rule{width:44px;height:1px;background:var(--ink);margin:34px auto 0;}
.lf-bl .duo-cta{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:44px 0 60px;}
.lf-bl .dc{background:var(--paper);border:1px solid var(--line);padding:40px 38px 36px;display:flex;flex-direction:column;transition:border-color .3s;}
.lf-bl .dc:hover{border-color:var(--gold);}
.lf-bl .dc .rn{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:15px;color:var(--gold);letter-spacing:.08em;}
.lf-bl .dc h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:30px;margin:10px 0 10px;letter-spacing:.01em;}
.lf-bl .dc p{font-size:13.5px;color:var(--ink-soft);line-height:1.9;max-width:400px;margin:0;}
.lf-bl .dc .note{font-size:11.5px;color:var(--accent);margin-top:14px;letter-spacing:.04em;}
.lf-bl .dc .btn{margin-top:26px;align-self:flex-start;}
.lf-bl .gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:26px;}
.lf-bl .g{position:relative;overflow:hidden;background:var(--cream-deep);}
.lf-bl .g.main{grid-column:1/-1;aspect-ratio:21/9;}
.lf-bl .g.sub{aspect-ratio:4/5;}
.lf-bl .g img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.lf-bl .ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;text-align:center;padding:0 20px;background:radial-gradient(120% 90% at 30% 18%, #fbf8f2 0%, #f0e8da 55%, #e7ddca 100%);}
.lf-bl .ph::after{content:"";position:absolute;inset:0;background:repeating-linear-gradient(135deg, rgba(138,114,80,.04) 0 2px, transparent 2px 9px);}
.lf-bl .ph span{position:relative;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:14px;color:#a2917a;line-height:1.5;}
.lf-bl .g-cap{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft);text-align:right;margin:-12px 2px 0;}
.lf-bl .band{border-top:1px solid var(--ink);border-bottom:1px solid var(--line);margin-top:56px;display:grid;grid-template-columns:1fr 1fr 1fr;}
.lf-bl .cell{padding:38px 34px 42px;border-right:1px solid var(--line);}
.lf-bl .cell:last-child{border-right:none;}
.lf-bl .cell h3{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:22px;letter-spacing:.04em;margin:10px 0 18px;}
.lf-bl .hours{width:100%;font-size:13.5px;color:var(--ink-soft);}
.lf-bl .hours .r{display:flex;justify-content:space-between;padding:7px 0;}
.lf-bl .hours .d{color:var(--ink);}
.lf-bl .hours .today .d,.lf-bl .hours .today .t{color:var(--accent);font-weight:500;}
.lf-bl .hours-note{font-size:11.5px;color:var(--accent);margin-top:14px;letter-spacing:.03em;}
.lf-bl .cell p{font-size:13.5px;color:var(--ink-soft);line-height:1.9;margin:0;}
.lf-bl .cell p b{color:var(--ink);font-weight:500;}
.lf-bl .linkline{display:inline-block;margin-top:14px;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink);border-bottom:1px solid var(--gold);padding-bottom:3px;}
.lf-bl .svc{list-style:none;font-size:13.5px;color:var(--ink-soft);margin:0;padding:0;}
.lf-bl .svc li{padding:7px 0 7px 20px;position:relative;border-bottom:1px dotted var(--line);}
.lf-bl .svc li:last-child{border-bottom:none;}
.lf-bl .svc li::before{content:"";position:absolute;left:2px;top:17px;width:8px;height:1px;background:var(--gold);}
.lf-bl .mapsec{margin-top:64px;}
.lf-bl .sec-head{display:flex;align-items:baseline;gap:16px;border-bottom:1px solid var(--ink);padding-bottom:14px;margin-bottom:28px;}
.lf-bl .sec-head h2{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:30px;margin:0;}
.lf-bl .sec-head .k{margin-left:auto;font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);}
.lf-bl .map-grid{display:grid;grid-template-columns:2fr 1fr;gap:14px;}
.lf-bl .map-frame{aspect-ratio:16/8;border:1px solid var(--line);overflow:hidden;background:var(--cream-deep);}
.lf-bl .map-frame iframe{width:100%;height:100%;border:0;filter:sepia(.18) saturate(.82);}
.lf-bl .map-note{background:var(--paper);border:1px solid var(--line);padding:30px 30px 26px;display:flex;flex-direction:column;}
.lf-bl .map-note h4{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:20px;margin:8px 0 12px;}
.lf-bl .map-note p{font-size:13.5px;color:var(--ink-soft);line-height:1.9;margin:0;}
.lf-bl .pickup{margin-top:72px;}
.lf-bl .pick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px;}
.lf-bl .pc{display:block;}
.lf-bl .pc .fr{position:relative;aspect-ratio:4/5;overflow:hidden;background:var(--cream-deep);margin-bottom:12px;}
.lf-bl .pc .fr .ph span{font-size:26px;font-style:normal;color:rgba(138,114,80,.32);}
.lf-bl .pc .tag{position:absolute;bottom:12px;left:12px;z-index:2;font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;background:rgba(253,251,246,.92);color:var(--accent);padding:5px 9px;}
.lf-bl .pc .bc{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);}
.lf-bl .pc .nm{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:600;margin-top:4px;line-height:1.25;}
.lf-bl .pc .pr{font-size:13px;color:var(--ink-soft);margin-top:4px;}
.lf-bl .pick-cta{text-align:center;margin-top:38px;}
.lf-bl .pick-line{font-size:12px;color:var(--ink-soft);margin-top:14px;}
.lf-bl .btn{display:inline-block;text-align:center;background:var(--ink);color:var(--cream);border:none;font-size:11.5px;letter-spacing:.22em;text-transform:uppercase;padding:16px 40px;transition:background .25s;cursor:pointer;}
.lf-bl .btn:hover{background:var(--accent);color:var(--cream);}
.lf-bl .btn.ghost{background:transparent;color:var(--ink);border:1px solid var(--ink);}
.lf-bl .btn.ghost:hover{border-color:var(--accent);color:var(--accent);background:transparent;}
.lf-bl .btn.gold{background:#e3d6bf;color:var(--ink);}
.lf-bl .btn.gold:hover{background:#d6c6a8;color:var(--ink);}
.lf-bl .other{margin-top:84px;border-top:1px solid var(--line);padding:54px 0 70px;display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center;}
.lf-bl .other .fr{position:relative;aspect-ratio:16/10;overflow:hidden;background:var(--cream-deep);}
.lf-bl .other .fr img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.lf-bl .other h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:32px;margin:12px 0 8px;}
.lf-bl .other p{font-size:14px;color:var(--ink-soft);max-width:420px;line-height:1.9;margin:0;}
.lf-bl .other .btn{margin-top:22px;}
@media(max-width:920px){
  .lf-bl .duo-cta{grid-template-columns:1fr;}
  .lf-bl .band{grid-template-columns:1fr;}
  .lf-bl .cell{border-right:none;border-bottom:1px solid var(--line);}
  .lf-bl .map-grid{grid-template-columns:1fr;}
  .lf-bl .pick-grid{grid-template-columns:1fr 1fr;gap:20px 14px;}
  .lf-bl .other{grid-template-columns:1fr;gap:24px;}
}
@media(max-width:560px){
  .lf-bl .wrap,.lf-bl-poster-wrap{padding-left:20px;padding-right:20px;}
  .lf-bl .poster-in{padding:54px 18px 50px;}
  .lf-bl .corner{display:none;}
  .lf-bl .gallery{grid-template-columns:1fr;}
  .lf-bl .g.sub{aspect-ratio:16/10;}
  .lf-bl .pick-grid{grid-template-columns:1fr;}
}
{% endstylesheet %}

{% schema %}
{
  "name": "LF Bleecker · NoHo",
  "settings": [
    { "type": "checkbox", "id": "opening_mode", "label": "Pre-opening mode", "default": true, "info": "ON: opening poster + opening-list signup + 'From September' pickup wording. Untick on opening day for the normal hero and live pickup wording." },
    { "type": "text", "id": "opening_when", "label": "Opening line (poster)", "default": "Opening September 2026" },
    { "type": "text", "id": "contact_email", "label": "Contact email shown on page", "default": "bleecker@lefigue.com" },
    { "type": "header", "content": "Photos (placeholder art shows until set)" },
    { "type": "image_picker", "id": "img_main", "label": "Gallery — wide room photo" },
    { "type": "image_picker", "id": "img_sub_1", "label": "Gallery photo 2 (appointment table)" },
    { "type": "image_picker", "id": "img_sub_2", "label": "Gallery photo 3 (gift room)" },
    { "type": "image_picker", "id": "img_sub_3", "label": "Gallery photo 4 (custom bench)" },
    { "type": "image_picker", "id": "img_westvillage", "label": "West Village cross-promo photo" }
