{%- comment -%}
  LE FIGUE — shared Pre-Order payload. Source of truth = manual collection "pre-order";
  product metafields custom.preorder_* drive state/dates/labels. Rendered by
  sections/lefigue-preorder.liquid and lefigue-preorder-detail.liquid.
  Dates emit as ISO-8601 (offset without colon, e.g. -0400) — page JS normalizes.
{%- endcomment -%}
{%- assign lf_po = collections['pre-order'] -%}
<script type="application/json" data-lf-preorder>
[
{%- assign lf_emitted = 0 -%}
{%- for p in lf_po.products -%}
  {%- if lf_emitted > 0 -%},{%- endif -%}
  {"handle": {{ p.handle | json }},
   "title": {{ p.title | json }},
   "brand": {{ p.vendor | json }},
   "price": {{ p.price | divided_by: 100.0 | json }},
   "img": {% if p.featured_image %}{{ p.featured_image | image_url: width: 900 | json }}{% else %}null{% endif %},
   "variant": {{ p.selected_or_first_available_variant.id | json }},
   "url": {{ p.url | json }},
   "open_at": {% assign lf_oa = p.metafields.custom.preorder_open_at.value | date: '%Y-%m-%dT%H:%M:%S%z' %}{% if lf_oa != blank %}{{ lf_oa | json }}{% else %}null{% endif %},
   "close_at": {% assign lf_ca = p.metafields.custom.preorder_close_at.value | date: '%Y-%m-%dT%H:%M:%S%z' %}{% if lf_ca != blank %}{{ lf_ca | json }}{% else %}null{% endif %},
   "limited": {% if p.metafields.custom.preorder_limited.value %}true{% else %}false{% endif %},
   "ships": {{ p.metafields.custom.preorder_ships.value | json }},
   "note": {{ p.metafields.custom.preorder_note.value | json }},
   "material": {{ p.metafields.custom.material.value | json }},
   "form": {{ p.metafields.custom.form.value | json }},
   "desc": {{ p.description | strip_html | truncate: 600 | json }},
   "maker_handle": {% assign lf_mh = '' %}{% for c in p.collections %}{% if c.title == p.vendor and c.metafields.custom.designer_page.value %}{% assign lf_mh = c.handle %}{% endif %}{% endfor %}{% if lf_mh != '' %}{{ lf_mh | json }}{% else %}null{% endif %}}
  {%- assign lf_emitted = lf_emitted | plus: 1 -%}
{%- endfor -%}
]
</script>
