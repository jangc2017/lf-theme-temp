{%- comment -%}
  LE FIGUE — Contact Us (Client Services). Ported from the provided design;
  theme header/footer wrap it. CSS+ids namespaced .lf-contact / #lfc-*.
  SUBMISSION (since 2026-07-05): posts to the Basin form backend — endpoint
  https://usebasin.com/f/1b1bfa2d0910 (the form's `action`) — which emails the
  submission INCLUDING the attached photo/PDF to care@lefigue.com (destination
  configured in the Basin dashboard, not here). This replaced the native
  Shopify contact form tag (no attachments, single store email only). Submit is
  AJAX so the branded confirmation modal still shows; without JS the form posts
  to Basin's hosted success page. The design's photo dropzone is RESTORED and
  also accepts PDF (≤10MB); the "photo link" field remains as an alternative.
  Topic selection stays REQUIRED (JS-enforced). Honeypot: hidden `_gotcha`.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css">

<div class="lf-contact">
  <section class="pt-hero">
    <div class="eyebrow">Client Services · We're here to help</div>
    <h1 class="display">We're listening.</h1>
    <p>However we can help, we'd love to hear from you. Choose what your message is about and we'll send it straight to the right person on our team. We read everything ourselves, and we'll always write back.</p>
  </section>

  <div class="pt-wrap">
    <aside class="pt-rail">
      <div class="rail-block">
        <h3>Before you write</h3>
        <p style="margin-bottom:10px;">Many questions are answered in our help pages — shipping times, our returns window, ring sizing, and how to care for each material.</p>
        <ul class="rail-list">
          <li>Order status &amp; tracking</li>
          <li>Returns &amp; exchanges policy</li>
          <li>Sizing &amp; material care</li>
          <li>Shipping &amp; delivery</li>
        </ul>
      </div>
      <div class="rail-block">
        <h3>When you'll hear back</h3>
        <p style="margin-bottom:10px;">We reply to every message, usually within 1 to 2 business days.</p>
        <p>Our client services hours are Monday to Friday, 10am to 6pm ET. Messages sent over the weekend are answered the next business day.</p>
      </div>
      <div class="rail-block">
        <h3>Other ways to reach us</h3>
        <div class="method">
          <span class="ml">Email</span>
          <span class="mv"><a href="mailto:care@lefigue.com">care@lefigue.com</a></span>
        </div>
        <div class="method">
          <span class="ml">Visit · Bleecker · NoHo</span>
          <span class="mh">19 Bleecker Street, New York</span>
        </div>
        <div class="method">
          <span class="ml">Visit · West Village</span>
          <span class="mh">18 Christopher Street, New York</span>
        </div>
      </div>
    </aside>

    <form id="lfc-form" class="pt-form" action="https://usebasin.com/f/1b1bfa2d0910" method="POST" enctype="multipart/form-data" novalidate>
      <div class="lfc-error" id="lfc-error" hidden></div>

      <div class="fsec">
        <div class="fsec-h"><span class="n">01</span>You</div>
        <div class="two">
          <div class="field"><label>Your name <span class="req">*</span></label><input type="text" name="Name" required placeholder="First and last name"></div>
          <div class="field"><label>Email <span class="req">*</span></label><input type="email" name="email" required placeholder="you@email.com"></div>
        </div>
        <label class="consent"><input type="checkbox" data-lfc-consent><span>I'd like to receive a reply by email, and I'm happy for LE FIGUE to keep this message on file to help with my request.</span></label>
      </div>

      <div class="fsec">
        <div class="fsec-h"><span class="n">02</span>What's this about?</div>
        <div class="field" style="margin-bottom:0;">
          <span class="qlabel">Choose a topic <span class="req">*</span></span>
          <div class="topics" id="lfc-topics">
            <button type="button" class="topic" data-team="Orders team" data-note="order number and the email used at checkout">
              <span class="tt">Order &amp; Tracking</span>
              <span class="td">Where is my order, changes, or cancellation</span>
            </button>
            <button type="button" class="topic" data-team="Returns team" data-note="order number and which pieces you'd like to return or exchange">
              <span class="tt">Returns &amp; Exchanges</span>
              <span class="td">Start a return, exchange, or refund</span>
            </button>
            <button type="button" class="topic" data-team="Care team" data-note="order number if you have one, and a photo of the piece">
              <span class="tt">Repairs &amp; Care</span>
              <span class="td">Resizing, repairs, warranty, looking after a piece</span>
            </button>
            <button type="button" class="topic" data-team="The studio" data-note="the piece or designer you're asking about">
              <span class="tt">Product &amp; Materials</span>
              <span class="td">Sizing, materials, availability, a specific piece</span>
            </button>
            <button type="button" class="topic" data-team="The edit team" data-note="the occasion, and any pieces you already have in mind">
              <span class="tt">Styling &amp; Appointments</span>
              <span class="td">Book a styling visit or ask for guidance</span>
            </button>
            <button type="button" class="topic" data-team="Concierge" data-note="any gift card number or order reference you have">
              <span class="tt">Gifts &amp; Gift Cards</span>
              <span class="td">Gifting help, gift notes, gift card questions</span>
            </button>
            <button type="button" class="topic" data-team="Press" data-note="a short line about your publication or feature">
              <span class="tt">Press</span>
              <span class="td">Media and editorial enquiries</span>
            </button>
            <button type="button" class="topic" data-team="Client services" data-note="as much detail as you can so we can point you the right way">
              <span class="tt">Something Else</span>
              <span class="td">Anything not listed above</span>
            </button>
          </div>
          <div class="routed" id="lfc-routed">
            <span class="rdot"></span>
            <span class="rtxt">This will go to <span class="rteam" id="lfc-routedTeam">our team</span>. <span id="lfc-routedHint"></span></span>
          </div>
        </div>
      </div>

      <div class="fsec">
        <div class="fsec-h"><span class="n">03</span>Your message</div>
        <div class="field"><label>Subject <span class="opt">· optional</span></label><input type="text" name="Subject" placeholder="A few words about your message"></div>
        <div class="field"><label>Order number <span class="opt">· if it's about an order</span></label><input type="text" name="Order number" placeholder="e.g. LF10342"></div>
        <div class="field"><label>How can we help? <span class="req">*</span></label><textarea name="Message" rows="5" required placeholder="Tell us what you need. The more detail you share, the faster we can help."></textarea></div>

        <div class="field">
          <span class="qlabel">Attach a photo or PDF <span class="opt">· optional · up to 10&nbsp;MB</span></span>
          <input type="file" name="Attachment" id="lfc-file" accept="application/pdf,.pdf,image/*" hidden>
          <div class="drop" id="lfc-drop" role="button" tabindex="0" aria-label="Attach a photo or PDF">
            <div class="d1">Drop a file here, or click to browse</div>
            <div class="d2">A photo of the piece, or a PDF document</div>
          </div>
          <div class="dropfile" id="lfc-dropfile" hidden>
            <span class="fn" id="lfc-filename"></span>
            <button type="button" class="fx" id="lfc-fileremove" aria-label="Remove file">&times;</button>
          </div>
        </div>

        <div class="field" style="margin-bottom:0;"><label>Or a link to a photo <span class="opt">· optional · Drive, Dropbox, or image URL</span></label><input type="text" name="Photo link" placeholder="https://"></div>
      </div>

      <input type="hidden" name="Topic" value="" data-lfc-h="topic">
      <input type="hidden" name="Routed to" value="" data-lfc-h="team">
      <input type="hidden" name="Reply consent" value="No" data-lfc-h="consent">
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" aria-hidden="true">

      <div class="submitrow">
        <button type="submit" class="submit" id="lfc-submit">Send message</button>
        <div class="submitnote">Your message goes straight to the right person on our team. We reply to everyone.</div>
      </div>

      <!-- CONFIRMATION (opened by JS on successful submit) -->
      <div class="scrim" id="lfc-scrim"><div class="confirm">
        <div class="seal">✓</div>
        <h3 class="display">Thank you — your message is on its way.</h3>
        <p class="sub">We've received it, and it's with the right person on our team.</p>
        <div class="expect"><b>What happens next.</b> We read every message ourselves and reply within 1 to 2 business days, Monday to Friday. If you sent us an order number, that helps us find everything quickly. Keep an eye on your inbox, and do check your spam folder just in case.</div>
        <button type="button" class="cbtn" id="lfc-closeConfirm">Done</button>
      </div></div>
    </form>
  </div>
</div>

{% stylesheet %}
  .lf-contact{ --ink:#2a2622; --ink-soft:#6b635a; --line:#e3dccf; --line-soft:#efe9dd; --cream:#faf7f1; --cream-deep:#f3ede1; --accent:#8a7250; --gold:#b8975f; --paper:#fdfbf6;
    background:var(--cream); color:var(--ink); font-family:'Pretendard Variable','Pretendard',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-weight:400; line-height:1.7; -webkit-font-smoothing:antialiased; }
  .lf-contact *{ box-sizing:border-box; }
  .lf-contact a{ color:inherit; text-decoration:none; }
  .lf-contact .display{ font-family:'Cormorant Garamond',serif; }

  .lf-contact .pt-hero{ max-width:1280px; margin:0 auto; padding:64px 30px 30px; }
  .lf-contact .pt-hero .eyebrow{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--accent); font-size:17px; }
  .lf-contact .pt-hero h1{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(42px,7vw,84px); line-height:1.0; letter-spacing:-.01em; margin:10px 0 16px; }
  .lf-contact .pt-hero p{ font-size:15.5px; color:var(--ink-soft); max-width:580px; }

  .lf-contact .pt-wrap{ max-width:1280px; margin:0 auto; padding:26px 30px 72px; display:grid; grid-template-columns:360px 1fr; gap:64px; align-items:start; }
  .lf-contact .pt-rail{ position:sticky; top:24px; }
  .lf-contact .rail-block{ padding:22px 0; border-top:1px solid var(--line); }
  .lf-contact .rail-block:first-child{ border-top:none; padding-top:0; }
  .lf-contact .rail-block h3{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:18px; color:var(--gold); margin-bottom:12px; }
  .lf-contact .rail-block p{ font-size:13.5px; color:var(--ink-soft); }
  .lf-contact .rail-list{ list-style:none; display:flex; flex-direction:column; gap:9px; }
  .lf-contact .rail-list li{ font-size:13.5px; color:var(--ink-soft); padding-left:18px; position:relative; line-height:1.55; }
  .lf-contact .rail-list li::before{ content:"—"; position:absolute; left:0; color:var(--accent); }
  .lf-contact .method{ display:flex; flex-direction:column; gap:2px; margin-bottom:14px; }
  .lf-contact .method:last-child{ margin-bottom:0; }
  .lf-contact .method .ml{ font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-soft); }
  .lf-contact .method .mv{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:16px; color:var(--ink); }
  .lf-contact .method .mv a{ border-bottom:1px solid var(--accent); }
  .lf-contact .method .mh{ font-size:12px; color:var(--ink-soft); }

  .lf-contact .pt-form{ background:var(--paper); border:1px solid var(--line); padding:40px 42px 36px; box-shadow:0 30px 60px -42px rgba(42,38,34,.4); }
  .lf-contact .fsec{ border-top:1px solid var(--line-soft); padding-top:24px; margin-top:26px; }
  .lf-contact .fsec:first-child{ border-top:none; margin-top:0; padding-top:0; }
  .lf-contact .fsec-h{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:22px; margin-bottom:18px; }
  .lf-contact .fsec-h .n{ font-style:italic; color:var(--gold); font-size:15px; margin-right:8px; }
  .lf-contact .field{ margin-bottom:18px; }
  .lf-contact .field>label,.lf-contact .qlabel{ display:block; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:8px; }
  .lf-contact .req{ color:var(--accent); }
  .lf-contact .opt{ text-transform:none; letter-spacing:0; color:#bcae93; font-style:italic; }
  .lf-contact .field input,.lf-contact .field textarea{ width:100%; border:1px solid var(--line); background:var(--cream); padding:12px 14px; font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:14px; color:var(--ink); outline:none; transition:border-color .18s; }
  .lf-contact .field input:focus,.lf-contact .field textarea:focus{ border-color:var(--accent); }
  .lf-contact .field input::placeholder,.lf-contact .field textarea::placeholder{ color:#bcb09a; }
  .lf-contact .two{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }

  .lf-contact .topics{ display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .lf-contact .topic{ text-align:left; border:1px solid var(--line); background:var(--cream); padding:14px 16px; cursor:pointer; transition:.16s; display:flex; flex-direction:column; gap:3px; }
  .lf-contact .topic:hover{ border-color:var(--accent); background:#fffdf8; }
  .lf-contact .topic.on{ border-color:var(--accent); background:#fffdf8; box-shadow:inset 0 0 0 1px var(--accent); }
  .lf-contact .topic .tt{ font-family:'Cormorant Garamond',serif; font-size:18px; color:var(--ink); line-height:1.2; }
  .lf-contact .topic .td{ font-size:11.5px; color:var(--ink-soft); line-height:1.45; }
  .lf-contact .topic.on .tt{ color:var(--accent); }

  .lf-contact .routed{ margin-top:16px; border:1px solid var(--line); background:var(--cream-deep); padding:14px 16px; display:none; align-items:flex-start; gap:12px; }
  .lf-contact .routed.show{ display:flex; }
  .lf-contact .routed .rdot{ width:8px; height:8px; border-radius:50%; background:var(--accent); margin-top:6px; flex-shrink:0; }
  .lf-contact .routed .rtxt{ font-size:13px; color:var(--ink-soft); line-height:1.6; }
  .lf-contact .routed .rtxt b{ color:var(--ink); font-weight:500; }
  .lf-contact .routed .rteam{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--accent); font-size:15px; }

  /* attachment dropzone */
  .lf-contact .drop{ border:1px dashed var(--line); background:var(--cream); padding:24px 18px; text-align:center; cursor:pointer; transition:.18s; }
  .lf-contact .drop:hover,.lf-contact .drop.over,.lf-contact .drop:focus-visible{ border-color:var(--accent); outline:none; }
  .lf-contact .drop .d1{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15.5px; color:var(--ink); }
  .lf-contact .drop .d2{ font-size:11.5px; color:var(--ink-soft); margin-top:4px; letter-spacing:.02em; }
  .lf-contact .dropfile{ display:flex; align-items:center; justify-content:space-between; gap:12px; border:1px solid var(--line); background:var(--cream); padding:11px 14px; font-size:13px; color:var(--ink); margin-top:10px; }
  .lf-contact .dropfile[hidden]{ display:none; }
  .lf-contact .dropfile .fn{ overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .lf-contact .dropfile .fx{ background:none; border:none; cursor:pointer; color:var(--ink-soft); font-family:'Cormorant Garamond',serif; font-size:20px; line-height:1; padding:0 2px; }
  .lf-contact .dropfile .fx:hover{ color:var(--ink); }

  .lf-contact .consent{ display:flex; gap:10px; align-items:flex-start; margin-top:8px; font-size:12.5px; color:var(--ink-soft); }
  .lf-contact .consent input{ appearance:none; -webkit-appearance:none; margin:2px 0 0; flex-shrink:0; width:20px; height:20px; border-radius:50%; border:1px solid var(--line); background:var(--paper); cursor:pointer; position:relative; transition:.18s; }
  .lf-contact .consent input:checked{ background:var(--accent); border-color:var(--accent); }
  .lf-contact .consent input:checked::after{ content:""; position:absolute; left:50%; top:50%; width:5px; height:9px; border:2px solid #fff; border-top:none; border-left:none; transform:translate(-50%,-60%) rotate(45deg); }

  .lf-contact .submitrow{ margin-top:30px; display:flex; align-items:center; gap:20px; flex-wrap:wrap; }
  .lf-contact .submit{ background:var(--ink); color:#f4eee2; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:17px; padding:15px 38px; border:none; cursor:pointer; transition:.2s; }
  .lf-contact .submit:hover{ background:var(--accent); }
  .lf-contact .submit:disabled{ opacity:.55; cursor:default; }
  .lf-contact .submitnote{ font-size:12px; color:var(--ink-soft); max-width:320px; line-height:1.5; }
  .lf-contact .lfc-error{ border:1px solid #c0392b; color:#c0392b; background:#fbeeec; padding:12px 14px; margin-bottom:18px; font-size:13px; }
  .lf-contact .lfc-error[hidden]{ display:none; }

  .lf-contact .scrim{ position:fixed; inset:0; background:rgba(33,29,25,.5); z-index:1000; display:none; align-items:flex-start; justify-content:center; padding:48px 20px; overflow-y:auto; }
  .lf-contact .scrim.open{ display:flex; }
  .lf-contact .confirm{ background:var(--paper); max-width:520px; width:100%; margin:auto; border:1px solid var(--line); box-shadow:0 40px 80px -30px rgba(0,0,0,.5); padding:40px 38px 32px; }
  .lf-contact .confirm .seal{ width:48px; height:48px; border:1px solid var(--accent); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--accent); font-size:22px; margin-bottom:20px; }
  .lf-contact .confirm h3{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:28px; margin-bottom:8px; }
  .lf-contact .confirm .sub{ font-size:14px; color:var(--ink-soft); margin-bottom:22px; }
  .lf-contact .confirm .expect{ font-size:13px; color:var(--ink-soft); line-height:1.7; border:1px solid var(--line); background:var(--cream); padding:16px 18px; margin-bottom:22px; }
  .lf-contact .confirm .expect b{ color:var(--ink); font-weight:500; }
  .lf-contact .cbtn{ width:100%; text-align:center; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; padding:13px; border:1px solid var(--accent); color:#f7f1e6; background:var(--accent); cursor:pointer; transition:.18s; }
  .lf-contact .cbtn:hover{ background:var(--ink); border-color:var(--ink); }

  @media(max-width:980px){
    .lf-contact .pt-wrap{ grid-template-columns:1fr; gap:30px; }
    .lf-contact .pt-rail{ position:static; order:2; }
    .lf-contact .pt-form{ order:1; padding:30px 24px 28px; }
  }
  @media(max-width:560px){ .lf-contact .two{ grid-template-columns:1fr; } .lf-contact .topics{ grid-template-columns:1fr; } }
{% endstylesheet %}

{% javascript %}
  (function () {
    var root = document.querySelector('.lf-contact');
    if (!root) return;

    var topics = root.querySelector('#lfc-topics');
    var routed = root.querySelector('#lfc-routed');
    var routedTeam = root.querySelector('#lfc-routedTeam');
    var routedHint = root.querySelector('#lfc-routedHint');
    var topicH = root.querySelector('[data-lfc-h="topic"]');
    var teamH = root.querySelector('[data-lfc-h="team"]');
    var consentH = root.querySelector('[data-lfc-h="consent"]');
    var consentBox = root.querySelector('[data-lfc-consent]');
    var form = root.querySelector('#lfc-form');
    var submitBtn = root.querySelector('#lfc-submit');
    var errBox = root.querySelector('#lfc-error');

    function showError(msg) {
      if (!errBox) return;
      errBox.textContent = msg;
      errBox.hidden = false;
      errBox.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
    function clearError() { if (errBox) { errBox.hidden = true; errBox.textContent = ''; } }

    if (topics) {
      topics.addEventListener('click', function (e) {
        var b = e.target.closest('.topic'); if (!b || !topics.contains(b)) return;
        topics.querySelectorAll('.topic').forEach(function (t) { t.classList.remove('on'); });
        b.classList.add('on');
        var label = b.querySelector('.tt').textContent.trim();
        if (topicH) topicH.value = label;
        if (teamH) teamH.value = b.dataset.team || '';
        if (routedTeam) routedTeam.textContent = b.dataset.team || 'our team';
        var note = b.dataset.note;
        if (routedHint) routedHint.textContent = note ? ('It helps to include your ' + note + '.') : '';
        if (routed) routed.classList.add('show');
      });
    }

    // ---- attachment dropzone (photo or PDF) ----
    var MAX_MB = 10;
    var fileInput = root.querySelector('#lfc-file');
    var drop = root.querySelector('#lfc-drop');
    var dropfile = root.querySelector('#lfc-dropfile');
    var filename = root.querySelector('#lfc-filename');
    var fileremove = root.querySelector('#lfc-fileremove');

    function fmtSize(bytes) {
      return bytes >= 1048576 ? (bytes / 1048576).toFixed(1) + ' MB' : Math.max(1, Math.round(bytes / 1024)) + ' KB';
    }
    function validFile(f) {
      var ok = f.type === 'application/pdf' || /\.pdf$/i.test(f.name) || /^image\//.test(f.type);
      if (!ok) { showError('Please attach a photo (JPG, PNG, HEIC) or a PDF.'); return false; }
      if (f.size > MAX_MB * 1048576) { showError('That file is over ' + MAX_MB + ' MB. Please attach a smaller file, or paste a link instead.'); return false; }
      return true;
    }
    function setFile(f) {
      clearError();
      if (!validFile(f)) { fileInput.value = ''; return; }
      if (fileInput.files.length === 0 || fileInput.files[0] !== f) {
        try {
          var dt = new DataTransfer();
          dt.items.add(f);
          fileInput.files = dt.files;
        } catch (e) { /* very old browsers: click-to-browse still works */ }
      }
      filename.textContent = f.name + ' · ' + fmtSize(f.size);
      dropfile.hidden = false;
      drop.style.display = 'none';
    }
    function clearFile() {
      if (!fileInput) return;
      fileInput.value = '';
      dropfile.hidden = true;
      drop.style.display = '';
    }
    if (drop && fileInput) {
      drop.addEventListener('click', function () { fileInput.click(); });
      drop.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); } });
      fileInput.addEventListener('change', function () { if (fileInput.files[0]) setFile(fileInput.files[0]); });
      ['dragover', 'dragenter'].forEach(function (ev) {
        drop.addEventListener(ev, function (e) { e.preventDefault(); drop.classList.add('over'); });
      });
      ['dragleave', 'drop'].forEach(function (ev) {
        drop.addEventListener(ev, function (e) { e.preventDefault(); drop.classList.remove('over'); });
      });
      drop.addEventListener('drop', function (e) {
        var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
        if (f) setFile(f);
      });
      fileremove.addEventListener('click', clearFile);
    }

    // ---- AJAX submit to Basin (keeps the branded confirmation modal) ----
    var scrim = root.querySelector('#lfc-scrim');
    function openConfirm() { if (scrim) scrim.classList.add('open'); }
    function resetForm() {
      form.reset();
      if (topics) topics.querySelectorAll('.topic').forEach(function (t) { t.classList.remove('on'); });
      if (topicH) topicH.value = '';
      if (teamH) teamH.value = '';
      if (consentH) consentH.value = 'No';
      if (routed) routed.classList.remove('show');
      clearFile();
    }

    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        clearError();

        // topic is required — hidden inputs aren't browser-validated, so enforce here
        if (topics && !topics.querySelector('.topic.on')) {
          if (routed) routed.classList.remove('show');
          topics.scrollIntoView({ behavior: 'smooth', block: 'center' });
          topics.querySelectorAll('.topic').forEach(function (t) {
            t.style.borderColor = 'var(--accent)';
            setTimeout(function () { t.style.borderColor = ''; }, 1200);
          });
          return;
        }
        if (!form.checkValidity()) { form.reportValidity(); return; }
        var f = fileInput && fileInput.files[0];
        if (f && !validFile(f)) return;
        if (consentH) consentH.value = (consentBox && consentBox.checked) ? 'Yes' : 'No';

        submitBtn.disabled = true;
        var label = submitBtn.textContent;
        submitBtn.textContent = 'Sending…';

        fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        }).then(function (res) {
          if (!res.ok) throw new Error('basin ' + res.status);
          openConfirm();
          resetForm();
        }).catch(function () {
          showError('Something went wrong sending your message. Please try again, or email us at care@lefigue.com.');
        }).finally(function () {
          submitBtn.disabled = false;
          submitBtn.textContent = label;
        });
      });
    }

    var closeBtn = root.querySelector('#lfc-closeConfirm');
    function close() { if (scrim) scrim.classList.remove('open'); }
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (scrim) scrim.addEventListener('click', function (e) { if (e.target === scrim) close(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
  })();
{% endjavascript %}

