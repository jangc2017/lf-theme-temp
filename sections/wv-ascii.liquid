<div class="lf-visit-wv">
<!-- ===== HERO ===== -->
<section class="hero">
  <div class="crumbs"><a href="#">Visit NYC</a> &#183; West Village</div>
  <span class="eyebrow">LE FIGUE &#183; The First Door</span>
  <h1>West Village</h1>
  <div class="addr">18 Christopher Street, New York</div>
  <p class="lead">A white building on Christopher Street that feels like a small corner of Europe, folded quietly into New York. Step inside and the city lowers its voice, and the tray does the talking.</p>
  <div class="rule"></div>
</section>

<div class="wrap">

  <!-- ===== GALLERY (swap .ph for <img> when photography is ready) ===== -->
  <div class="gallery">
    <div class="g main"><div class="ph"><span>Storefront on Christopher Street, golden hour</span></div></div>
    <div class="g sub"><div class="ph"><span>The tray table by the window</span></div></div>
    <div class="g sub"><div class="ph"><span>The shelf of objects, not for sale</span></div></div>
    <div class="g sub"><div class="ph"><span>Hands over the case, mid edit</span></div></div>
  </div>
  <div class="g-cap">The room, as it is</div>

  <!-- ===== HOURS &#183; VISIT &#183; SERVICES ===== -->
  <div class="band">
    <div class="cell">
      <span class="eyebrow">Open Hours</span>
      <h3>When to Come</h3>
      <div class="hours" id="hours">
        <div class="r today"><span class="d">Daily</span><span class="t">11 &#8211; 7</span></div>
      </div>
      <p style="font-size:12.5px;color:var(--ink-soft);margin-top:14px;">Seven days a week, every week. The door is open when the light is on.</p>
    </div>
    <div class="cell">
      <span class="eyebrow">Visit</span>
      <h3>Finding the Door</h3>
      <p><b>18 Christopher Street</b><br>New York, NY 10014</p>
      <p style="margin-top:12px;">Two blocks west of the 1 train at Christopher Street. Look for the quiet window.</p>
      <p style="margin-top:12px;"><b>hello@lefigue.com</b></p>
      <a class="linkline" href="https://maps.google.com/?q=18+Christopher+Street+New+York+NY" target="_blank" rel="noopener">Get Directions</a>
    </div>
    <div class="cell">
      <span class="eyebrow">In This Room</span>
      <h3>What We Offer</h3>
      <ul class="svc">
        <li>The full tray, styled in person</li>
        <li>Same day pickup for online orders</li>
        <li>Gift wrapping, always complimentary</li>
        <li>Walk ins welcome, every open hour</li>
      </ul>
    </div>
  </div>

  <!-- ===== MAP ===== -->
  <section class="mapsec">
    <div class="sec-head"><h2>On the Map</h2><span class="k">West Village</span></div>
    <div class="map-grid">
      <div class="map-frame">
        <iframe title="LE FIGUE West Village map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=18+Christopher+Street,+New+York,+NY+10014&output=embed"></iframe>
      </div>
      <div class="map-note">
        <span class="eyebrow">The Neighborhood</span>
        <h4>Make an afternoon of it</h4>
        <p>The blocks around our door are built for the rest of the day. Coffee two corners north, the golden hour walk west, a small table nearby for dinner. We wrote the route down.</p>
        <a class="btn ghost" href="#" style="margin-top:22px;">The West Village Route</a>
      </div>
    </div>
  </section>

  <!-- ===== PICKUP ===== -->
  <section class="pickup">
    <div class="sec-head"><h2>Ready at This Boutique</h2><span class="k">Pickup &#183; Usually Within 2 Hours</span></div>
    <div class="pick-grid">
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>R</span></div><span class="tag">Pickup Today</span></div>
        <div class="bc">Romilt &#183; Seoul</div><div class="nm">Coil Band Ring</div><div class="pr">$260</div>
      </a>
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>M</span></div><span class="tag">Pickup Today</span></div>
        <div class="bc">Miliemoon &#183; New York</div><div class="nm">Quiet Pendant</div><div class="pr">$340</div>
      </a>
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>H</span></div><span class="tag">Pickup Today</span></div>
        <div class="bc">H&#229;nd &#183; Copenhagen</div><div class="nm">Pebble Studs</div><div class="pr">$240</div>
      </a>
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>L</span></div><span class="tag">Pickup Today</span></div>
        <div class="bc">LA2L &#183; Paris</div><div class="nm">Galet Signet Ring</div><div class="pr">$420</div>
      </a>
    </div>
    <div class="pick-cta">
      <a class="btn" href="#">Shop Everything Ready at West Village</a>
      <p style="font-size:12px;color:var(--ink-soft);margin-top:14px;">Order online, choose pickup at checkout, and we will have it wrapped when you arrive.</p>
    </div>
  </section>

  <!-- ===== THE OTHER DOOR ===== -->
  <section class="other">
    <div class="fr"><div class="ph"><span>19 Bleecker Street, the door in morning light</span></div></div>
    <div>
      <span class="eyebrow">The House, Expanded</span>
      <h3>Bleecker &#183; NoHo</h3>
      <p>Opening September 2026. The tray comes to a table, with private edits, custom pieces, and the long look. The first appointments open with the door.</p>
      <a class="btn ghost" href="/pages/visit-bleecker">Visit the Bleecker Page</a>
    </div>
  </section>

</div>
</div>
{% stylesheet %}
.lf-visit-wv{--cream:#fdfbf6;--cream-deep:#f3eee4;--paper:#fffdf9;--ink:#2a2622;--ink-soft:#5b554d;--gold:#b8975f;--accent:#8a7250;--line:#e3dccd;}.lf-visit-wv *{box-sizing:border-box;margin:0;padding:0;}.lf-visit-wv{scroll-behavior:smooth;}.lf-visit-wv{background:var(--cream);color:var(--ink);font-family:'Pretendard Variable','Pretendard',-apple-system,sans-serif;font-size:15px;line-height:1.75;-webkit-font-smoothing:antialiased;}.lf-visit-wv a{color:inherit;text-decoration:none;}.lf-visit-wv button{font-family:inherit;cursor:pointer;color:inherit;}.lf-visit-wv ::selection{background:rgba(184,151,95,.22);}.lf-visit-wv .eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent);}.lf-visit-wv .topbar{border-bottom:1px solid var(--line);background:var(--cream);position:sticky;top:0;z-index:60;}.lf-visit-wv .topbar-in{max-width:1240px;margin:0 auto;padding:0 32px;height:62px;display:flex;align-items:center;gap:26px;}.lf-visit-wv .logo{font-family:'Cormorant Garamond',serif;font-size:21px;letter-spacing:.22em;font-weight:600;}.lf-visit-wv .nav{display:flex;gap:26px;margin-left:auto;}.lf-visit-wv .nav a{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-soft);}.lf-visit-wv .nav a.active{color:var(--ink);border-bottom:1px solid var(--gold);padding-bottom:3px;}.lf-visit-wv .wrap{max-width:1240px;margin:0 auto;padding:0 32px;}.lf-visit-wv .hero{text-align:center;padding:78px 24px 50px;}.lf-visit-wv .hero .crumbs{font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:20px;}.lf-visit-wv .hero .crumbs a{color:var(--accent);}.lf-visit-wv .hero h1{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:clamp(42px,6vw,68px);line-height:1.04;letter-spacing:.01em;}.lf-visit-wv .hero .addr{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:20px;color:var(--gold);margin-top:14px;letter-spacing:.03em;}.lf-visit-wv .hero .lead{max-width:520px;margin:18px auto 0;font-size:14.5px;color:var(--ink-soft);line-height:1.85;}.lf-visit-wv .hero .rule{width:44px;height:1px;background:var(--ink);margin:34px auto 0;}.lf-visit-wv .gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:26px;}.lf-visit-wv .g{position:relative;overflow:hidden;background:var(--cream-deep);}.lf-visit-wv .g.main{grid-column:1/-1;aspect-ratio:21/9;}.lf-visit-wv .g.sub{aspect-ratio:4/5;}.lf-visit-wv .g img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}.lf-visit-wv .ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;text-align:center;padding:0 20px;
  background:radial-gradient(120% 90% at 30% 18%, #fbf8f2 0%, #f0e8da 55%, #e7ddca 100%);}.lf-visit-wv .ph::after{content:"";position:absolute;inset:0;background:repeating-linear-gradient(135deg, rgba(138,114,80,.04) 0 2px, transparent 2px 9px);}.lf-visit-wv .ph span{position:relative;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:14px;color:#a2917a;line-height:1.5;}.lf-visit-wv .g-cap{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft);text-align:right;margin:-12px 2px 0;}.lf-visit-wv .band{border-top:1px solid var(--ink);border-bottom:1px solid var(--line);margin-top:56px;
  display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;}.lf-visit-wv .cell{padding:38px 34px 42px;border-right:1px solid var(--line);}.lf-visit-wv .cell:last-child{border-right:none;}.lf-visit-wv .cell h3{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:22px;letter-spacing:.04em;margin:10px 0 18px;}.lf-visit-wv .hours{width:100%;font-size:13.5px;color:var(--ink-soft);}.lf-visit-wv .hours .r{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px dotted var(--line);}.lf-visit-wv .hours .r:last-child{border-bottom:none;}.lf-visit-wv .hours .d{color:var(--ink);}.lf-visit-wv .hours .today .d,.lf-visit-wv .hours .today .t{color:var(--accent);font-weight:500;}.lf-visit-wv .cell p{font-size:13.5px;color:var(--ink-soft);line-height:1.9;}.lf-visit-wv .cell p b{color:var(--ink);font-weight:500;}.lf-visit-wv .linkline{display:inline-block;margin-top:14px;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink);border-bottom:1px solid var(--gold);padding-bottom:3px;}.lf-visit-wv .svc{list-style:none;font-size:13.5px;color:var(--ink-soft);}.lf-visit-wv .svc li{padding:7px 0 7px 20px;position:relative;border-bottom:1px dotted var(--line);}.lf-visit-wv .svc li:last-child{border-bottom:none;}.lf-visit-wv .svc li::before{content:"";position:absolute;left:2px;top:17px;width:8px;height:1px;background:var(--gold);}.lf-visit-wv .mapsec{margin-top:64px;}.lf-visit-wv .sec-head{display:flex;align-items:baseline;gap:16px;border-bottom:1px solid var(--ink);padding-bottom:14px;margin-bottom:28px;}.lf-visit-wv .sec-head h2{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:30px;letter-spacing:.02em;}.lf-visit-wv .sec-head .k{margin-left:auto;font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);}.lf-visit-wv .map-grid{display:grid;grid-template-columns:2fr 1fr;gap:14px;}.lf-visit-wv .map-frame{aspect-ratio:16/8;border:1px solid var(--line);overflow:hidden;background:var(--cream-deep);}.lf-visit-wv .map-frame iframe{width:100%;height:100%;border:0;filter:sepia(.18) saturate(.82);}.lf-visit-wv .map-note{background:var(--paper);border:1px solid var(--line);padding:30px 30px 26px;display:flex;flex-direction:column;}.lf-visit-wv .map-note h4{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:20px;margin:8px 0 12px;}.lf-visit-wv .map-note p{font-size:13.5px;color:var(--ink-soft);line-height:1.9;}.lf-visit-wv .map-note .btn{margin-top:auto;}.lf-visit-wv .pickup{margin-top:72px;}.lf-visit-wv .pick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px;}.lf-visit-wv .pc{display:block;}.lf-visit-wv .pc .fr{position:relative;aspect-ratio:4/5;overflow:hidden;background:var(--cream-deep);margin-bottom:12px;}.lf-visit-wv .pc .fr .ph span{font-size:26px;font-style:normal;color:rgba(138,114,80,.32);}.lf-visit-wv .pc .tag{position:absolute;bottom:12px;left:12px;z-index:2;font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;
  background:rgba(253,251,246,.92);color:var(--accent);padding:5px 9px;}.lf-visit-wv .pc .bc{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);}.lf-visit-wv .pc .nm{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:600;margin-top:4px;line-height:1.25;}.lf-visit-wv .pc .pr{font-size:13px;color:var(--ink-soft);margin-top:4px;}.lf-visit-wv .pick-cta{text-align:center;margin-top:38px;}.lf-visit-wv .btn{display:inline-block;text-align:center;background:var(--ink);color:var(--cream);border:none;
  font-size:11.5px;letter-spacing:.22em;text-transform:uppercase;padding:16px 40px;transition:background .25s;}.lf-visit-wv .btn:hover{background:var(--accent);}.lf-visit-wv .btn.ghost{background:transparent;color:var(--ink);border:1px solid var(--ink);}.lf-visit-wv .btn.ghost:hover{border-color:var(--accent);color:var(--accent);background:transparent;}.lf-visit-wv .other{margin-top:84px;border-top:1px solid var(--line);padding:54px 0 70px;display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center;}.lf-visit-wv .other .fr{position:relative;aspect-ratio:16/10;overflow:hidden;background:var(--cream-deep);}.lf-visit-wv .other h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:32px;margin:12px 0 8px;}.lf-visit-wv .other p{font-size:14px;color:var(--ink-soft);max-width:420px;line-height:1.9;}.lf-visit-wv .other .btn{margin-top:22px;}.lf-visit-wv footer{background:var(--ink);color:#cfc6b9;margin-top:20px;}.lf-visit-wv .foot-in{max-width:1240px;margin:0 auto;padding:60px 32px 40px;display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:36px;}.lf-visit-wv .foot-logo{font-family:'Cormorant Garamond',serif;font-size:22px;letter-spacing:.3em;text-transform:uppercase;color:#f3ede1;}.lf-visit-wv .foot-sig{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:17px;color:var(--gold);margin-top:16px;}.lf-visit-wv .foot-tag{font-size:13px;margin-top:8px;line-height:1.85;max-width:240px;color:#a89e90;}.lf-visit-wv .foot-col h5{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#8f8576;margin-bottom:14px;}.lf-visit-wv .foot-col a{display:block;font-size:13.5px;color:#cfc6b9;padding:4px 0;}.lf-visit-wv .foot-col a:hover{color:#fff;}.lf-visit-wv .foot-bottom{max-width:1240px;margin:0 auto;padding:20px 32px 40px;border-top:1px solid rgba(255,255,255,.08);
  display:flex;justify-content:space-between;gap:14px;font-size:11.5px;color:#8f8576;flex-wrap:wrap;}@media(max-width:920px){.lf-visit-wv .nav{display:none;}.lf-visit-wv .band{grid-template-columns:1fr;}.lf-visit-wv .cell{border-right:none;border-bottom:1px solid var(--line);}.lf-visit-wv .map-grid{grid-template-columns:1fr;}.lf-visit-wv .pick-grid{grid-template-columns:1fr 1fr;gap:20px 14px;}.lf-visit-wv .other{grid-template-columns:1fr;gap:24px;}.lf-visit-wv .gallery{gap:10px;}.lf-visit-wv .foot-in{grid-template-columns:1fr 1fr;}
}@media(max-width:560px){.lf-visit-wv .wrap,.lf-visit-wv .topbar-in{padding-left:20px;padding-right:20px;}.lf-visit-wv .gallery{grid-template-columns:1fr;}.lf-visit-wv .g.sub{aspect-ratio:16/10;}.lf-visit-wv .pick-grid{grid-template-columns:1fr;}.lf-visit-wv .foot-in{grid-template-columns:1fr;}
}

