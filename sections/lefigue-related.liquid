{%- comment -%}
  LE FIGUE — "You May Also Like" (related products on the product page).
  Replaces the demo "More in Stoneware" featured-collection-slider.
  Sourcing per product:
    Tier 1 — same brand (vendor) AND same category
    Tier 2 — fill remaining slots with same category (any brand)
  Renders in the theme's own slider markup + product-item card so it matches
  the rest of the site. Hides itself when there is nothing relevant to show.
{%- endcomment -%}

{%- liquid
  assign max = section.settings.maximum_products

  capture custom_swatch_color_maps
    render 'get-custom-swatch-color-maps'
  endcapture
  assign custom_color_key_map = custom_swatch_color_maps | split: ' | ' | first | split: ','
  assign custom_color_value_map = custom_swatch_color_maps | split: ' | ' | last | split: ','

  assign want_cat = product.category.name | default: product.type
  assign seen = ',' | append: product.id | append: ','
  assign shown = 0

  assign brand_col = nil
  assign cat_col = nil
  for c in product.collections
    if brand_col == nil and c.title == product.vendor
      assign brand_col = c
    endif
    if cat_col == nil and c.title == want_cat
      assign cat_col = c
    endif
  endfor
-%}

{%- capture slides -%}
  {%- comment -%} Tier 1: same brand + same category {%- endcomment -%}
  {%- if brand_col != nil and want_cat != blank -%}
    {%- for p in brand_col.products -%}
      {%- if shown >= max -%}{%- break -%}{%- endif -%}
      {%- assign p_cat = p.category.name | default: p.type -%}
      {%- assign key = ',' | append: p.id | append: ',' -%}
      {%- if p_cat == want_cat and p.id != product.id -%}
        {%- unless seen contains key -%}
          {%- assign seen = seen | append: p.id | append: ',' -%}
          {%- assign shown = shown | plus: 1 -%}
          <div class="featured-collection-slider__product carousel__slide swiper-slide">
            {%- render 'product-item',
              prod: p,
              aspect_ratio: settings.product_listing_aspect_ratio,
              product_columns: section.settings.columns,
              custom_color_key_map: custom_color_key_map,
              custom_color_value_map: custom_color_value_map
            -%}
          </div>
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%} Tier 2: fill with same category, any brand {%- endcomment -%}
  {%- if shown < max and cat_col != nil and want_cat != blank -%}
    {%- for p in cat_col.products -%}
      {%- if shown >= max -%}{%- break -%}{%- endif -%}
      {%- assign p_cat = p.category.name | default: p.type -%}
      {%- assign key = ',' | append: p.id | append: ',' -%}
      {%- if p_cat == want_cat and p.id != product.id -%}
        {%- unless seen contains key -%}
          {%- assign seen = seen | append: p.id | append: ',' -%}
          {%- assign shown = shown | plus: 1 -%}
          <div class="featured-collection-slider__product carousel__slide swiper-slide">
            {%- render 'product-item',
              prod: p,
              aspect_ratio: settings.product_listing_aspect_ratio,
              product_columns: section.settings.columns,
              custom_color_key_map: custom_color_key_map,
              custom_color_value_map: custom_color_value_map
            -%}
          </div>
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endcapture -%}

{%- assign slides_stripped = slides | strip -%}
{%- if slides_stripped != blank -%}
  {%- capture nav_attr -%}data-navigation="0"{%- endcapture -%}
  <div
    class="
      featured-collection-slider
      featured-collection-slider--mobile-per-view-{{ section.settings.mobile_columns }}
      featured-collection-slider--per-view-{{ section.settings.mobile_columns }}
      section
      section--includes-product-items
      section--divider-{{ section.settings.divider_style }}
      {{ section.settings.section_padding }}
      {% if settings.enable_section_animations and section.settings.enable_animation %}animation animation--list-slider{% endif %}
    "
    data-section-id="{{ section.id }}"
    data-section-type="featured-collection-slider"
    data-products-per-view="{{ section.settings.columns }}"
    data-mobile-products-per-view="{{ section.settings.mobile_columns }}"
  >
    <div class="featured-collection-slider__inner">
      <div class="featured-collection-slider__meta carousel__navigation-wrapper">
        <div class="section-introduction animation--section-introduction">
          {%- unless section.settings.heading == blank -%}
            <{{ section.settings.heading_tag }} class="featured-collection-slider__heading section-introduction__heading ff-heading fs-heading-3-base">
              {{ section.settings.heading }}
            </{{ section.settings.heading_tag }}>
          {%- endunless -%}
          {%- unless section.settings.subheading == blank -%}
            <div class="featured-collection-slider__subheading section-introduction__subheading rte ff-body fs-body-100">
              {{ section.settings.subheading }}
            </div>
          {%- endunless -%}
        </div>
        {%- render 'carousel-navigation',
          wrapper_class: 'featured-collection-slider__navigation-buttons animation--controls visible',
          data_attribute: nav_attr
        -%}
      </div>

      <div class="featured-collection-slider__content carousel swiper visible" data-collection="0">
        <div class="featured-collection-slider__products carousel__wrapper swiper-wrapper">
          {{ slides }}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "You May Also Like",
  "tag": "section",
  "class": "featured-collections-slider-wrap",
  "disabled_on": {
    "groups": ["header", "custom.overlay"],
    "templates": ["password"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "h4", "label": "h4" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "paragraph",
      "content": "Shows items with the same brand and category as the current product, then fills remaining slots with same-category items."
    },
    {
      "type": "range",
      "id": "maximum_products",
      "label": "Maximum products",
      "min": 3,
      "max": 15,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Desktop columns",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable animation",
      "default": true
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Divider",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section padding",
      "options": [
        { "value": "section--vertical-padding-none", "label": "None" },
        { "value": "section--vertical-padding-top-bottom", "label": "Top and bottom" },
        { "value": "section--vertical-padding-top-only", "label": "Top only" },
        { "value": "section--vertical-padding-bottom-only", "label": "Bottom only" }
      ],
      "default": "section--vertical-padding-top-bottom"
    }
  ],
  "presets": [
    { "name": "You May Also Like" }
  ]
}
{% endschema %}
