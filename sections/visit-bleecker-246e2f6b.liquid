<div class="lf-visit-bleecker">
<!-- ===== OPENING POSTER (pre-opening state) ===== -->
<div class="poster-wrap">
  <div class="poster"><div class="poster-in">
    <span class="corner tl">Le Figue</span><span class="corner tr">New York</span>
    <span class="corner bl">NoHo</span><span class="corner br">MMXXVI</span>
    <div class="ov">LE FIGUE · The House, Expanded</div>
    <div class="no">No. II</div>
    <h1>BLEECKER</h1>
    <div class="addr">19 Bleecker Street · New York</div>
    <div class="prule"></div>
    <div class="when">Opening September 2026</div>
    <p class="line">The tray comes to a table.</p>
    <p class="sub">Private edits, custom pieces, and the long look.</p>
    <div class="p-form">
      <input type="email" placeholder="Your email" aria-label="Email">
      <button type="button" id="pJoin">Join the Opening List</button>
    </div>
    <p class="fine">The opening date, the first appointments, the opening evening. Nothing else.</p>
  </div></div>
</div>

<!-- ===== NORMAL HERO (post-opening: flips on when OPENING = false) ===== -->
<section class="hero">
  <div class="crumbs"><a href="#">Visit NYC</a> · Bleecker · NoHo</div>
  <span class="eyebrow">LE FIGUE · The House, Expanded</span>
  <h1>Bleecker · NoHo</h1>
  <div class="addr">19 Bleecker Street, New York</div>
  <p class="lead">The tray comes to a table. A room built for the long look, the private edit, and the pieces that deserve a chair.</p>
  <div class="rule"></div>
</section>

<div class="wrap">

  <!-- ===== APPOINTMENT + CUSTOM (Bleecker only) ===== -->
  <div class="duo-cta">
    <div class="dc">
      <span class="rn">i</span>
      <h3>The Private Edit</h3>
      <p>A tray built around your note before you arrive. A chair, a drink, and enough quiet to try the third option you would not have asked for at a counter.</p>
      <p class="note">First appointments open with the door · Complimentary</p>
      <a class="btn" href="/pages/book-appointment">Book an Appointment</a>
    </div>
    <div class="dc">
      <span class="rn">ii</span>
      <h3>A Piece of Your Own</h3>
      <p>Custom and bespoke work with our designer June. From a first sketch over the table to a piece that exists nowhere else, in gold, silver, and stone.</p>
      <p class="note">By consultation · Begins with a conversation</p>
      <a class="btn gold" href="/pages/custom-bespoke">Begin a Custom Piece</a>
    </div>
  </div>

  <!-- ===== GALLERY (swap .ph for <img> when photography is ready) ===== -->
  <div class="gallery">
    <div class="g main"><div class="ph"><span>The Bleecker room, morning light on a set table</span></div></div>
    <div class="g sub"><div class="ph"><span>The appointment table, laid for two</span></div></div>
    <div class="g sub"><div class="ph"><span>The gift room, shelves in shadow</span></div></div>
    <div class="g sub"><div class="ph"><span>The bench where custom pieces begin</span></div></div>
  </div>
  <div class="g-cap">The room, as it will be</div>

  <!-- ===== HOURS · VISIT · SERVICES ===== -->
  <div class="band">
    <div class="cell">
      <span class="eyebrow">Open Hours</span>
      <h3>When to Come</h3>
      <div class="hours" id="hours">
        <div class="r today"><span class="d">Daily</span><span class="t">11 – 7</span></div>
      </div>
      <p class="hours-note" id="hoursNote">Hours begin with the September opening and may settle in the first weeks.</p>
    </div>
    <div class="cell">
      <span class="eyebrow">Visit</span>
      <h3>Finding the Door</h3>
      <p><b>19 Bleecker Street</b><br>New York, NY 10012</p>
      <p style="margin-top:12px;">Between Bowery and Lafayette, a short walk from the 6 at Bleecker Street and the B, D, F, M at Broadway–Lafayette.</p>
      <p style="margin-top:12px;"><b>bleecker@lefigue.com</b></p>
      <a class="linkline" href="https://maps.google.com/?q=19+Bleecker+Street+New+York+NY" target="_blank" rel="noopener">Get Directions</a>
    </div>
    <div class="cell">
      <span class="eyebrow">In This Room</span>
      <h3>What Changes Here</h3>
      <ul class="svc">
        <li>The private edit, a tray built before you arrive</li>
        <li>Custom and bespoke pieces with June</li>
        <li>The gift room, for presents that cannot be guessed</li>
        <li>Fine and demi fine, the long look at a table</li>
        <li>Boutique pickup, from opening week</li>
      </ul>
    </div>
  </div>

  <!-- ===== MAP ===== -->
  <section class="mapsec">
    <div class="sec-head"><h2>On the Map</h2><span class="k">NoHo</span></div>
    <div class="map-grid">
      <div class="map-frame">
        <iframe title="LE FIGUE Bleecker map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=19+Bleecker+Street,+New+York,+NY+10012&output=embed"></iframe>
      </div>
      <div class="map-note">
        <span class="eyebrow">The Neighborhood</span>
        <h4>NoHo, at a walk</h4>
        <p>Galleries a block in either direction, the gallery we keep returning to among them, and some of the best tables downtown within five minutes. The Bleecker edit of the neighborhood arrives with the opening.</p>
        <a class="btn ghost" href="#" style="margin-top:22px;">Read the Bleecker Edit</a>
      </div>
    </div>
  </section>

  <!-- ===== PICKUP ===== -->
  <section class="pickup">
    <div class="sec-head"><h2>Ready at This Boutique</h2><span class="k" id="pickState">Pickup Begins With the Door</span></div>
    <div class="pick-grid">
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>F</span></div><span class="tag pick-tag">From September</span></div>
        <div class="bc">LE FIGUE · Fine</div><div class="nm">Fine Diamond Line Band</div><div class="pr">$780</div>
      </a>
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>B</span></div><span class="tag pick-tag">From September</span></div>
        <div class="bc">Miliemoon · New York</div><div class="nm">The Bleecker Signet</div><div class="pr">$420</div>
      </a>
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>S</span></div><span class="tag pick-tag">From September</span></div>
        <div class="bc">Stilla · Milan</div><div class="nm">Sculptural Statement Cuff</div><div class="pr">$980</div>
      </a>
      <a class="pc" href="#">
        <div class="fr"><div class="ph"><span>O</span></div><span class="tag pick-tag">From September</span></div>
        <div class="bc">LE FIGUE · Opening</div><div class="nm">Opening Pearl Drop</div><div class="pr">$430</div>
      </a>
    </div>
    <div class="pick-cta">
      <a class="btn" href="#" id="pickBtn">Preview the Bleecker Pickup Edit</a>
      <p style="font-size:12px;color:var(--ink-soft);margin-top:14px;" id="pickLine">From opening week: order online, choose Bleecker at checkout, and it is wrapped when you arrive.</p>
    </div>
  </section>

  <!-- ===== THE OTHER DOOR ===== -->
  <section class="other">
    <div class="fr"><div class="ph"><span>18 Christopher Street, the quiet window</span></div></div>
    <div>
      <span class="eyebrow">The First Door</span>
      <h3>West Village</h3>
      <p>Where LE FIGUE began, and open today. The full tray, same day pickup, and walk ins welcome every open hour at 18 Christopher Street.</p>
      <a class="btn ghost" href="/pages/visit-west-village">Visit the West Village Page</a>
    </div>
  </section>

</div>
