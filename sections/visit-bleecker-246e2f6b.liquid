{% javascript %}
(function(){
var root=document.querySelector('.lf-visit-bleecker');
if(!root) return;
// ============================================================
  //  OPENING = true  -> poster hero, "From September" pickup tags
  //  OPENING = false -> normal hero, live pickup wording
  //  Flip this one flag on opening day.
  // ============================================================
  var OPENING = true;

  if(!OPENING){
    root.classList.add('open-mode');
    root.querySelector('#pickState').textContent = 'Pickup · Usually Within 2 Hours';
    root.querySelector('#pickBtn').textContent = 'Shop Everything Ready at Bleecker';
    root.querySelector('#pickLine').textContent = 'Order online, choose pickup at checkout, and we will have it wrapped when you arrive.';
    root.querySelector('#hoursNote').style.display = 'none';
    root.querySelectorAll('.pick-tag').forEach(function(t){ t.textContent = 'Pickup Today'; });
  }

  // opening list capture (wire to Klaviyo list when live)
  root.querySelector('#pJoin').addEventListener('click', function(){
    var inp = this.parentElement.querySelector('input');
    if(inp.value && inp.value.indexOf('@') > 0){
      this.parentElement.outerHTML = '<p style="font-family:\'Cormorant Garamond\',serif;font-style:italic;font-size:18px;color:#8a7250;margin-top:26px;">Thank you. You will hear from us first.</p>';
    } else { inp.focus(); }
  });
})();
