<div class="lf-visit-wv">
<!-- ===== HERO ===== -->
<section class="hero">
  <div class="crumbs"><a href="#">Visit NYC</a> · West Village</div>
  <span class="eyebrow">LE FIGUE · The First Door</span>
  <h1>West Village</h1>
  <div class="addr">18 Christopher Street, New York</div>
  <p class="lead">A white building on Christopher Street that feels like a small corner of Europe, folded quietly into New York. Step inside and the city lowers its voice, and the tray does the talking.</p>
  <div class="rule"></div>
</section>

<div class="wrap">

  <!-- ===== GALLERY (swap .ph for <img> when photography is ready) ===== -->
  <div class="gallery">
    <div class="g main"><div class="ph"><span>Storefront on Christopher Street, golden hour</span></div></div>
    <div class="g sub"><div class="ph"><span>The tray table by the window</span></div></div>
    <div class="g sub"><div class="ph"><span>The shelf of objects, not for sale</span></div></div>
    <div class="g sub"><div class="ph"><span>Hands over the case, mid edit</span></div></div>
  </div>
  <div class="g-cap">The room, as it is</div>

  <!-- ===== HOURS · VISIT · SERVICES ===== -->
  <div class="band">
    <div class="cell">
      <span class="eyebrow">Open Hours</span>
      <h3>When to Come</h3>
      <div class="hours" id="hours">
        <div class="r today"><span class="d">Daily</span><span class="t">11 – 7</span></div>
      </div>
      <p style="font-size:12.5px;color:var(--ink-soft);margin-top:14px;">Seven days a week, every week. The door is open when the light is on.</p>
    </div>
    <div class="cell">
      <span class="eyebrow">Visit</span>
      <h3>Finding the Door</h3>
      <p><b>18 Christopher Street</b><br>New York, NY 10014</p>
      <p style="margin-top:12px;">Two blocks west of the 1 train at Christopher Street. Look for the quiet window.</p>
      <p style="margin-top:12px;"><b>hello@lefigue.com</b></p>
      <a class="linkline" href="https://maps.google.com/?q=18+Christopher+Street+New+York+NY" target="_blank" rel="noopener">Get Directions</a>
    </div>
    <div class="cell">
      <span class="eyebrow">In This Room</span>
      <h3>What We Offer</h3>
      <ul class="svc">
        <li>The full tray, styled in person</li>
        <li>Same day pickup for online orders</li>
        <li>Gift wrapping, always complimentary</li>
        <li>Walk ins welcome, every open hour</li>
      </ul>
    </div>
  </div>

  </div>
