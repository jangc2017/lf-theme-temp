{%- comment -%}
  LE FIGUE — Agenda (Visit NYC → Agenda). Calendar of pop-ups / drops / trips.
  Ported from the provided design; theme header/footer wrap it (design's own
  announce/header/footer removed). CSS+ids namespaced .lf-agenda / #lfa-*; the
  list-view toggle uses a class on the section root (not <body>).
  EVENTS ARE DATA-DRIVEN: Admin > Content > Metaobjects > Agenda Event (Active
  entries render). Popover "Add to calendar" downloads a real .ics file.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css">

<div class="lf-agenda">
{%- comment -%} Events come from Content > Metaobjects > Agenda Event (Active entries only). {%- endcomment -%}
<script type="application/json" data-lf-events>
[
{%- assign lf_emitted = 0 -%}
{%- for ev in shop.metaobjects.agenda_event.values -%}
  {%- if ev.date == blank or ev.title == blank -%}{%- continue -%}{%- endif -%}
  {%- if lf_emitted > 0 -%},{%- endif -%}
  {"date": {{ ev.date | date: '%Y-%m-%d' | json }},
   "type": {{ ev.event_type | json }},
   "title": {{ ev.title | json }},
   "where": {{ ev.where | json }},
   "desc": {{ ev.description | json }},
   "hint": {{ ev.hint | json }}}
  {%- assign lf_emitted = lf_emitted | plus: 1 -%}
{%- endfor -%}
]
</script>
  <div class="cal-wrap">
    <section class="cal-head">
      <div>
        <div class="eyebrow">Agenda</div>
        <h1 class="display">What's next.</h1>
      </div>
      <p class="lede">Pop-ups, drops, and the trips that bring new pieces home. Where to find LE FIGUE, and what is on its way.</p>
    </section>

    <div class="legend">
      <div class="leg"><span class="gly g-popup"><svg viewBox="0 0 14 14"><path d="M7 0l7 7-7 7-7-7z" fill="currentColor"/></svg></span><b>Pop-up</b><small>In-store, by date</small></div>
      <div class="leg"><span class="gly g-online"><svg viewBox="0 0 14 14"><circle cx="7" cy="7" r="6" fill="none" stroke="currentColor" stroke-width="1.6"/></svg></span><b>Online</b><small>Live, from anywhere</small></div>
      <div class="leg"><span class="gly g-trip"><svg viewBox="0 0 14 14"><path d="M7 0l1.8 4.7L14 5.3l-3.8 3.3L11.3 14 7 11.1 2.7 14l1.1-5.4L0 5.3l5.2-.6z" fill="currentColor"/></svg></span><b>Buying Trip</b><small>New pieces follow</small></div>
      <div class="leg"><span class="gly g-pair"><svg viewBox="0 0 14 14"><path d="M7 1l6 11H1z" fill="currentColor"/></svg></span><b>Pairing Drop</b><small>Every two weeks</small></div>
      <div class="leg"><span class="gly g-preord"><svg viewBox="0 0 14 14"><path d="M7 13L1 2h12z" fill="currentColor"/></svg></span><b>Pre-order</b><small>Reserve first</small></div>
    </div>

    <div class="cal-bar">
      <div class="cal-month" id="lfa-calMonth">Month <span class="yr">2026</span></div>
      <div style="display:flex;gap:14px;align-items:center;">
        <div class="cal-nav">
          <button id="lfa-prevM" type="button" aria-label="Previous month">&#8249;</button>
          <button id="lfa-nextM" type="button" aria-label="Next month">&#8250;</button>
        </div>
        <div class="cal-toggle">
          <button id="lfa-vGrid" type="button" class="on">Month</button>
          <button id="lfa-vList" type="button">List</button>
        </div>
      </div>
    </div>

    <!-- GRID VIEW -->
    <div class="view-grid">
      <div class="grid-head"><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span></div>
      <div class="grid" id="lfa-grid"></div>
    </div>

    <!-- LIST VIEW -->
    <div class="view-list">
      <div class="agenda" id="lfa-agenda"></div>
    </div>
  </div>

  <!-- DISPATCH — events subscribe (cosmetic) -->
  <section class="dispatch">
    <div class="dispatch-in">
      <div class="d-eyebrow">The Invitation</div>
      <h2 class="d-title">Be there first.</h2>
      <p class="d-line">Pop-ups, trunk shows, and private previews.</p>
      <p class="d-line"><span class="gold">First word</span> on pre-orders, drops, and the dates that fill quickly.</p>
      <div class="d-form">
        <input type="email" placeholder="Your email" aria-label="Email">
        <button type="button">Subscribe</button>
      </div>
      <p class="d-fine">Only when something is worth your calendar. Unsubscribe anytime.</p>
    </div>
  </section>

  <!-- detail popover -->
  <div class="cal-scrim" id="lfa-scrim"><div class="cal-pop">
    <button class="pop-x" id="lfa-popX" type="button" aria-label="Close">&times;</button>
    <div class="pop-gly" id="lfa-popGly"></div>
    <div class="pop-type" id="lfa-popType"></div>
    <h3 id="lfa-popTitle"></h3>
    <div class="pop-when" id="lfa-popWhen"></div>
    <div class="pop-where" id="lfa-popWhere"></div>
    <div class="pop-desc" id="lfa-popDesc"></div>
    <div class="pop-hint" id="lfa-popHint"></div>
    <button class="pop-btn" id="lfa-popBtn" type="button">Add to calendar</button>
  </div></div>
</div>

{% stylesheet %}
  .lf-agenda{ --ink:#2a2622; --ink-soft:#6b635a; --line:#e3dccf; --line-soft:#efe9dd; --cream:#faf7f1; --cream-deep:#f3ede1; --accent:#8a7250; --gold:#b8975f; --gold-pale:#d4bc8e; --paper:#fdfbf6;
    background:var(--cream); color:var(--ink); font-family:'Pretendard Variable','Pretendard',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-weight:400; line-height:1.7; -webkit-font-smoothing:antialiased; }
  .lf-agenda *{ box-sizing:border-box; }
  .lf-agenda a{ color:inherit; text-decoration:none; }
  .lf-agenda .display{ font-family:'Cormorant Garamond',serif; }

  .lf-agenda .cal-wrap{ max-width:1200px; margin:0 auto; padding:0 30px 80px; }
  .lf-agenda .cal-head{ padding:56px 0 24px; display:grid; grid-template-columns:1fr auto; gap:30px; align-items:end; }
  .lf-agenda .cal-head .eyebrow{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--accent); font-size:17px; margin-bottom:10px; }
  .lf-agenda .cal-head h1{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(44px,7vw,84px); line-height:.95; letter-spacing:-.018em; }
  .lf-agenda .cal-head .lede{ max-width:330px; font-size:13.5px; color:var(--ink-soft); line-height:1.75; text-align:right; padding-bottom:10px; }

  .lf-agenda .legend{ display:flex; flex-wrap:wrap; gap:8px 26px; padding:22px 0; border-top:1px solid var(--line); border-bottom:1px solid var(--line); margin-bottom:6px; }
  .lf-agenda .leg{ display:flex; align-items:center; gap:9px; font-size:12.5px; color:var(--ink-soft); }
  .lf-agenda .leg .gly{ width:18px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .lf-agenda .leg b{ color:var(--ink); font-weight:500; font-family:'Cormorant Garamond',serif; font-size:15px; font-style:italic; }
  .lf-agenda .leg small{ color:var(--ink-soft); font-size:11px; letter-spacing:.02em; }
  .lf-agenda .gly svg{ width:14px; height:14px; display:block; }
  .lf-agenda .g-popup{ color:var(--gold); }
  .lf-agenda .g-online{ color:var(--accent); }
  .lf-agenda .g-trip{ color:#9a6f4e; }
  .lf-agenda .g-pair{ color:#7c8a6a; }
  .lf-agenda .g-preord{ color:#a8758f; }

  .lf-agenda .cal-bar{ display:flex; align-items:center; justify-content:space-between; gap:20px; margin:26px 0 18px; flex-wrap:wrap; }
  .lf-agenda .cal-month{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(24px,3vw,34px); letter-spacing:-.01em; display:flex; align-items:center; gap:16px; }
  .lf-agenda .cal-month .yr{ color:var(--gold); font-style:italic; font-size:.62em; }
  .lf-agenda .cal-nav{ display:flex; gap:6px; }
  .lf-agenda .cal-nav button{ width:36px; height:36px; border:1px solid var(--line); background:var(--paper); color:var(--ink); cursor:pointer; font-size:16px; line-height:1; transition:.16s; display:flex; align-items:center; justify-content:center; }
  .lf-agenda .cal-nav button:hover{ border-color:var(--accent); color:var(--accent); }
  .lf-agenda .cal-toggle{ display:flex; border:1px solid var(--line); }
  .lf-agenda .cal-toggle button{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; color:var(--ink-soft); background:var(--paper); border:none; padding:8px 20px; cursor:pointer; transition:.16s; }
  .lf-agenda .cal-toggle button.on{ background:var(--ink); color:var(--paper); }

  .lf-agenda .view-grid{ display:block; }
  .lf-agenda .view-list{ display:none; }
  .lf-agenda.listmode .view-grid{ display:none; }
  .lf-agenda.listmode .view-list{ display:block; }

  .lf-agenda .grid-head{ display:grid; grid-template-columns:repeat(7,1fr); gap:1px; }
  .lf-agenda .grid-head span{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:12px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-soft); text-align:left; padding:0 8px 10px; }
  .lf-agenda .grid{ display:grid; grid-template-columns:repeat(7,1fr); gap:1px; background:var(--line); border:1px solid var(--line); }
  .lf-agenda .cell{ background:var(--paper); min-height:130px; padding:10px 10px 12px; position:relative; }
  .lf-agenda .cell.out{ background:#f6f1e8; }
  .lf-agenda .cell.out .dn{ color:#c4b9a4; }
  .lf-agenda .cell .dn{ font-family:'Cormorant Garamond',serif; font-size:16px; color:var(--ink-soft); margin-bottom:8px; }
  .lf-agenda .cell.today .dn{ color:var(--paper); background:var(--ink); width:25px; height:25px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; }
  .lf-agenda .cell .evs{ display:flex; flex-direction:column; gap:5px; }
  .lf-agenda .ev{ display:flex; align-items:center; gap:7px; cursor:pointer; padding:3px 5px; margin:0 -5px; border-radius:3px; transition:background .15s; }
  .lf-agenda .ev:hover{ background:var(--cream-deep); }
  .lf-agenda .ev .gly{ flex-shrink:0; }
  .lf-agenda .ev .et{ font-size:11.5px; line-height:1.35; color:var(--ink); transition:color .15s; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .lf-agenda .ev:hover .et{ color:var(--accent); }

  @media(max-width:760px){
    .lf-agenda .cell{ min-height:64px; padding:8px; }
    .lf-agenda .cell .et{ display:none; }
    .lf-agenda .cell .ev{ padding:0; margin:0; }
    .lf-agenda .cell .evs{ flex-direction:row; flex-wrap:wrap; gap:4px; }
  }

  .lf-agenda .agenda{ border-top:1px solid var(--line); }
  .lf-agenda .ag-row{ display:grid; grid-template-columns:120px 28px 1fr auto; gap:18px; align-items:center; padding:18px 4px; border-bottom:1px solid var(--line-soft); cursor:pointer; transition:background .15s; }
  .lf-agenda .ag-row:hover{ background:#fbf8f2; }
  .lf-agenda .ag-date{ font-family:'Cormorant Garamond',serif; color:var(--ink); }
  .lf-agenda .ag-date .d{ font-size:24px; font-weight:500; line-height:1; }
  .lf-agenda .ag-date .m{ font-style:italic; font-size:13px; color:var(--ink-soft); }
  .lf-agenda .ag-gly{ display:flex; align-items:center; justify-content:center; }
  .lf-agenda .ag-main .ag-type{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:12px; letter-spacing:.06em; color:var(--gold); text-transform:uppercase; }
  .lf-agenda .ag-main .ag-title{ font-family:'Cormorant Garamond',serif; font-size:20px; line-height:1.2; color:var(--ink); margin-top:1px; }
  .lf-agenda .ag-main .ag-where{ font-size:12px; color:var(--ink-soft); margin-top:2px; }
  .lf-agenda .ag-hint{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:12.5px; color:var(--accent); text-align:right; max-width:160px; line-height:1.4; }
  @media(max-width:680px){
    .lf-agenda .ag-row{ grid-template-columns:64px 22px 1fr; gap:12px; }
    .lf-agenda .ag-hint{ display:none; }
  }

  .lf-agenda .cal-scrim{ position:fixed; inset:0; background:rgba(33,29,25,.5); z-index:90; display:none; align-items:center; justify-content:center; padding:30px 20px; }
  .lf-agenda .cal-scrim.open{ display:flex; }
  .lf-agenda .cal-pop{ background:var(--paper); max-width:440px; width:100%; border:1px solid var(--line); box-shadow:0 40px 80px -30px rgba(0,0,0,.5); padding:34px 34px 30px; position:relative; }
  .lf-agenda .cal-pop .pop-gly{ margin-bottom:16px; }
  .lf-agenda .cal-pop .pop-type{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13px; letter-spacing:.12em; text-transform:uppercase; color:var(--gold); margin-bottom:6px; }
  .lf-agenda .cal-pop h3{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:30px; line-height:1.08; margin-bottom:10px; }
  .lf-agenda .cal-pop .pop-when{ font-size:13px; color:var(--ink); margin-bottom:4px; }
  .lf-agenda .cal-pop .pop-where{ font-size:13px; color:var(--ink-soft); margin-bottom:18px; }
  .lf-agenda .cal-pop .pop-desc{ font-size:14px; color:var(--ink-soft); line-height:1.8; border-top:1px solid var(--line-soft); padding-top:16px; margin-bottom:20px; }
  .lf-agenda .cal-pop .pop-hint{ background:var(--cream-deep); border-left:2px solid var(--gold); padding:12px 16px; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--accent); line-height:1.5; margin-bottom:22px; }
  .lf-agenda .cal-pop .pop-btn{ width:100%; text-align:center; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; padding:13px; border:1px solid var(--accent); color:var(--paper); background:var(--accent); cursor:pointer; transition:.18s; }
  .lf-agenda .cal-pop .pop-btn:hover{ background:var(--ink); border-color:var(--ink); }
  .lf-agenda .cal-pop .pop-x{ position:absolute; top:16px; right:18px; background:none; border:none; font-size:22px; color:var(--ink-soft); cursor:pointer; line-height:1; }
  .lf-agenda .cal-pop .pop-x:hover{ color:var(--accent); }

  @media(max-width:980px){
    .lf-agenda .cal-head{ grid-template-columns:1fr; gap:14px; }
    .lf-agenda .cal-head .lede{ text-align:left; max-width:480px; }
  }
  @media(max-width:620px){
    .lf-agenda .cal-wrap{ padding:0 20px 60px; }
    .lf-agenda .grid-head span{ font-size:10px; padding:0 4px 8px; }
  }

  .lf-agenda .dispatch{ background:var(--ink); color:var(--paper); padding:72px 30px; text-align:center; position:relative; overflow:hidden; }
  .lf-agenda .dispatch::before{ content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% -10%,rgba(184,151,95,.16),transparent 55%); pointer-events:none; }
  .lf-agenda .dispatch-in{ max-width:520px; margin:0 auto; position:relative; }
  .lf-agenda .d-eyebrow{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13px; letter-spacing:.34em; text-transform:uppercase; color:var(--gold-pale); margin-bottom:22px; }
  .lf-agenda .d-title{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:clamp(34px,5vw,52px); line-height:1.04; letter-spacing:-.015em; margin-bottom:18px; }
  .lf-agenda .d-line{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(16px,2.2vw,19px); line-height:1.6; color:rgba(253,251,246,.74); margin-bottom:8px; }
  .lf-agenda .d-line .gold{ color:var(--gold-pale); font-style:normal; }
  .lf-agenda .d-form{ display:flex; max-width:380px; margin:34px auto 0; border-bottom:1px solid rgba(212,188,142,.55); }
  .lf-agenda .d-form input{ flex:1; background:none; border:none; outline:none; padding:13px 4px; font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:14px; color:#fff; letter-spacing:.01em; }
  .lf-agenda .d-form input::placeholder{ color:rgba(253,251,246,.4); }
  .lf-agenda .d-form button{ background:none; border:none; cursor:pointer; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:16px; color:var(--gold-pale); padding:0 6px; transition:color .2s; white-space:nowrap; }
  .lf-agenda .d-form button:hover{ color:#fff; }
  .lf-agenda .d-fine{ margin-top:15px; font-family:'Pretendard Variable','Pretendard',sans-serif; font-size:11px; letter-spacing:.04em; color:rgba(253,251,246,.36); }
  @media(max-width:560px){ .lf-agenda .dispatch{ padding:56px 22px; } }
{% endstylesheet %}

{% javascript %}
  (function () {
    var root = document.querySelector('.lf-agenda');
    if (!root) return;
    function $(id){ return root.querySelector('#' + id); }

    var GLY = {
      popup:'<svg viewBox="0 0 14 14"><path d="M7 0l7 7-7 7-7-7z" fill="currentColor"/></svg>',
      online:'<svg viewBox="0 0 14 14"><circle cx="7" cy="7" r="6" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>',
      trip:'<svg viewBox="0 0 14 14"><path d="M7 0l1.8 4.7L14 5.3l-3.8 3.3L11.3 14 7 11.1 2.7 14l1.1-5.4L0 5.3l5.2-.6z" fill="currentColor"/></svg>',
      pair:'<svg viewBox="0 0 14 14"><path d="M7 1l6 11H1z" fill="currentColor"/></svg>',
      preord:'<svg viewBox="0 0 14 14"><path d="M7 13L1 2h12z" fill="currentColor"/></svg>'
    };
    var GCLS = {popup:'g-popup',online:'g-online',trip:'g-trip',pair:'g-pair',preord:'g-preord'};
    var TYPE_LABEL = {popup:'Pop-up',online:'Online',trip:'Buying Trip',pair:'Pairing Drop',preord:'Pre-order Drop'};
    function gly(t){ return '<span class="gly '+GCLS[t]+'">'+GLY[t]+'</span>'; }

    /* ---------- EVENT DATA: Content > Metaobjects > Agenda Event ---------- */
    var TMAP = {'Pop-up':'popup','Online':'online','Buying Trip':'trip','Pairing Drop':'pair','Pre-order':'preord'};
    var EVENTS = (function(){
      try {
        var el = root.querySelector('script[data-lf-events]');
        var arr = JSON.parse(el.textContent) || [];
        return arr.filter(function(e){ return e && e.date && e.title && !isNaN(Date.parse(e.date+'T00:00')); })
                  .map(function(e){ return { date:e.date, type:(TMAP[e.type]||'popup'), title:e.title,
                                             where:e.where||'', desc:e.desc||'', hint:e.hint||'' }; });
      } catch (err) { return []; }
    })();

    var MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
    var now0 = new Date();
    var cur = new Date(now0.getFullYear(), now0.getMonth(), 1); // start on the current month

    function evsOn(isoStr){ return EVENTS.filter(function(e){ return e.date===isoStr; }); }
    function iso(y,m,d){ return y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0'); }

    function renderGrid(){
      var y=cur.getFullYear(), m=cur.getMonth();
      $('lfa-calMonth').innerHTML = MONTHS[m]+' <span class="yr">'+y+'</span>';
      var first=new Date(y,m,1);
      var startDow=(first.getDay()+6)%7;
      var daysIn=new Date(y,m+1,0).getDate();
      var prevDays=new Date(y,m,0).getDate();
      var today=new Date();
      var todayIso=iso(today.getFullYear(),today.getMonth(),today.getDate());
      var cells='';
      for(var i=0;i<startDow;i++){ var dp=prevDays-startDow+1+i; cells+='<div class="cell out"><div class="dn">'+dp+'</div></div>'; }
      for(var d=1;d<=daysIn;d++){
        var di=iso(y,m,d);
        var evs=evsOn(di);
        var evHTML=evs.map(function(e,idx){
          return '<div class="ev" data-iso="'+di+'" data-idx="'+idx+'">'+gly(e.type)+'<span class="et">'+e.title+'</span></div>';
        }).join('');
        cells+='<div class="cell'+(di===todayIso?' today':'')+'"><div class="dn">'+d+'</div><div class="evs">'+evHTML+'</div></div>';
      }
      var total=startDow+daysIn;
      var trail=(7-(total%7))%7;
      for(var t=1;t<=trail;t++){ cells+='<div class="cell out"><div class="dn">'+t+'</div></div>'; }
      $('lfa-grid').innerHTML=cells;
    }

    function renderList(){
      var y=cur.getFullYear(), m=cur.getMonth();
      var inMonth=EVENTS.filter(function(e){ var dt=new Date(e.date+'T00:00'); return dt.getFullYear()===y && dt.getMonth()===m; })
                        .sort(function(a,b){ return a.date<b.date?-1:1; });
      if(!inMonth.length){ $('lfa-agenda').innerHTML='<p style="padding:30px 4px;color:var(--ink-soft);font-style:italic;font-family:Cormorant Garamond,serif;">Nothing on the agenda this month. Check back soon.</p>'; return; }
      $('lfa-agenda').innerHTML=inMonth.map(function(e){
        var dt=new Date(e.date+'T00:00');
        var realIdx=evsOn(e.date).indexOf(e);
        return '<div class="ag-row" data-iso="'+e.date+'" data-idx="'+realIdx+'">'
          +'<div class="ag-date"><span class="d">'+dt.getDate()+'</span> <span class="m">'+MONTHS[dt.getMonth()].slice(0,3)+'</span></div>'
          +'<div class="ag-gly">'+gly(e.type)+'</div>'
          +'<div class="ag-main"><div class="ag-type">'+TYPE_LABEL[e.type]+'</div><div class="ag-title">'+e.title+'</div><div class="ag-where">'+e.where+'</div></div>'
          +(e.hint?'<div class="ag-hint">'+e.hint+'</div>':'<div></div>')
          +'</div>';
      }).join('');
    }

    function renderAll(){ renderGrid(); renderList(); }
    renderAll();

    $('lfa-prevM').onclick=function(){ cur=new Date(cur.getFullYear(),cur.getMonth()-1,1); renderAll(); };
    $('lfa-nextM').onclick=function(){ cur=new Date(cur.getFullYear(),cur.getMonth()+1,1); renderAll(); };

    $('lfa-vGrid').onclick=function(){ root.classList.remove('listmode'); this.classList.add('on'); $('lfa-vList').classList.remove('on'); };
    $('lfa-vList').onclick=function(){ root.classList.add('listmode'); this.classList.add('on'); $('lfa-vGrid').classList.remove('on'); };

    var scrim=$('lfa-scrim');
    var curEv = null;
    function openEv(isoStr,idx){
      var e=evsOn(isoStr)[idx]; if(!e) return;
      curEv = e;
      $('lfa-popGly').innerHTML=gly(e.type);
      $('lfa-popType').textContent=TYPE_LABEL[e.type];
      $('lfa-popTitle').textContent=e.title;
      var dt=new Date(e.date+'T00:00');
      $('lfa-popWhen').textContent=MONTHS[dt.getMonth()]+' '+dt.getDate()+', '+dt.getFullYear();
      var placeOnly=e.where.split('·').filter(function(part){ return !/\d\s*(am|pm)|\bto\b|\bET\b/i.test(part); }).join('·').trim().replace(/·\s*$/,'').trim();
      $('lfa-popWhere').textContent=placeOnly || e.where;
      $('lfa-popDesc').textContent=e.desc;
      var hintEl=$('lfa-popHint');
      if(e.hint){ hintEl.textContent=e.hint; hintEl.style.display=''; } else { hintEl.style.display='none'; }
      scrim.classList.add('open');
    }
    root.addEventListener('click',function(ev){
      var rowEl=ev.target.closest('.ev,.ag-row');
      if(rowEl && rowEl.dataset.iso){ openEv(rowEl.dataset.iso, +rowEl.dataset.idx); }
    });
    function closePop(){ scrim.classList.remove('open'); }
    $('lfa-popX').onclick=closePop;
    $('lfa-popBtn').onclick = function(){
      if (!curEv) { closePop(); return; }
      function esc(s){ return String(s||'').replace(/\\/g,'\\\\').replace(/;/g,'\\;').replace(/,/g,'\\,').replace(/\n/g,'\\n'); }
      var d1 = curEv.date.replace(/-/g,'');
      var nd = new Date(new Date(curEv.date+'T00:00').getTime() + 86400000);
      var d2 = '' + nd.getFullYear() + String(nd.getMonth()+1).padStart(2,'0') + String(nd.getDate()).padStart(2,'0');
      var ics = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//LE FIGUE//Agenda//EN','BEGIN:VEVENT',
        'UID:lf-'+d1+'-'+encodeURIComponent(curEv.title).replace(/%/g,'')+'@lefigue.com',
        'DTSTAMP:'+d1+'T000000Z','DTSTART;VALUE=DATE:'+d1,'DTEND;VALUE=DATE:'+d2,
        'SUMMARY:'+esc(curEv.title),'LOCATION:'+esc(curEv.where),'DESCRIPTION:'+esc(curEv.desc),
        'END:VEVENT','END:VCALENDAR'].join('\r\n');
      var a = document.createElement('a');
      a.href = URL.createObjectURL(new Blob([ics], {type:'text/calendar'}));
      a.download = 'le-figue-'+d1+'.ics';
      document.body.appendChild(a); a.click(); a.remove();
      closePop();
    };
    scrim.addEventListener('click',function(e){ if(e.target===scrim) closePop(); });
    document.addEventListener('keydown',function(e){ if(e.key==='Escape') closePop(); });

    // dispatch subscribe (cosmetic)
    var dform=root.querySelector('.d-form');
    if(dform){
      var btn=dform.querySelector('button'), inp=dform.querySelector('input');
      btn.addEventListener('click',function(){
        if(inp.value && inp.value.indexOf('@')>0){
          dform.outerHTML='<p style="font-family:\'Cormorant Garamond\',serif;font-style:italic;font-size:18px;color:#d4bc8e;margin-top:34px;">Thank you. The next letter is on its way.</p>';
        } else { inp.focus(); }
      });
    }
  })();
{% endjavascript %}

